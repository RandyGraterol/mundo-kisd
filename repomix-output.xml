/* Stack vertical en móvil para flex */
@media (max-width: 640px) {
  .flex-mobile-col {
    flex-direction: column !important;
  }
  .flex-mobile-wrap {
    flex-wrap: wrap !important;
  }
  .w-full-mobile {
    width: 100% !important;
  }
  .text-center-mobile {
    text-align: center !important;
  }
  .hidden-mobile {
    display: none !important;
  }
}

/* Mejora de touch en móvil */
@media (hover: none) and (pointer: coarse) {
  .touch-target {
    min-height: 44px;
    min-width: 44px;
  }
  
  button, .btn, a[class*="bg-"] {
    min-height: 44px;
  }
}

/* Animación reducida para preferencia de accesibilidad */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Mejorar accesibilidad con focus visible profesional */
button:focus, a:focus, input:focus {
  outline: 2px solid #38bdf8; /* Sky 400 */
  outline-offset: 2px;
}

/* Asegurar fondo blanco en todos los contenedores anidados */
html, body {
  background-color: #ffffff !important;
}

body::before {
  display: none !important;
}

/* Glassmorphism refinado para fondo blanco */
.glass-effect {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(0, 0, 0, 0.05);
}

/* Glassmorphism simplificado en móvil (sin blur para rendimiento) */
@media (max-width: 640px) {
  .glass-effect {
    backdrop-filter: none;
    background: rgba(255, 255, 255, 0.95);
  }
}

/* Estilos del modal de atención */
#modal-atencion {
  animation: none;
}

#modal-contenido {
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
}

/* Estilos del cronómetro */
#cronometro-container {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 1.5rem;
  padding: 1.25rem;
  border: 1px solid rgba(0, 0, 0, 0.04);
}

/* Loader elegante */
.loader {
  border: 3px solid #f1f5f9;
  border-top: 3px solid #0ea5e9;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
