<file path="public/css/estilos-globales.css">
/* Estilos globales para Mundo Kids */

/* Fuente principal profesional */
body {
  font-family: 'Quicksand', sans-serif;
  color: #1e293b; /* Slate 800 */
  line-height: 1.6;
}

/* Animaciones globales suaves */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-10px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5px);
  }
}

/* Aplicar animaciones */
.animate-fade-in {
  animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.animate-fade-in-fast {
  animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.animate-slide-in {
  animation: slideIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.animate-bounce {
  animation: bounce 2s ease-in-out infinite;
}

/* Botones y elementos interactivos profesionales */
button, .btn, a[class*="bg-"] {
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  border-radius: 1rem;
}

button:hover, .btn:hover, a[class*="bg-"]:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

/* Sombras suaves y profesionales */
.soft-shadow {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
}

.soft-shadow-hover:hover {
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

/* Unificación de elementos: Integración suave (Glassmorphism) */
.glass-effect {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.unified-item {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 1.5rem;
  transition: all 0.3s ease;
}

.unified-item:hover {
  background: rgba(255, 255, 255, 0.8);
  border-color: #bae6fd; /* Sky 200 */
  transform: translateY(-2px);
}

/* Tipografía elegante */
h1, h2, h3, h4, h5, h6 {
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #0f172a; /* Slate 900 */
  line-height: 1.3;
}

/* Mejorar legibilidad */
p, li, span {
  line-height: 1.6;
}

/* Responsive: ajustar tamaños de fuente */
@media (max-width: 640px) {
  h1 { font-size: 2.25rem; }
  h2 { font-size: 1.875rem; }
  h3 { font-size: 1.5rem; }
}

/* Responsive: pantallas pequeñas */
@media (max-width: 640px) {
  .container-padding {
    padding-left: 1rem !important;
    padding-right: 1rem !important;
  }
  .card-padding {
    padding: 1.5rem !important;
  }
  .grid-gap-sm {
    gap: 0.75rem !important;
