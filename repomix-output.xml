// Rutas de Sopa de Letras - Mundo Kids
const express = require('express');
const router = express.Router();
const { generarSopaLetras, obtenerTemas } = require('../helpers/sopa-letras');
const { obtenerContinentes } = require('../data/continentes');
const { registrarActividad, actualizarPuntosYNivel } = require('../database/db');

// Middleware de verificación de sesión
function verificarSesion(req, res, next) {
  if (req.session.usuarioId || req.session.nombreUsuario) {
    res.locals.progreso = req.session.progreso || { nivel: 1, puntosTotal: 0, continentesVisitados: [], retosCompletados: [] };
    res.locals.nombreUsuario = req.session.nombreUsuario || (req.usuario && req.usuario.nombre_completo) || 'Estudiante';
    res.locals.genero = req.session.genero || 'masculino';
    return next();
  }
  res.redirect('/');
}

/**
 * GET /sopa-letras - Página principal de sopa de letras
 */
router.get('/', verificarSesion, (req, res) => {
  const temas = obtenerTemas();
  const continentes = obtenerContinentes().map(c => ({
    id: c.id,
    nombre: c.nombre,
    emoji: c.emoji,
    color: c.color
  }));

  res.render('sopa-letras', {
    temas,
    continentes,
    juego: null,
    mensaje: null
  });
});

/**
 * GET /sopa-letras/jugar - Generar nueva sopa de letras
 */
router.get('/jugar', verificarSesion, (req, res) => {
  const temaId = req.query.tema || 'global';
  const tamano = parseInt(req.query.tamano) || 12;
  
  const juego = generarSopaLetras(tamano, temaId);
  const temas = obtenerTemas();
  const temaSeleccionado = temas.find(t => t.id === temaId) || temas[0];

  // Guardar en sesión para verificar respuestas
  req.session.sopaLetras = {
    palabras: juego.palabras,
    posiciones: juego.posiciones
  };

  res.render('sopa-letras', {
    temas,
    juego: {
      grid: juego.grid,
      palabras: juego.palabras,
      tamano,
      tema: temaSeleccionado
    },
    mensaje: null
  });
});

/**
 * POST /sopa-letras/verificar - Verificar palabras encontradas (API)
 */
router.post('/verificar', express.json(), verificarSesion, (req, res) => {
  const { palabra } = req.body;
  const juegoGuardado = req.session.sopaLetras;

  if (!juegoGuardado || !juegoGuardado.palabras) {
    return res.json({ correcta: false, error: 'Sesión de juego no encontrada' });
  }

  const palabraUpper = palabra.toUpperCase().trim();
  const esCorrecta = juegoGuardado.palabras.includes(palabraUpper);

  // Acumular puntos si la palabra es correcta
  if (esCorrecta) {
    if (!req.session.palabrasEncontradas) {
      req.session.palabrasEncontradas = [];
    }
    if (!req.session.palabrasEncontradas.includes(palabraUpper)) {
      req.session.palabrasEncontradas.push(palabraUpper);
      
      // Sumar puntos en el progreso
      if (req.session.progreso) {
        req.session.progreso.puntosTotal += 5;
        const nivelAnterior = req.session.progreso.nivel;
        const nuevoNivel = Math.floor(req.session.progreso.puntosTotal / 30) + 1;
        if (nuevoNivel > nivelAnterior) {
          req.session.progreso.nivel = nuevoNivel;
        }
      }
      
      // Registrar actividad en BD si el usuario está autenticado
      if (req.session.usuarioId) {
        registrarActividad({
          usuarioId: req.session.usuarioId,
          tipoActividad: 'sopa_letras',
          puntajeObtenido: 5,
          respuestasCorrectas: 1,
          respuestasTotales: juegoGuardado.palabras.length,
          tiempoSegundos: null
        });
        actualizarPuntosYNivel(req.session.usuarioId, 5);
      }
    }
  }

  const juegoCompletado = esCorrecta && (req.session.palabrasEncontradas?.length || 0) >= juegoGuardado.palabras.length;

  res.json({
    correcta: esCorrecta,
    puntosGanados: esCorrecta ? 5 : 0,
    totalPalabras: juegoGuardado.palabras.length,
    palabrasEncontradas: req.session.palabrasEncontradas?.length || 0,
    juegoCompletado
  });
});

module.exports = router;
</file>

<file path="views/admin/alumno-detalle.ejs">
<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-6xl mx-auto">

    <!-- Header con datos del alumno -->
    <div class="mb-6 sm:mb-8">
      <div class="flex items-center gap-2 text-xs sm:text-sm font-semibold text-emerald-600 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        <a href="/admin/monitoreo" class="hover:text-emerald-700 transition-all">Monitoreo</a>
        <span>/ Detalle del Alumno</span>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-4 sm:gap-6">
          <div class="w-16 h-16 sm:w-20 sm:h-20 <%= alumno.genero === 'femenino' ? 'bg-pink-100 text-pink-600' : 'bg-blue-100 text-blue-600' %> rounded-2xl flex items-center justify-center font-bold text-3xl sm:text-4xl flex-shrink-0">
            <%= alumno.nombre_completo.charAt(0).toUpperCase() %>
          </div>
          <div class="min-w-0">
            <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-slate-900 truncate"><%= alumno.nombre_completo %></h1>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3 mt-1">
              <span class="text-sm sm:text-base text-slate-500">@<%= alumno.nombre_usuario %></span>
              <span class="w-1 h-1 bg-slate-300 rounded-full hidden sm:block"></span>
              <span class="px-2.5 py-0.5 rounded-full text-xs font-bold inline-flex items-center gap-1 <%= alumno.genero === 'femenino' ? 'bg-pink-100 text-pink-700' : 'bg-blue-100 text-blue-700' %>">
                <% if (alumno.genero === 'femenino') { %>
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/><path d="M14 2l-2 4 2 4"/></svg>
                <% } else { %>
                  <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/><path d="M16 4l4-2-2 4"/></svg>
                <% } %>
                <%= alumno.genero === 'femenino' ? 'Niña' : 'Niño' %>
              </span>
              <span class="w-1 h-1 bg-slate-300 rounded-full hidden sm:block"></span>
              <span class="text-xs sm:text-sm text-slate-400">Registrado: <%= new Date(alumno.fecha_registro).toLocaleDateString() %></span>
            </div>
          </div>
        </div>
        <a href="/admin/monitoreo"
           class="bg-white hover:bg-slate-50 text-slate-600 font-bold py-2.5 px-5 rounded-xl border border-slate-200 transition-all text-center sm:text-left">
          ← Volver
        </a>
      </div>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4 mb-6 sm:mb-8">
      <div class="bg-white rounded-2xl p-3 sm:p-5 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Nivel</p>
        <p class="text-2xl sm:text-3xl font-bold text-sky-600 flex items-center justify-center gap-1 sm:gap-2">
          <svg class="w-6 h-6 sm:w-8 sm:h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <%= alumno.nivel %>
        </p>
      </div>
      <div class="bg-white rounded-2xl p-3 sm:p-5 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Puntos</p>
        <p class="text-2xl sm:text-3xl font-bold text-amber-600 flex items-center justify-center gap-1 sm:gap-2">
          <svg class="w-6 h-6 sm:w-8 sm:h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <%= alumno.puntos_total %>
        </p>
      </div>
      <div class="bg-white rounded-2xl p-3 sm:p-5 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Actividades</p>
        <p class="text-2xl sm:text-3xl font-bold text-indigo-600"><%= totalActividades %></p>
      </div>
      <div class="bg-white rounded-2xl p-3 sm:p-5 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">% Aciertos</p>
        <p class="text-2xl sm:text-3xl font-bold <%= porcentajeAciertos >= 70 ? 'text-emerald-600' : porcentajeAciertos >= 40 ? 'text-amber-600' : 'text-red-500' %>">
          <%= porcentajeAciertos %>%</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
      <!-- Progreso por Continente -->
      <div class="bg-white rounded-2xl p-4 sm:p-6 soft-shadow border border-slate-100">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Progreso por Continente
        </h2>

        <% if (progreso.length === 0) { %>
          <p class="text-slate-400 text-center py-6">Este alumno aún no ha explorado continentes.</p>
        <% } else { %>
          <div class="space-y-3">
            <% progreso.forEach(function(p) { %>
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-3 rounded-xl bg-slate-50 border border-slate-100 gap-2">
                <div class="flex items-center gap-2 sm:gap-3">
                  <svg class="w-6 h-6 sm:w-7 sm:h-7 text-slate-600 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-800 text-sm sm:text-base truncate"><%= p.nombreContinente %></p>
                    <p class="text-xs text-slate-400">
                      <%= p.puntaje_continente %> pts · <%= p.retos_completados %>/<%= p.retos_totales %> retos
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <div class="w-20 sm:w-24 h-2.5 bg-slate-200 rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-400 rounded-full" style="width: <%= Math.min(100, (p.retos_completados / p.retos_totales) * 100) %>%"></div>
                  </div>
                  <span class="text-xs font-bold text-slate-500"><%= Math.round((p.retos_completados / p.retos_totales) * 100) %>%</span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>

      <!-- Actividades por Tipo -->
      <div class="bg-white rounded-2xl p-4 sm:p-6 soft-shadow border border-slate-100">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
          Actividades por Tipo
        </h2>

        <% if (Object.keys(actividadesPorTipo).length === 0) { %>
          <p class="text-slate-400 text-center py-6">Sin actividades registradas.</p>
        <% } else { %>
          <div class="space-y-3">
            <% var tiposMap = { 'reto': 'Retos', 'trivia': 'Trivia', 'sopa': 'Sopa de Letras', 'memoria': 'Memoria', 'puzzle': 'Puzzle' }; %>
            <% Object.keys(actividadesPorTipo).forEach(function(tipo) { %>
              <div class="flex items-center justify-between p-3 rounded-xl bg-slate-50 border border-slate-100">
                <span class="font-medium text-slate-700"><%= tiposMap[tipo] || tipo %></span>
                <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm font-bold">
                  <%= actividadesPorTipo[tipo] %> veces
                </span>
              </div>
            <% }); %>
          </div>
          <div class="mt-4 p-3 rounded-xl bg-slate-50 border border-slate-100">
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium text-slate-600">Total Respuestas</span>
              <span class="font-bold text-slate-800"><%= totalCorrectas %> / <%= totalRespuestas %> correctas</span>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Historial de Actividad -->
    <div class="bg-white rounded-2xl p-4 sm:p-6 soft-shadow border border-slate-100">
      <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Historial de Actividad
      </h2>

      <% if (historial.length === 0) { %>
        <p class="text-slate-400 text-center py-8">No hay actividad registrada aún.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-slate-200">
                <th class="text-left p-2 sm:p-3 text-xs sm:text-sm font-bold text-slate-600">Fecha</th>
                <th class="text-left p-2 sm:p-3 text-xs sm:text-sm font-bold text-slate-600">Actividad</th>
                <th class="text-center p-2 sm:p-3 text-xs sm:text-sm font-bold text-slate-600">Puntos</th>
                <th class="text-center p-2 sm:p-3 text-xs sm:text-sm font-bold text-slate-600 hidden sm:table-cell">Aciertos</th>
                <th class="text-center p-2 sm:p-3 text-xs sm:text-sm font-bold text-slate-600 hidden sm:table-cell">Tiempo</th>
              </tr>
            </thead>
            <tbody>
              <% historial.forEach(function(h) { %>
                <tr class="border-b border-slate-100 hover:bg-slate-50 transition-all">
                  <td class="p-2 sm:p-3 text-xs sm:text-sm text-slate-500">
                    <%= new Date(h.fecha).toLocaleDateString() %>
                    <br><span class="text-xs text-slate-400"><%= new Date(h.fecha).toLocaleTimeString() %></span>
                  </td>
                  <td class="p-2 sm:p-3">
                    <% var iconosTipo = { 'reto': 'Mundo', 'trivia': 'Bandera', 'sopa': 'Letras', 'memoria': 'Cartas', 'puzzle': 'Piezas' }; %>
                    <span class="font-medium text-slate-700 text-xs sm:text-sm"><%= h.tipo_actividad %></span>
                  </td>
                  <td class="p-2 sm:p-3 text-center font-bold text-xs sm:text-sm <%= h.puntaje_obtenido > 0 ? 'text-amber-600' : 'text-slate-400' %>">
                    <%= h.puntaje_obtenido > 0 ? '+' + h.puntaje_obtenido : '—' %>
                  </td>
                  <td class="p-2 sm:p-3 text-center hidden sm:table-cell">
                    <% if (h.respuestas_totales > 0) { %>
                      <span class="<%= h.respuestas_correctas === h.respuestas_totales ? 'text-emerald-600' : 'text-slate-600' %> font-medium text-xs sm:text-sm">
                        <%= h.respuestas_correctas %>/<%= h.respuestas_totales %>
                      </span>
                    <% } else { %>
                      <span class="text-slate-400">—</span>
                    <% } %>
                  </td>
                  <td class="p-2 sm:p-3 text-center text-xs sm:text-sm text-slate-500 hidden sm:table-cell">
                    <%= h.tiempo_segundos ? h.tiempo_segundos + 's' : '—' %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

  </div>
</div>
</file>

<file path="views/admin/contenido-form.ejs">
<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
        Gestor de Contenido
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">
        <%= pregunta ? 'Editar Pregunta' : 'Nueva Pregunta' %>
      </h1>
      <p class="text-slate-500 mt-1 text-sm sm:text-base">
        <%= pregunta ? 'Modifica los datos de la pregunta personalizada.' : 'Crea una nueva pregunta para tus actividades educativas.' %>
      </p>
    </div>

    <!-- Mensaje de error -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-2xl p-4 mb-6 flex items-center gap-3">
        <svg class="w-6 h-6 text-red-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="font-medium"><%= error %></span>
      </div>
    <% } %>

    <!-- Formulario -->
    <form action="<%= pregunta ? '/admin/contenido/editar/' + pregunta.id : '/admin/contenido/nueva' %>" method="POST"
          class="bg-white rounded-2xl p-4 sm:p-6 lg:p-8 soft-shadow border border-slate-100 space-y-6">

      <!-- Tipo de Pregunta -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Tipo de Pregunta</label>
        <select name="tipo" id="tipoSelect" required
                class="w-full p-3.5 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-lg font-medium"
                onchange="toggleContinente()">
          <% tipos.forEach(function(t) { %>
            <option value="<%= t.valor %>" <%= pregunta && pregunta.tipo === t.valor ? 'selected' : '' %>>
              <%= t.etiqueta %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Continente (solo para tipo 'continente') -->
      <div id="continenteGroup" class="<%= pregunta && pregunta.tipo === 'continente' ? '' : 'hidden' %>">
        <label class="block text-sm font-bold text-slate-700 mb-2">Continente</label>
        <select name="continenteId"
                class="w-full p-3.5 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-lg font-medium">
          <option value="">Seleccionar continente...</option>
          <% continentes.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= pregunta && pregunta.continente_id === c.id ? 'selected' : '' %>>
              <%= c.nombre %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Pregunta -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Pregunta</label>
        <textarea name="pregunta" rows="2" required
                  class="w-full p-3.5 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-lg resize-none"
                  placeholder="Escribe la pregunta aquí..."><%= pregunta ? pregunta.pregunta : '' %></textarea>
      </div>

      <!-- Opciones -->
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-3">Opciones de Respuesta</label>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <% for (var i = 0; i < 4; i++) { %>
            <div class="flex items-center gap-3 p-3 rounded-xl border <%= pregunta && pregunta.respuesta_correcta === i ? 'border-emerald-300 bg-emerald-50/50' : 'border-slate-200' %>">
              <input type="radio" name="respuestaCorrecta" value="<%= i %>" required
                     <%= pregunta && pregunta.respuesta_correcta === i ? 'checked' : i === 0 && !pregunta ? 'checked' : '' %>
                     class="w-5 h-5 text-emerald-500 focus:ring-emerald-400 flex-shrink-0">
              <input type="text" name="opcion<%= i+1 %>" required
                     value="<%= pregunta ? pregunta.opciones[i] : '' %>"
                     placeholder="Opción <%= i+1 %>"
                     class="flex-1 p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all"
                     <%= i === 0 && !pregunta ? 'autofocus' : '' %>>
            </div>
          <% }); %>
        </div>
        <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
          Selecciona el círculo de la opción correcta.
        </p>
      </div>

      <!-- Configuración avanzada -->
      <div class="border-t border-slate-100 pt-6">
        <h3 class="text-lg font-bold text-slate-700 mb-4">Configuración Avanzada</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Puntos</label>
            <input type="number" name="puntos" value="<%= pregunta ? pregunta.puntos : 10 %>" min="1" max="100"
                   class="w-full p-3 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Tiempo Límite (seg)</label>
            <input type="number" name="tiempoLimite" value="<%= pregunta ? pregunta.tiempo_limite : 30 %>" min="5" max="300"
                   class="w-full p-3 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all">
          </div>
          <% if (pregunta) { %>
            <div class="flex items-center gap-2 pt-6">
              <input type="checkbox" name="activa" id="activa" <%= pregunta.activa == 1 ? 'checked' : '' %>
                     class="w-5 h-5 text-indigo-500 focus:ring-indigo-400 rounded">
              <label for="activa" class="text-sm font-medium text-slate-700">Pregunta Activa</label>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Botones -->
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between pt-2 border-t border-slate-100 gap-3">
        <a href="/admin/contenido"
           class="bg-white hover:bg-slate-50 text-slate-600 font-bold py-3 px-6 rounded-xl border border-slate-200 transition-all text-center sm:text-left">
          ← Cancelar
        </a>
        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-xl transition-all soft-shadow flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
