<file path="views/resultado-reto.ejs">
<%- include('partials/confetti') %>

<div class="min-h-screen flex items-center justify-center p-6 py-12 animate-fade-in">
  
  <div class="bg-white rounded-[3rem] shadow-xl p-responsive card-padding-md max-w-2xl w-full border border-slate-100 relative overflow-hidden">
    
    <!-- Resultado -->
    <div class="text-center mb-10">
      <% if (esCorrecta) { %>
        <!-- Respuesta Correcta -->
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-green-100 text-green-600 mb-6 animate-bounce">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle-2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h2 class="text-responsive-5xl font-black text-slate-900 mb-4">
          ¡Excelente!
        </h2>
        <div class="inline-block px-6 py-2 rounded-full bg-green-50 text-green-700 font-bold text-xl border border-green-100 mb-4">
          +<%= puntosGanados %> puntos
          <svg class="w-5 h-5 inline-block align-text-bottom" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
      <% } else { %>
        <!-- Respuesta Incorrecta -->
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-red-100 text-red-600 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-circle"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        </div>
        <h2 class="text-5xl font-black text-slate-900 mb-4">
          ¡Casi lo logras!
        </h2>
        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 mb-4">
          <p class="text-slate-500 font-bold mb-2 uppercase tracking-widest text-xs">La respuesta correcta era:</p>
          <p class="text-2xl font-black text-sky-600"><%= respuestaCorrecta %></p>
        </div>
      <% } %>
    </div>

    <!-- Progreso actualizado -->
    <div class="grid grid-cols-2 gap-responsive gap-4 mb-10">
      <div class="bg-sky-50/60 rounded-2xl p-6 border border-sky-100/60 text-center shadow-sm">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Nivel Actual</p>
        <p class="text-3xl font-black text-sky-600 flex items-center justify-center gap-1">
          <svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <%= progreso.nivel %>
        </p>
      </div>
      <div class="bg-sky-50/60 rounded-2xl p-6 border border-sky-100/60 text-center shadow-sm">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Puntos Totales</p>
        <p class="text-3xl font-black text-sky-600 flex items-center justify-center gap-1">
          <svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <%= progreso.puntosTotal %></p>
      </div>
    </div>

    <!-- Mensaje de nivel -->
    <% if (subisteNivel) { %>
      <div class="bg-gradient-to-br from-amber-400 to-orange-500 rounded-[2rem] p-8 mb-8 text-center text-white shadow-xl animate-pulse">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h4 class="text-3xl font-black mb-1">¡NUEVO NIVEL!</h4>
        <p class="text-xl font-bold opacity-90">
          Has alcanzado el Nivel <%= progreso.nivel %>
        </p>
      </div>
    <% } %>

    <!-- Botones de navegación -->
    <div class="grid gap-4">
      <% if (hayMasPreguntas) { %>
