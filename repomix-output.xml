<file path="views/partials/confetti.ejs">
<!-- Sistema de Confetti - Sin dependencias externas -->
<style>
  .confetti-particle {
    position: fixed;
    pointer-events: none;
    z-index: 10000;
    border-radius: 2px;
  }
  
  @keyframes confettiFall {
    0% { transform: translateY(-10px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
  
  @keyframes confettiSide {
    0% { transform: translateX(0) translateY(-10px) rotate(0deg); opacity: 1; }
    100% { transform: translateX(var(--drift)) translateY(100vh) rotate(720deg); opacity: 0; }
  }
</style>

<script>
  // Colores vibrantes para el confeti
  const CONFETTI_COLORES = [
    '#ff6b6b', '#ffd93d', '#6bcb77', '#4d96ff', '#ff6b9d',
    '#c084fc', '#fb923c', '#34d399', '#38bdf8', '#f472b6',
    '#a78bfa', '#fbbf24', '#60a5fa', '#34d399', '#f87171'
  ];

  /**
   * Lanza confetti en posiciones aleatorias
   * @param {number} cantidad - Numero de particulas (default: 80)
   * @param {boolean} usarEmojis - Incluir emojis entre las particulas (default: false)
   */
  function lanzarConfetti(cantidad, usarEmojis) {
    cantidad = cantidad || 80;
    usarEmojis = usarEmojis || false;
    
    // Explosion central
    for (var i = 0; i < cantidad; i++) {
      crearParticula(
        window.innerWidth / 2 + (Math.random() - 0.5) * 200,
        window.innerHeight / 3 + (Math.random() - 0.5) * 100,
        usarEmojis && Math.random() < 0.2
      );
    }
    
    // Explosiones laterales (extra)
    if (cantidad >= 50) {
      setTimeout(function() {
        for (var i = 0; i < cantidad / 3; i++) {
          crearParticula(
            Math.random() * window.innerWidth,
            Math.random() * window.innerHeight * 0.5,
            usarEmojis && Math.random() < 0.15
          );
        }
      }, 200);
      
      setTimeout(function() {
        for (var i = 0; i < cantidad / 4; i++) {
          crearParticula(
            Math.random() * window.innerWidth,
            Math.random() * window.innerHeight * 0.4,
            usarEmojis && Math.random() < 0.1
          );
        }
      }, 400);
    }
  }

  function crearParticula(x, y, esEmoji) {
    var particula = document.createElement('div');
    var color = CONFETTI_COLORES[Math.floor(Math.random() * CONFETTI_COLORES.length)];
    var size = 6 + Math.random() * 10;
    var duracion = 1.5 + Math.random() * 2;
    var drift = (Math.random() - 0.5) * 300;
    
    particula.className = 'confetti-particle';
    
    if (esEmoji) {
      particula.textContent = '✦';
      particula.style.fontSize = (14 + Math.random() * 20) + 'px';
      particula.style.color = color;
      particula.style.background = 'transparent';
    } else {
      particula.style.width = size + 'px';
      particula.style.height = size + 'px';
      particula.style.background = color;
      particula.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      particula.style.boxShadow = '0 0 6px ' + color + '80';
    }
    
    particula.style.left = x + 'px';
    particula.style.top = y + 'px';
    particula.style.setProperty('--drift', drift + 'px');
    particula.style.animation = 'confettiSide ' + duracion + 's cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards';
    particula.style.transform = 'rotate(' + (Math.random() * 360) + 'deg)';
    
    document.body.appendChild(particula);
    
    // Limpiar despues de la animacion
    setTimeout(function() {
      if (particula.parentNode) {
        particula.parentNode.removeChild(particula);
      }
    }, duracion * 1000 + 500);
  }

  /**
   * Lanza fuegos artificiales (confetti en rafagas)
   * @param {number} rondas - Numero de rondas (default: 3)
   */
  function lanzarFuegosArtificiales(rondas) {
    rondas = rondas || 3;
    for (var r = 0; r < rondas; r++) {
      setTimeout(function() {
        var cantidad = 30 + Math.floor(Math.random() * 40);
        for (var i = 0; i < cantidad; i++) {
          crearParticula(
            Math.random() * window.innerWidth,
            Math.random() * window.innerHeight * 0.6,
            Math.random() < 0.25
          );
        }
      }, r * 600);
    }
  }
</script>
</file>

<file path="views/partials/cronometro.ejs">
<!-- Cronómetro Visual: Timer circular + barra de progreso -->
<div id="cronometro-container" class="mb-6" style="display: none;">
  <div class="flex items-center justify-center gap-8">
    <!-- Círculo del cronómetro -->
    <div class="relative w-24 h-24 flex-shrink-0" id="timer-circle">
      <svg class="w-24 h-24 -rotate-90" viewBox="0 0 100 100">
        <!-- Círculo de fondo -->
        <circle cx="50" cy="50" r="42" fill="none" stroke="#e2e8f0" stroke-width="8"/>
        <!-- Círculo de progreso -->
        <circle cx="50" cy="50" r="42" fill="none" stroke="#3b82f6" stroke-width="8" 
                stroke-linecap="round" stroke-dasharray="263.89" stroke-dashoffset="0"
                id="timer-progress"/>
      </svg>
      <div class="absolute inset-0 flex items-center justify-center">
        <span id="timer-texto" class="text-3xl font-black text-slate-800">30</span>
      </div>
    </div>

    <!-- Barra de progreso horizontal -->
    <div class="flex-1">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-bold text-slate-500 uppercase tracking-wider">Tiempo restante</span>
        <span id="timer-bar-texto" class="text-sm font-bold text-slate-600">30s</span>
      </div>
      <div class="w-full h-3 bg-slate-100 rounded-full overflow-hidden">
        <div id="timer-barra" class="h-full rounded-full transition-all duration-300 ease-linear" 
             style="width: 100%; background: linear-gradient(90deg, #3b82f6, #60a5fa);"></div>
      </div>
    </div>
  </div>
</div>

<style>
  #timer-circle {
    filter: drop-shadow(0 4px 6px -1px rgba(0,0,0,0.1));
  }
  
  /* Animación de pulso cuando está por acabarse */
  @keyframes timerPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  
  .timer-critical #timer-texto {
    animation: timerPulse 0.8s ease-in-out infinite;
  }
  
  /* Transición suave del color */
  #timer-barra {
    transition: width 0.3s ease-linear, background 0.5s ease;
  }
  
  #timer-progress {
    transition: stroke-dashoffset 0.3s ease-linear, stroke 0.5s ease;
  }
</style>

<script>
  // Variables del cronómetro
  let tiempoRestante = <%= typeof tiempoLimite !== 'undefined' ? tiempoLimite : 30 %>;
  let tiempoTotal = tiempoRestante;
  let intervalo = null;
  let cronometroActivo = false;
  const CIRCUNFERENCIA = 263.89; // 2 * PI * 42

  // Inicializar cronómetro (llamado por el modal)
  function iniciarCronometro() {
    if (cronometroActivo) return;
    cronometroActivo = true;
    
    const container = document.getElementById('cronometro-container');
    const texto = document.getElementById('timer-texto');
    const barra = document.getElementById('timer-barra');
    const barraTexto = document.getElementById('timer-bar-texto');
    const progress = document.getElementById('timer-progress');
    
    if (container) container.style.display = 'block';
    
    actualizarDisplay(texto, barra, barraTexto, progress);
    
    intervalo = setInterval(function() {
      tiempoRestante--;
      actualizarDisplay(texto, barra, barraTexto, progress);
      
      if (tiempoRestante <= 0) {
        clearInterval(intervalo);
        cronometroActivo = false;
        // Sonido de tiempo agotado
        if (typeof SonidosMundoKids !== 'undefined') {
          SonidosMundoKids.tiempoAgotado();
        }
        // Auto-enviar formulario
        const form = document.getElementById('form-actividad');
        if (form) {
          form.submit();
        }
      }
    }, 1000);
  }

  function actualizarDisplay(texto, barra, barraTexto, progress) {
    const porcentaje = (tiempoRestante / tiempoTotal) * 100;
    const circle = document.getElementById('timer-circle');
    
    // Actualizar números
    texto.textContent = tiempoRestante;
    if (barraTexto) barraTexto.textContent = tiempoRestante + 's';
    
    // Actualizar barra
    if (barra) barra.style.width = porcentaje + '%';
    
    // Actualizar círculo SVG
    if (progress) {
      const offset = CIRCUNFERENCIA - (CIRCUNFERENCIA * tiempoRestante / tiempoTotal);
      progress.style.strokeDashoffset = offset;
    }
    
    // Cambiar colores según tiempo restante
    if (circle) {
      circle.classList.remove('timer-critical');
    }
    
    if (porcentaje <= 25) {
      // Rojo - crítico
      if (barra) barra.style.background = 'linear-gradient(90deg, #ef4444, #f87171)';
      if (progress) progress.style.stroke = '#ef4444';
      if (texto) texto.className = 'text-3xl font-black text-red-600';
      if (circle) circle.classList.add('timer-critical');
    } else if (porcentaje <= 50) {
      // Amarillo - advertencia
      if (barra) barra.style.background = 'linear-gradient(90deg, #f59e0b, #fbbf24)';
      if (progress) progress.style.stroke = '#f59e0b';
      if (texto) texto.className = 'text-3xl font-black text-amber-600';
    } else {
      // Azul - normal
      if (barra) barra.style.background = 'linear-gradient(90deg, #3b82f6, #60a5fa)';
      if (progress) progress.style.stroke = '#3b82f6';
      if (texto) texto.className = 'text-3xl font-black text-slate-800';
    }
  }

  // Función para detener el cronómetro (cuando se responde)
  function detenerCronometro() {
    if (intervalo) {
      clearInterval(intervalo);
      intervalo = null;
    }
    cronometroActivo = false;
  }

  // Limpiar al cambiar de página
  window.addEventListener('beforeunload', function() {
    if (intervalo) clearInterval(intervalo);
  });
</script>
</file>

<file path="views/partials/iconos.ejs">
<!-- Sistema de Iconos SVG Profesionales -->
<!-- Incluir en layout.ejs para disponer de icono() en todas las vistas -->
<script src="/js/iconos.js"></script>
<script>
window.icono = function(nombre, clase) {
  var svg = ICONOS[nombre] || '';
  if (!svg) return '<span class="' + (clase || '') + '"></span>';
  if (clase) svg = svg.replace('<svg ', '<svg class="' + clase + '" ');
  return svg;
};

// Auto-render: reemplaza <span class="icono-render" data-icono="trofeo">
// con el SVG real de ICONOS al cargar la página
// Soporta: data-icono (nombre del icono), data-clases (clases CSS), data-titulo (tooltip accesible)
function renderizarIconos() {
  document.querySelectorAll('.icono-render').forEach(function(el) {
    var nombre = el.getAttribute('data-icono');
    var clases = el.getAttribute('data-clases') || '';
    var titulo = el.getAttribute('data-titulo');
    if (nombre && ICONOS[nombre]) {
      var svg = window.icono(nombre, clases);
      // Si hay data-titulo, inyectar elemento <title> para accesibilidad
      if (titulo && svg.indexOf('<svg ') === 0) {
        svg = svg.replace('<svg ', '<svg role="img" aria-label="' + titulo.replace(/"/g, '&quot;') + '" ');
        svg = svg.replace('>', '><title>' + titulo.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</title>');
      }
      el.outerHTML = svg;
    }
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', renderizarIconos);
} else {
  renderizarIconos();
}
</script>
</file>

<file path="views/partials/modal-atencion.ejs">
<!-- Modal de Atención: Aparece antes de iniciar trivias/retos -->
<div id="modal-atencion" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display: none;">
  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="cerrarAtencion()"></div>
  
  <!-- Contenido del modal -->
  <div class="relative bg-white rounded-[2.5rem] shadow-2xl max-w-lg w-full p-10 text-center animate-modal-bounce border border-slate-100" id="modal-contenido">
    <!-- Icono de alerta -->
    <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6 animate-pulse-soft">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </div>
    
    <h2 class="text-3xl font-extrabold text-slate-900 mb-3"><%- icono('reloj', 'w-6 h-6 inline text-amber-600') %> Atencion!</h2>
    
    <div class="bg-amber-50 rounded-2xl p-6 mb-6 border border-amber-100">
      <p class="text-lg font-bold text-amber-800 mb-2">
        Esta actividad tiene un <span class="underline decoration-wavy decoration-amber-400">limite de tiempo</span>
      </p>
      <p class="text-amber-700">
        Debes responder cada pregunta dentro del tiempo establecido. 
        Si el tiempo se agota, la respuesta se enviara automaticamente.
      </p>
    </div>
    
    <div class="flex items-center gap-3 bg-sky-50 rounded-xl p-4 mb-8 border border-sky-100">
      <%- icono('luz', 'w-7 h-7 text-sky-600 shrink-0') %>
      <p class="text-sky-700 text-sm font-medium">
        Lee bien cada pregunta antes de responder. Concentrate y da lo mejor de ti!
      </p>
    </div>
    
    <button onclick="iniciarActividad()" 
            class="w-full py-4 px-8 bg-gradient-to-r from-sky-500 to-blue-600 text-white font-bold text-xl rounded-2xl hover:from-sky-600 hover:to-blue-700 transform hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 shadow-lg hover:shadow-xl flex items-center justify-center gap-3">
      <%- icono('jugar', 'w-5 h-5') %>
      Comenzar Ahora!
    </button>
  </div>
</div>

<style>
  @keyframes modalBounceIn {
    0% { opacity: 0; transform: scale(0.7) translateY(40px); }
    60% { transform: scale(1.03) translateY(-4px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-modal-bounce {
    animation: modalBounceIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes pulseSoft {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
  .animate-pulse-soft {
    animation: pulseSoft 2s ease-in-out infinite;
  }
</style>

<script>
  // Funcion global para mostrar el modal
  function mostrarAtencion() {
    const modal = document.getElementById('modal-atencion');
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  }

  // Funcion para cerrar el modal (sin iniciar)
  function cerrarAtencion() {
    const modal = document.getElementById('modal-atencion');
    if (modal) {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  // Funcion para iniciar la actividad (se sobreescribe en cada pagina)
  function iniciarActividad() {
    cerrarAtencion();
    const contenido = document.getElementById('contenido-actividad');
    if (contenido) {
      contenido.style.display = 'block';
      contenido.classList.add('animate-fade-in');
    }
    if (typeof iniciarCronometro === 'function') {
      iniciarCronometro();
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const estadoActividad = sessionStorage.getItem('actividad_iniciada');
    if (!estadoActividad) {
      setTimeout(mostrarAtencion, 300);
    } else {
      const contenido = document.getElementById('contenido-actividad');
      if (contenido) contenido.style.display = 'block';
    }
  });

  function marcarIniciada() {
    sessionStorage.setItem('actividad_iniciada', 'true');
  }

  document.addEventListener('DOMContentLoaded', function() {
    const btnComenzar = document.querySelector('#modal-contenido button');
    if (btnComenzar) {
      btnComenzar.addEventListener('click', marcarIniciada);
    }
  });
</script>
</file>

