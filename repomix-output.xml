           class="flex items-center justify-center gap-3 w-full bg-white/40 hover:bg-red-50 hover:text-red-600 text-slate-600 font-bold py-4 rounded-2xl transition-all border border-transparent hover:border-red-100 soft-shadow">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
          Cerrar Sesión
        </a>
      </div>

      <!-- Columna Derecha: Opciones -->
      <div class="space-y-6">
        <a href="/continentes" 
           class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-white/60 hover:border-sky-200 transition-all hover:-translate-y-1">
          <div class="flex flex-col gap-4">
            <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center text-teal-600 group-hover:bg-teal-500 group-hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-800 mb-2">Estudiar Continentes</h3>
              <p class="text-slate-500">Aprende sobre la cultura y geografía del mundo.</p>
            </div>
          </div>
        </a>

        <a href="/trivia-banderas" 
           class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-white/60 hover:border-orange-200 transition-all hover:-translate-y-1">
          <div class="flex flex-col gap-4">
            <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center text-orange-600 group-hover:bg-orange-500 group-hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="12" y2="12"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="15" x2="15.01" y1="13" y2="13"/><line x1="18" x2="18.01" y1="11" y2="11"/><rect width="20" height="12" x="2" y="6" rx="2"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-800 mb-2">Trivia de Banderas</h3>
              <p class="text-slate-500">¿Qué tan bien conoces las banderas del mundo?</p>
            </div>
          </div>
        </a>

        <!-- Minijuego: Sopa de Letras -->
        <a href="/sopa-letras"
           class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-white/60 hover:border-teal-300 transition-all hover:-translate-y-1">
          <div class="flex flex-col gap-4">
            <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center text-teal-600 group-hover:bg-teal-500 group-hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-800 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                Sopa de Letras
              </h3>
              <p class="text-slate-500">Encuentra palabras geográficas escondidas en la cuadrícula.</p>
            </div>
          </div>
        </a>

        <!-- Minijuego: Memoria -->
        <a href="/memoria"
           class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-white/60 hover:border-purple-300 transition-all hover:-translate-y-1">
          <div class="flex flex-col gap-4">
            <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center text-purple-600 group-hover:bg-purple-500 group-hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-800 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                Juego de Memoria
              </h3>
              <p class="text-slate-500">Encuentra los pares de países y banderas del mundo.</p>
            </div>
          </div>
        </a>

        <!-- Minijuego: Puzzle / Rompecabezas -->
        <a href="/puzzle"
           class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-white/60 hover:border-amber-300 transition-all hover:-translate-y-1">
          <div class="flex flex-col gap-4">
            <div class="w-16 h-16 bg-amber-100 rounded-2xl flex items-center justify-center text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19.439 7.85c0-1.57.551-2.483 1.45-3.045l.333-.208-1.222-1.222-.208.333c-.562.899-1.475 1.45-3.045 1.45a2.986 2.986 0 0 1-2.951-2.478l-.07-.48H12.2l-.07.48A2.986 2.986 0 0 1 9.179 4.808c-1.57 0-2.483-.551-3.045-1.45l-.208-.333-1.222 1.222.333.208c.899.562 1.45 1.475 1.45 3.045a2.986 2.986 0 0 1-2.478 2.951l-.48.07V12.2l.48.07A2.986 2.986 0 0 1 4.808 15.179c0 1.57.551 2.483 1.45 3.045l.333.208 1.222 1.222.208-.333c.562-.899 1.475-1.45 3.045-1.45a2.986 2.986 0 0 1 2.951 2.478l.07.48H12.2l.07-.48a2.986 2.986 0 0 1 2.951-2.478c1.57 0 2.483.551 3.045 1.45l.208.333 1.222-1.222-.333-.208c-.899-.562-1.45-1.475-1.45-3.045a2.986 2.986 0 0 1 2.478-2.951l.48-.07V9.179l-.48-.07a2.986 2.986 0 0 1-2.478-2.951Z"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-800 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><path d="M19.439 7.85c0-1.57.551-2.483 1.45-3.045l.333-.208-1.222-1.222-.208.333c-.562.899-1.475 1.45-3.045 1.45a2.986 2.986 0 0 1-2.951-2.478l-.07-.48H12.2l-.07.48A2.986 2.986 0 0 1 9.179 4.808c-1.57 0-2.483-.551-3.045-1.45l-.208-.333-1.222 1.222.333.208c.899.562 1.45 1.475 1.45 3.045a2.986 2.986 0 0 1-2.478 2.951l-.48.07V12.2l.48.07A2.986 2.986 0 0 1 4.808 15.179c0 1.57.551 2.483 1.45 3.045l.333.208 1.222 1.222.208-.333c.562-.899 1.475-1.45 3.045-1.45a2.986 2.986 0 0 1 2.951 2.478l.07.48H12.2l.07-.48a2.986 2.986 0 0 1 2.951-2.478c1.57 0 2.483.551 3.045 1.45l.208.333 1.222-1.222-.333-.208c-.899-.562-1.45-1.475-1.45-3.045a2.986 2.986 0 0 1 2.478-2.951l.48-.07V9.179l-.48-.07a2.986 2.986 0 0 1-2.478-2.951Z"/></svg>
                Rompecabezas
              </h3>
              <p class="text-slate-500">Ordena las piezas para formar la imagen geográfica.</p>
            </div>
          </div>
        </a>

        <!-- Panel del Profesor (solo visible para profesores) -->
        <% if (typeof usuario !== 'undefined' && usuario && usuario.rol === 'profesor') { %>
          <a href="/admin"
             class="group block glass-effect p-8 rounded-[2rem] soft-shadow border border-indigo-200 hover:border-indigo-400 transition-all hover:-translate-y-1 bg-indigo-50/70">
            <div class="flex flex-col gap-4">
              <div class="w-16 h-16 bg-indigo-100 rounded-2xl flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
