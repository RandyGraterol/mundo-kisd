          <div class="flex gap-3">
            <a href="/logros"
               class="flex-1 flex items-center justify-center gap-2 bg-white/40 hover:bg-purple-50 hover:text-purple-600 text-slate-600 font-bold py-4 rounded-2xl transition-all border border-transparent hover:border-purple-100 soft-shadow">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
