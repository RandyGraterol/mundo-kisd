        <% if (alumnosRecientes.length === 0) { %>
          <div class="bg-white rounded-2xl p-8 soft-shadow border border-slate-100 text-center">
            <p class="text-slate-400 text-lg">No hay alumnos registrados aún.</p>
            <p class="text-slate-300 text-sm mt-1">¡Invita a tus alumnos a registrarse!</p>
          </div>
        <% } else { %>
          <div class="space-y-2">
            <% alumnosRecientes.forEach(function(alumno) { %>
              <a href="/admin/monitoreo/<%= alumno.id %>"
                 class="flex items-center justify-between bg-white rounded-xl p-4 soft-shadow border border-slate-100 hover:border-sky-200 transition-all">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 <%= alumno.genero === 'femenino' ? 'bg-pink-100 text-pink-600' : 'bg-blue-100 text-blue-600' %> rounded-full flex items-center justify-center font-bold text-lg">
                    <%= alumno.nombre_completo.charAt(0).toUpperCase() %>
                  </div>
                  <div>
                    <p class="font-semibold text-slate-800"><%= alumno.nombre_completo %></p>
                    <p class="text-xs text-slate-400">⭐ Nivel <%= alumno.nivel %> · <%= alumno.puntos_total %> pts</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-xs text-slate-400">
                    Último acceso: <%= new Date(alumno.ultimo_acceso).toLocaleDateString() %>
                  </p>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Configuraciones de Temporizador -->
    <div class="mt-6">
      <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Configuración de Tiempos Actual
      </h2>

      <div class="bg-white rounded-2xl p-6 soft-shadow border border-slate-100">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <% configs.forEach(function(config) { %>
            <div class="<%= config.activo ? 'bg-indigo-50 border-indigo-200' : 'bg-slate-50 border-slate-200' %> rounded-xl p-4 border text-center">
              <p class="text-sm font-medium text-slate-500">Niveles <%= config.nivel_desde %>-<%= config.nivel_hasta %></p>
              <p class="text-2xl font-bold <%= config.activo ? 'text-indigo-600' : 'text-slate-400' %> mt-1"><%= config.tiempo_segundos %>s</p>
              <% if (!config.activo) { %><span class="text-xs text-slate-400">Inactivo</span><% } %>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div>
</div>
</file>

<file path="views/admin/monitoreo.ejs">
<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Monitoreo
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">Mis Alumnos</h1>
      <p class="text-slate-500 mt-1 text-sm sm:text-base">Supervisa el progreso y rendimiento de todos tus alumnos.</p>
    </div>

    <!-- Resumen rápido -->
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4 mb-6">
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Total Alumnos</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-900"><%= alumnos.length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Activos</p>
        <p class="text-xl sm:text-2xl font-bold text-emerald-600"><%= alumnos.filter(a => a.esActivo).length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Inactivos (>7 días)</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-400"><%= alumnos.filter(a => !a.esActivo).length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Mejor Puntaje</p>
        <p class="text-xl sm:text-2xl font-bold text-amber-600">
          <%= alumnos.length > 0 ? Math.max(...alumnos.map(a => a.puntos_total)) : 0 %>
        </p>
      </div>
    </div>

    <!-- Buscador -->
    <div class="bg-white rounded-2xl p-4 soft-shadow border border-slate-100 mb-6">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="buscador" onkeyup="buscarAlumno()" placeholder="Buscar alumno..."
               class="flex-1 p-2 bg-transparent border-none text-slate-800 placeholder-slate-400 focus:outline-none text-base sm:text-lg">
      </div>
    </div>

    <% if (alumnos.length === 0) { %>
      <div class="bg-white rounded-2xl p-6 sm:p-12 soft-shadow border border-slate-100 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-emerald-100 text-emerald-600 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-700 mb-2">No hay alumnos registrados</h3>
        <p class="text-slate-400">Los alumnos aparecerán aquí cuando se registren en la plataforma.</p>
      </div>
    <% } else { %>
      <!-- Tabla de Alumnos -->
      <div class="bg-white rounded-2xl overflow-hidden soft-shadow border border-slate-100">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left p-3 sm:p-4 text-sm font-bold text-slate-600">Alumno</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden sm:table-cell">Nivel</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600">Puntos</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden sm:table-cell">Retos</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600">Estado</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden md:table-cell">Último Acceso</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600"></th>
              </tr>
            </thead>
            <tbody>
              <% alumnos.forEach(function(alumno) { %>
                <tr class="alumno-row border-b border-slate-100 hover:bg-slate-50 transition-all"
                    data-nombre="<%= alumno.nombre_completo.toLowerCase() %>">
                  <td class="p-3 sm:p-4">
                    <div class="flex items-center gap-2 sm:gap-3">
                      <div class="w-9 h-9 sm:w-10 sm:h-10 <%= alumno.genero === 'femenino' ? 'bg-pink-100 text-pink-600' : 'bg-blue-100 text-blue-600' %> rounded-full flex items-center justify-center font-bold text-base sm:text-lg flex-shrink-0">
                        <%= alumno.nombre_completo.charAt(0).toUpperCase() %>
                      </div>
                      <div class="min-w-0">
                        <p class="font-bold text-slate-800 text-sm sm:text-base truncate"><%= alumno.nombre_completo %></p>
                        <p class="text-xs text-slate-400 truncate">@<%= alumno.nombre_usuario %></p>
                      </div>
                    </div>
                  </td>
                  <td class="p-3 sm:p-4 text-center hidden sm:table-cell">
                    <span class="inline-flex items-center gap-1 bg-sky-100 text-sky-700 px-2.5 sm:px-3 py-1 rounded-full text-xs sm:text-sm font-bold">
                      <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                      <%= alumno.nivel %>
                    </span>
                  </td>
                  <td class="p-3 sm:p-4 text-center font-bold text-base sm:text-lg text-slate-800 items-center justify-center gap-1">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5 inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <%= alumno.puntos_total %>
                  </td>
                  <td class="p-3 sm:p-4 text-center hidden sm:table-cell">
                    <span class="text-slate-600 font-medium text-sm"><%= alumno.totalRetos %></span>
                  </td>
                  <td class="p-3 sm:p-4 text-center">
                    <% if (alumno.esActivo) { %>
                      <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-2 sm:px-3 py-1 rounded-full text-xs font-bold">
                        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-emerald-500 rounded-full"></span>
                        <span class="hidden sm:inline">Activo</span>
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 px-2 sm:px-3 py-1 rounded-full text-xs font-bold">
                        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-slate-400 rounded-full"></span>
                        <span class="hidden sm:inline">Inactivo</span>
                      </span>
                    <% } %>
                  </td>
                  <td class="p-3 sm:p-4 text-center text-sm text-slate-500 hidden md:table-cell">
                    <%= new Date(alumno.ultimo_acceso).toLocaleDateString() %>
                  </td>
                  <td class="p-3 sm:p-4 text-center">
                    <a href="/admin/monitoreo/<%= alumno.id %>"
                       class="inline-flex items-center gap-1 bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition-all">
                      <span class="hidden sm:inline">Ver Detalle</span>
                      <svg class="sm:hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      <svg class="hidden sm:block" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>
</div>

<script>
function buscarAlumno() {
  var query = document.getElementById('buscador').value.toLowerCase();
  document.querySelectorAll('.alumno-row').forEach(function(row) {
    var nombre = row.dataset.nombre;
    row.style.display = nombre.includes(query) ? '' : 'none';
  });
}
</script>
</file>

<file path="views/admin/temporizador.ejs">
<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Configuración
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">Temporizador</h1>
      <p class="text-slate-500 mt-1 text-sm sm:text-base">Define los tiempos de respuesta para cada rango de niveles.</p>
    </div>

    <!-- Mensajes -->
    <% if (typeof exito !== 'undefined' && exito) { %>
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-2xl p-4 mb-6 flex items-center gap-3 soft-shadow">
        <svg class="w-6 h-6 text-emerald-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-medium"><%= exito %></span>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-2xl p-4 mb-6 flex items-center gap-3">
        <svg class="w-6 h-6 text-red-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="font-medium"><%= error %></span>
      </div>
    <% } %>

    <!-- Formulario -->
    <form action="/admin/temporizador" method="POST"
          class="bg-white rounded-2xl p-4 sm:p-6 lg:p-8 soft-shadow border border-slate-100 space-y-6">

      <!-- Configuraciones Existentes -->
      <div class="space-y-4">
        <h2 class="text-lg font-bold text-slate-700">Configuraciones Actuales</h2>

        <% if (configs.length === 0) { %>
          <div class="text-center py-8 text-slate-400">
            <p class="text-lg">No hay configuraciones de temporizador.</p>
            <p class="text-sm">Agrega una nueva configuración abajo.</p>
          </div>
        <% } else { %>
          <% configs.forEach(function(config, index) { %>
            <div class="flex flex-wrap items-end gap-4 p-5 rounded-xl border <%= config.activo ? 'border-slate-200' : 'border-red-200 bg-red-50/30' %>">
              <input type="hidden" name="configs[<%= index %>][id]" value="<%= config.id %>">

              <div class="flex-1 min-w-[100px]">
                <label class="block text-xs font-bold text-slate-600 mb-1.5">Desde Nivel</label>
                <input type="number" name="configs[<%= index %>][nivel_desde]" value="<%= config.nivel_desde %>" min="1"
                       class="w-full p-3 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
              </div>
              <div class="flex-1 min-w-[100px]">
                <label class="block text-xs font-bold text-slate-600 mb-1.5">Hasta Nivel</label>
                <input type="number" name="configs[<%= index %>][nivel_hasta]" value="<%= config.nivel_hasta %>" min="1"
                       class="w-full p-3 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
              </div>
              <div class="flex-1 min-w-[100px]">
                <label class="block text-xs font-bold text-slate-600 mb-1.5">Tiempo (segundos)</label>
                <input type="number" name="configs[<%= index %>][tiempo_segundos]" value="<%= config.tiempo_segundos %>" min="5" max="300"
                       class="w-full p-3 rounded-xl border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
              </div>
              <div class="flex items-center gap-2 pb-2">
                <input type="checkbox" name="configs[<%= index %>][activo]" id="activo_<%= index %>"
                       <%= config.activo ? 'checked' : '' %>
                       class="w-5 h-5 text-amber-500 focus:ring-amber-400 rounded">
                <label for="activo_<%= index %>" class="text-sm font-medium text-slate-600 cursor-pointer">Activo</label>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- Nueva Configuración -->
      <div class="border-t border-slate-100 pt-6">
        <h2 class="text-lg font-bold text-slate-700 mb-4">Agregar Nueva Configuración</h2>
        <div class="flex flex-wrap items-end gap-4 p-5 rounded-xl border border-dashed border-amber-300 bg-amber-50/30">
          <div class="flex-1 min-w-[100px]">
            <label class="block text-xs font-bold text-slate-600 mb-1.5">Desde Nivel</label>
            <input type="number" name="nueva_nivel_desde" min="1" placeholder="1"
                   class="w-full p-3 rounded-xl border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
          </div>
          <div class="flex-1 min-w-[100px]">
            <label class="block text-xs font-bold text-slate-600 mb-1.5">Hasta Nivel</label>
            <input type="number" name="nueva_nivel_hasta" min="1" placeholder="99"
                   class="w-full p-3 rounded-xl border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
          </div>
          <div class="flex-1 min-w-[100px]">
            <label class="block text-xs font-bold text-slate-600 mb-1.5">Tiempo (segundos)</label>
            <input type="number" name="nueva_tiempo_segundos" min="5" max="300" placeholder="30"
                   class="w-full p-3 rounded-xl border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all">
          </div>
        </div>
      </div>

      <!-- Botones -->
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between pt-2 border-t border-slate-100 gap-3">
        <a href="/admin"
           class="bg-white hover:bg-slate-50 text-slate-600 font-bold py-3 px-6 rounded-xl border border-slate-200 transition-all text-center sm:text-left">
          ← Volver al Dashboard
        </a>
        <button type="submit"
                class="bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-8 rounded-xl transition-all soft-shadow flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar Configuración
        </button>
      </div>
    </form>

    <!-- Vista previa de tiempos -->
    <div class="mt-6 bg-white rounded-2xl p-4 sm:p-6 soft-shadow border border-slate-100">
      <h3 class="text-md font-bold text-slate-700 mb-4">Vista previa de tiempos por nivel</h3>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2 sm:gap-3">
        <% if (configs.length > 0) { %>
          <% for (var nivel = 1; nivel <= 12; nivel++) { %>
            <% 
              var configMatch = null;
              for (var ci = 0; ci < configs.length; ci++) {
                if (configs[ci].activo && nivel >= configs[ci].nivel_desde && nivel <= configs[ci].nivel_hasta) {
                  configMatch = configs[ci];
                  break;
                }
              }
            %>
            <div class="p-3 rounded-xl text-center <%= configMatch ? 'bg-indigo-50 border border-indigo-200' : 'bg-slate-50 border border-slate-200' %>">
              <p class="text-xs font-medium text-slate-500">Nivel <%= nivel %></p>
              <p class="text-xl font-bold <%= configMatch ? 'text-indigo-600' : 'text-slate-300' %>">
                <%= configMatch ? configMatch.tiempo_segundos + 's' : '—' %>
              </p>
            </div>
          <% } %>
        <% } else { %>
          <p class="text-slate-400 col-span-full text-center py-4">No hay configuraciones para mostrar.</p>
        <% } %>
      </div>
    </div>

  </div>
</div>
</file>

<file path="views/auth/login.ejs">
<%- include('../partials/header') %>

<div class="min-h-screen bg-white flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <!-- Logo y título -->
    <div class="text-center mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 text-blue-500"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <h1 class="text-responsive-3xl font-bold text-gray-800 mb-2">¡Bienvenido de vuelta!</h1>
      <p class="text-gray-500">Ingresa con tu usuario y contraseña</p>
    </div>

    <!-- Formulario -->
