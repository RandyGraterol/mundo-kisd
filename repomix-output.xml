        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10Z"/><path d="M9 9h6"/><path d="M12 6v6"/></svg>
        <h2 class="text-2xl font-bold text-slate-800">
          ¡Hola, <span class="text-sky-600"><%= nombreUsuario %></span>!
        </h2>
      </div>
      <h1 class="text-responsive-5xl font-extrabold text-slate-900 tracking-tight">¿Qué aventura eliges hoy?</h1>
    </div>

    <div class="grid md:grid-cols-2 gap-responsive gap-8">
      <!-- Columna Izquierda: Progreso -->
      <div class="space-y-6">
        <div class="glass-effect rounded-[2rem] p-8 soft-shadow border border-white/60">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2 bg-sky-100 rounded-lg text-sky-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
            </div>
            <h3 class="text-responsive-2xl font-bold text-slate-800">Tu Progreso</h3>
          </div>
          
          <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40">
              <span class="text-slate-600 font-medium">Nivel Actual</span>
              <span class="text-2xl font-bold text-sky-600 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
                <%= progreso.nivel %>
              </span>
            </div>
            <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40">
              <span class="text-slate-600 font-medium">Puntos Totales</span>
              <span class="text-2xl font-bold text-sky-600 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <%= progreso.puntosTotal %>
              </span>
            </div>
            <div class="flex items-center justify-between p-4 bg-white/50 rounded-2xl border border-white/40">
              <span class="text-slate-600 font-medium">Continentes</span>
              <span class="text-2xl font-bold text-sky-600 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
