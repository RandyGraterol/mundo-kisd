              </span>
            </div>
          </div>
        </div>

        <!-- Enlaces de perfil y logros (solo usuarios con BD) -->
        <% if (typeof usuario !== 'undefined' && usuario) { %>
          <a href="/perfil"
             class="flex items-center justify-center gap-3 w-full bg-white/40 hover:bg-sky-50 hover:text-sky-600 text-slate-600 font-bold py-4 rounded-2xl transition-all border border-transparent hover:border-sky-100 soft-shadow">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
