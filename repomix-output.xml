               class="flex-1 flex items-center justify-center gap-2 bg-white/40 hover:bg-amber-50 hover:text-amber-600 text-slate-600 font-bold py-4 rounded-2xl transition-all border border-transparent hover:border-amber-100 soft-shadow">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
              Ranking
            </a>
          </div>
        <% } %>

        <!-- Botón Salir -->
