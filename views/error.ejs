<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mundo Kids - Error</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', 'Trebuchet MS', sans-serif;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 min-h-screen flex items-center justify-center p-4">
  
  <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-md w-full border-4 border-red-400 text-center">
    
    <!-- Emoji de error -->
    <div class="text-8xl mb-4">😅</div>
    
    <!-- Mensaje de error -->
    <h2 class="text-3xl font-bold text-red-500 mb-4">
      ¡Ups!
    </h2>
    
    <p class="text-gray-700 text-lg mb-6">
      <%= mensaje || 'Parece que algo salió mal. Intenta de nuevo.' %>
    </p>

    <!-- Botón para volver -->
    <a href="/" 
       class="inline-block bg-cyan-500 hover:bg-cyan-600 text-white font-bold text-xl py-4 px-8 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105">
      🏠 Volver al Inicio
    </a>

  </div>

</body>
</html>
