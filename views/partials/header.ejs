<!-- Header común para todas las páginas -->
<header class="text-center py-4">
  <div class="flex items-center justify-center gap-3">
    <%- icono('continentes', 'w-10 h-10 text-sky-500') %>
    <h1 class="text-3xl sm:text-4xl font-bold text-cyan-400">Mundo Kids</h1>
  </div>
  <% if (typeof nombreUsuario !== 'undefined' && nombreUsuario) { %>
    <p class="text-white text-lg mt-2">¡Hola, <%= nombreUsuario %>! <%- icono('saludo', 'w-5 h-5 inline') %></p>
  <% } %>
</header>
