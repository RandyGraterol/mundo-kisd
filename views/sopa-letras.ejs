<%- include('partials/confetti') %>

<div class="min-h-screen flex items-center justify-center p-responsive-main animate-fade-in">
  
  <div class="bg-white rounded-[3rem] shadow-xl p-responsive card-padding-md max-w-4xl w-full border border-slate-100 md:rounded-[3.5rem]">

    <!-- Encabezado -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-3 bg-teal-50 backdrop-blur-md px-6 py-2 rounded-full border border-teal-100 shadow-sm mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-600"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <h2 class="text-xl font-bold text-slate-800">Sopa de Letras</h2>
      </div>
      <h1 class="text-responsive-4xl font-extrabold text-slate-900 tracking-tight">Encuentra las palabras escondidas</h1>
    </div>

    <% if (juego) { %>
      <!-- Juego activo -->
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-responsive gap-responsive-desk-lg">
        <!-- Cuadrícula -->
        <div class="md:col-span-2 lg:col-span-2">
          <div class="bg-slate-50 rounded-2xl p-4 sm:p-6 border border-slate-100 shadow-sm">
            <div id="sopa-grid" 
                 class="grid gap-1 mx-auto" 
                 style="grid-template-columns: repeat(<%= juego.tamano %>, minmax(0, 1fr)); max-width: 500px;">
              <% juego.grid.forEach((fila, fIndex) => { %>
                <% fila.forEach((letra, cIndex) => { %>
                  <div class="sopa-celda aspect-square flex items-center justify-center 
                              bg-white rounded-lg border border-slate-200 text-sm font-bold 
                              text-slate-700 cursor-pointer select-none hover:bg-teal-50 
                              hover:border-teal-300 transition-all"
                       data-fila="<%= fIndex %>" 
                       data-columna="<%= cIndex %>"
                       data-letra="<%= letra %>">
                    <%= letra %>
                  </div>
                <% }); %>
              <% }); %>
            </div>
          </div>

          <!-- Instrucciones -->
          <div class="flex items-center gap-3 mt-4 text-sm text-slate-400 justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>Selecciona las letras en orden para formar una palabra</span>
          </div>
        </div>

        <!-- Panel lateral -->
        <div class="space-y-responsive">
          <!-- Palabras a encontrar -->
          <div>
            <h3 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-600"><path d="M9 12h6"/><path d="M9 16h6"/><path d="M9 20h6"/><path d="M3 4h18"/><path d="M3 8h18"/><path d="M3 12h1"/><path d="M3 16h1"/><path d="M3 20h1"/></svg>
              Palabras a encontrar:
            </h3>
            <div class="space-y-2" id="lista-palabras">
              <% juego.palabras.forEach(palabra => { %>
                <div class="palabra-item flex items-center gap-3 px-responsive-main py-2.5 sm:py-3 bg-white rounded-xl border border-slate-200 text-sm font-bold text-slate-600" data-palabra="<%= palabra %>">
                  <div class="w-2 h-2 rounded-full bg-teal-400"></div>
                  <%= palabra %>
                </div>
              <% }); %>
            </div>
          </div>

          <!-- Progreso -->
          <div class="bg-sky-50 rounded-2xl p-4 sm:p-5 border border-sky-100">
            <p class="text-sm text-slate-500 mb-2 font-bold uppercase tracking-widest">Tu Progreso</p>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs text-slate-400">Nivel</p>
                <p class="text-xl font-black text-sky-600 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
                  <%= progreso.nivel %>
                </p>
              </div>
              <div>
                <p class="text-xs text-slate-400">Puntos</p>
                <p class="text-xl font-black text-sky-600 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  <%= progreso.puntosTotal %>
                </p>
              </div>
              <div>
                <p class="text-xs text-slate-400">Encontradas</p>
                <p class="text-xl font-black text-teal-600" id="contador-encontradas">0</p>
              </div>
            </div>
          </div>

          <!-- Acciones -->
          <button onclick="verificarPalabraSeleccionada()"
                  class="w-full bg-teal-500 hover:bg-teal-600 text-white font-bold py-responsive-main px-responsive-md rounded-2xl transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Verificar Palabra
          </button>

          <a href="/sopa-letras/jugar?tema=<%= juego.tema.id %>&tamano=<%= juego.tamano %>"
             class="block text-center w-full bg-white hover:bg-slate-50 text-slate-600 font-bold py-responsive-main px-responsive-md rounded-2xl transition-all border border-slate-200 shadow-sm flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 3v6h-6"/></svg>
            Nueva Partida
          </a>

          <div id="mensaje-resultado" class="hidden text-center font-bold py-4 px-6 rounded-2xl transition-all"></div>
        </div>
      </div>

    <% } else { %>
      <!-- Selección de tema -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-teal-100 text-teal-600 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h2 class="text-3xl font-black text-slate-900 mb-4">¡Elige un tema y juega!</h2>
        <p class="text-slate-500 text-lg">Encuentra palabras relacionadas con geografía en la cuadrícula.</p>
      </div>

      <!-- Selector de tema -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-responsive-main mb-8 md:mb-10">
        <% (typeof temas !== 'undefined' ? temas : []).forEach(tema => { %>
          <a href="/sopa-letras/jugar?tema=<%= tema.id %>&tamano=12"
             class="group flex flex-col items-center gap-3 p-responsive-card bg-white rounded-2xl border border-slate-200 hover:border-teal-300 hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="w-14 h-14 bg-teal-50 rounded-2xl flex items-center justify-center text-2xl group-hover:bg-teal-100 transition-colors">
              <span class="icono-render" data-icono="<%= tema.icono %>" data-clases="w-8 h-8 text-teal-600" data-titulo="<%= tema.nombre %>"></span>
            </div>
            <p class="text-sm font-bold text-slate-600 text-center"><%= tema.nombre %></p>
          </a>
        <% }); %>
      </div>

      <!-- Selector de continente -->
      <h3 class="text-lg font-bold text-slate-800 text-center mb-4 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        O elige por continente:
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-responsive-main mb-8 md:mb-10">
        <% (typeof continentes !== 'undefined' ? continentes : []).forEach(c => { %>
          <a href="/sopa-letras/jugar?tema=<%= c.id %>&tamano=12"
             class="group flex flex-col items-center gap-3 p-3 sm:p-4 bg-white rounded-2xl border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1"
             style="border-color: <%= c.color %>33; hover:border-color: <%= c.color %>">
            <span class="icono-render" data-icono="<%= c.svgIcon %>" data-clases="w-8 h-8" data-titulo="<%= c.nombre %>"></span>
            <p class="text-xs font-bold text-slate-600"><%= c.nombre %></p>
          </a>
        <% }); %>
      </div>
    <% } %>

    <!-- Volver -->
    <div class="text-center pt-6 border-t border-slate-100 mt-8">
      <a href="/menu" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-600 font-bold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>

</div>

<script src="/js/sopa-letras.js"></script>
