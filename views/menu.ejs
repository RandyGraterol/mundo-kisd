<% if (typeof usuario !== 'undefined' && usuario && usuario.rol === 'profesor') { %>
  <!-- ================================================ -->
  <!--   MENÚ DEL PROFESOR — Full-width, compacto      -->
  <!-- ================================================ -->
  <div class="min-h-screen bg-white animate-fade-in">
    <div class="px-4 sm:px-6 md:px-8 lg:px-8 py-4 sm:py-6 md:py-8 max-w-full">

      <!-- Header → compacto, horizontal -->
      <div class="bg-gradient-to-r from-indigo-50 to-sky-50 rounded-xl px-responsive-md py-responsive-main md:py-5 mb-4 sm:mb-5 border border-indigo-100 shadow-sm animate-slide-in">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="hidden sm:flex w-9 h-9 bg-indigo-100 rounded-lg items-center justify-center text-indigo-600 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <h1 class="text-responsive-title font-bold text-slate-900 truncate">Panel del Profesor</h1>
              <p class="text-xs sm:text-sm text-slate-500 truncate">Bienvenido, <span class="font-semibold text-indigo-600"><%= nombreUsuario %></span></p>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <a href="/admin"
               class="hidden sm:inline-flex items-center gap-1.5 bg-white hover:bg-indigo-50 text-indigo-600 text-xs font-semibold px-3 py-2 rounded-lg border border-gray-200 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Dashboard
            </a>
            <a href="/salir"
               class="inline-flex items-center gap-1.5 bg-white hover:bg-red-50 hover:text-red-600 text-slate-500 text-xs font-semibold px-3 py-2 rounded-lg border border-gray-200 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              <span class="hidden sm:inline">Salir</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Grid: 3 tarjetas principales → más compactas -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-responsive-main md:gap-5 mb-4 sm:mb-5 md:mb-6">

        <!-- Gestor de Contenido -->
        <a href="/admin/contenido"
           class="group bg-white rounded-xl px-responsive-card py-3 sm:py-3.5 md:py-4 border border-gray-200 shadow-sm hover:border-indigo-300 hover:shadow-md hover:-translate-y-0.5 transition-all animate-fade-in flex items-center gap-responsive-md">
          <div class="w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600 group-hover:bg-indigo-500 group-hover:text-white transition-all shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm sm:text-[15px] font-bold text-slate-800">Gestor de Contenido</h3>
            <p class="text-xs sm:text-[13px] text-slate-500 truncate">Crea y administra preguntas</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-indigo-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <!-- Temporizador -->
        <a href="/admin/temporizador"
           class="group bg-white rounded-xl px-responsive-card py-3 sm:py-3.5 md:py-4 border border-gray-200 shadow-sm hover:border-amber-300 hover:shadow-md hover:-translate-y-0.5 transition-all animate-fade-in flex items-center gap-responsive-md" style="animation-delay: 0.06s">
          <div class="w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-all shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm sm:text-[15px] font-bold text-slate-800">Temporizador</h3>
            <p class="text-xs sm:text-[13px] text-slate-500 truncate">Tiempos por nivel de dificultad</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-amber-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <!-- Monitoreo de Alumnos -->
        <a href="/admin/monitoreo"
           class="group bg-white rounded-xl px-responsive-card py-3 sm:py-3.5 md:py-4 border border-gray-200 shadow-sm hover:border-emerald-300 hover:shadow-md hover:-translate-y-0.5 transition-all animate-fade-in flex items-center gap-responsive-md" style="animation-delay: 0.12s">
          <div class="w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600 group-hover:bg-emerald-500 group-hover:text-white transition-all shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm sm:text-[15px] font-bold text-slate-800">Monitoreo de Alumnos</h3>
            <p class="text-xs sm:text-[13px] text-slate-500 truncate">Rendimiento y progreso</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

      </div>

      <!-- Accesos adicionales -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

        <a href="/admin"
           class="group flex items-center gap-3 bg-white rounded-xl px-4 sm:px-5 py-3 sm:py-3.5 border border-gray-200 shadow-sm hover:border-indigo-200 hover:shadow-md hover:-translate-y-0.5 transition-all animate-fade-in" style="animation-delay: 0.18s">
          <div class="w-9 h-9 sm:w-10 sm:h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-[18px] sm:h-[18px]"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-semibold text-slate-800">Dashboard Completo</h3>
            <p class="text-xs text-slate-500">Estadísticas y alumnos recientes</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-indigo-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a href="/admin/exportar/csv"
           class="group flex items-center gap-3 bg-white rounded-xl px-4 sm:px-5 py-3 sm:py-3.5 border border-gray-200 shadow-sm hover:border-emerald-200 hover:shadow-md hover:-translate-y-0.5 transition-all animate-fade-in" style="animation-delay: 0.24s">
          <div class="w-9 h-9 sm:w-10 sm:h-10 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-all shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-[18px] sm:h-[18px]"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-semibold text-slate-800">Exportar Reporte CSV</h3>
            <p class="text-xs text-slate-500">Datos completos de alumnos</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

      </div>

    </div>
  </div>

<% } else { %>

  <!-- ================================================ -->
  <!--   MENÚ DEL ALUMNO — Full-width, compacto         -->
  <!-- ================================================ -->
  <div class="min-h-screen bg-white animate-fade-in">
    <div class="px-4 sm:px-6 md:px-8 lg:px-8 py-4 sm:py-6 md:py-8 max-w-full">

      <!-- Header: saludo compacto -->
      <div class="flex items-center justify-between mb-4 sm:mb-5 animate-slide-in">
        <div class="flex items-center gap-2.5 min-w-0">
          <div class="w-9 h-9 bg-sky-100 rounded-lg flex items-center justify-center text-sky-500 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4-8-10V5l8-3 8 3v7c0 6-8 10-8 10Z"/><path d="M9 9h6"/><path d="M12 6v6"/></svg>
          </div>
          <div>
            <h1 class="text-responsive-title font-bold text-slate-900">¡Hola, <span class="text-sky-600"><%= nombreUsuario %></span>!</h1>
            <p class="text-sm font-medium text-slate-500">¿Qué aventura eliges hoy?</p>
          </div>
        </div>
        <a href="/salir"
           class="inline-flex items-center gap-1.5 bg-white hover:bg-red-50 hover:text-red-600 text-slate-400 text-xs font-semibold px-3 py-2 rounded-lg border border-gray-200 transition-all shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
          <span class="hidden sm:inline">Salir</span>
        </a>
      </div>

      <!-- Grid principal: Progreso (izq) + Juegos (dcha) -->
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-responsive-fluid">

        <!-- ═══ COLUMNA IZQUIERDA: Progreso + Enlaces ═══ -->
        <div class="lg:col-span-1 md:col-span-1 md:order-1 space-y-3 sm:space-y-4">

          <!-- Tarjeta de progreso compacta -->
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-5">
            <div class="flex items-center gap-2 mb-3 sm:mb-4">
              <div class="p-1.5 bg-sky-100 rounded-md text-sky-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
              </div>
              <h3 class="text-sm font-bold text-slate-800">Tu Progreso</h3>
            </div>
            <div class="grid grid-cols-3 gap-2">
              <div class="bg-sky-50 rounded-lg p-2.5 text-center">
                <p class="text-xs text-slate-500">Nivel</p>
                <p class="text-lg font-bold text-sky-600"><%= progreso.nivel %></p>
              </div>
              <div class="bg-amber-50 rounded-lg p-2.5 text-center">
                <p class="text-xs text-slate-500">Puntos</p>
                <p class="text-lg font-bold text-amber-600"><%= progreso.puntosTotal %></p>
              </div>
              <div class="bg-emerald-50 rounded-lg p-2.5 text-center">
                <p class="text-xs text-slate-500">Mundo</p>
                <p class="text-lg font-bold text-emerald-600"><%= progreso.continentesVisitados.length %>/6</p>
              </div>
            </div>
          </div>

          <!-- Enlaces rápidos: Perfil, Logros, Ranking -->
          <% if (typeof usuario !== 'undefined' && usuario) { %>
            <div class="grid grid-cols-3 gap-2">
              <a href="/perfil"
                 class="flex flex-col items-center gap-1 bg-white rounded-xl py-3 px-2 border border-gray-200 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky-500"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span class="text-xs font-semibold text-slate-600">Perfil</span>
              </a>
              <a href="/logros"
                 class="flex flex-col items-center gap-1 bg-white rounded-xl py-3 px-2 border border-gray-200 shadow-sm hover:border-purple-200 hover:-translate-y-0.5 transition-all text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                <span class="text-xs font-semibold text-slate-600">Logros</span>
              </a>
              <a href="/clasificacion"
                 class="flex flex-col items-center gap-1 bg-white rounded-xl py-3 px-2 border border-gray-200 shadow-sm hover:border-amber-200 hover:-translate-y-0.5 transition-all text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
                <span class="text-xs font-semibold text-slate-600">Ranking</span>
              </a>
            </div>
          <% } %>

        </div>

        <!-- ═══ COLUMNA DERECHA: Actividades / Juegos ═══ -->
        <div class="lg:col-span-2 md:col-span-2 md:order-2">      <div class="grid grid-cols-1 sm:grid-cols-2 gap-responsive-main">
        <!-- Estudiar Continentes -->
            <a href="/continentes"
               class="group bg-white rounded-xl px-4 py-3.5 border border-gray-200 shadow-sm hover:border-teal-300 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center gap-3.5 animate-fade-in">
              <div class="w-11 h-11 bg-teal-100 rounded-lg flex items-center justify-center text-teal-600 group-hover:bg-teal-500 group-hover:text-white transition-all shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="text-sm font-bold text-slate-800">Estudiar Continentes</h3>
                <p class="text-xs text-slate-500 truncate">Cultura y geografía del mundo</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-teal-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>

            <!-- Trivia de Banderas -->
            <a href="/trivia-banderas"
               class="group bg-white rounded-xl px-4 py-3.5 border border-gray-200 shadow-sm hover:border-orange-300 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center gap-3.5 animate-fade-in" style="animation-delay: 0.04s">
              <div class="w-11 h-11 bg-orange-100 rounded-lg flex items-center justify-center text-orange-600 group-hover:bg-orange-500 group-hover:text-white transition-all shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="12" y2="12"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="15" x2="15.01" y1="13" y2="13"/><line x1="18" x2="18.01" y1="11" y2="11"/><rect width="20" height="12" x="2" y="6" rx="2"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="text-sm font-bold text-slate-800">Trivia de Banderas</h3>
                <p class="text-xs text-slate-500 truncate">¿Conoces las banderas?</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-orange-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>

            <!-- Sopa de Letras -->
            <a href="/sopa-letras"
               class="group bg-white rounded-xl px-4 py-3.5 border border-gray-200 shadow-sm hover:border-cyan-300 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center gap-3.5 animate-fade-in" style="animation-delay: 0.08s">
              <div class="w-11 h-11 bg-cyan-100 rounded-lg flex items-center justify-center text-cyan-600 group-hover:bg-cyan-500 group-hover:text-white transition-all shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="text-sm font-bold text-slate-800">Sopa de Letras</h3>
                <p class="text-xs text-slate-500 truncate">Palabras geográficas</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-cyan-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>

            <!-- Juego de Memoria -->
            <a href="/memoria"
               class="group bg-white rounded-xl px-4 py-3.5 border border-gray-200 shadow-sm hover:border-purple-300 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center gap-3.5 animate-fade-in" style="animation-delay: 0.12s">
              <div class="w-11 h-11 bg-purple-100 rounded-lg flex items-center justify-center text-purple-600 group-hover:bg-purple-500 group-hover:text-white transition-all shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              </div>
              <div class="min-w-0 flex-1">
                <h3 class="text-sm font-bold text-slate-800">Juego de Memoria</h3>
