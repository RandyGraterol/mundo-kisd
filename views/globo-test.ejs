<!-- GLOBO MÍNIMO DE PRUEBA - Sin polígonos, sin marcadores, sin estrellas -->
<script src="https://cdn.jsdelivr.net/npm/globe.gl@2.32.2/dist/globe.gl.min.js"></script>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #f0f4f8;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .container {
    width: 100%;
    max-width: 900px;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
    text-align: center;
    margin-bottom: 8px;
  }

  .subtitle {
    text-align: center;
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  #globo-test {
    width: 100%;
    height: 650px;
    border-radius: 24px;
    background: #0a1628;
    overflow: hidden;
    position: relative;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2);
    cursor: grab;
  }

  #globo-test:active { cursor: grabbing; }

  .status-bar {
    margin-top: 16px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .badge {
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    background: #e2e8f0;
    color: #475569;
  }

  .badge.ok { background: #dcfce7; color: #166534; }
  .badge.err { background: #fecaca; color: #991b1b; }
  .badge.warn { background: #fef9c3; color: #854d0e; }

  .debug-console {
    margin-top: 16px;
    width: 100%;
    max-height: 200px;
    overflow-y: auto;
    background: #0f172a;
    color: #e2e8f0;
    font-family: 'Cascadia Code', 'Fira Code', monospace;
    font-size: 0.75rem;
    padding: 12px 16px;
    border-radius: 12px;
    line-height: 1.6;
  }

  .debug-console .log { color: #94a3b8; }
  .debug-console .info { color: #38bdf8; }
  .debug-console .ok   { color: #4ade80; }
  .debug-console .err  { color: #f87171; }
  .debug-console .warn { color: #fbbf24; }
</style>

<div class="container">
  <h1>Globo 3D — Prueba Mínima</h1>
  <p class="subtitle">Sin polígonos, sin marcadores, sin campo estelar. Solo el globo con textura.</p>

  <div id="globo-test"></div>

  <div class="status-bar" id="statusBar">
    <span class="badge" id="badgeGlobe">globe.gl: cargando...</span>
    <span class="badge" id="badgeGlobeMethod">Globe(): esperando...</span>
    <span class="badge" id="badgeTexture">textura: esperando...</span>
  </div>

  <div class="debug-console" id="debugConsole">
    <div class="info">Iniciando diagnóstico del globo mínimo...</div>
  </div>
</div>

<script>
  (function() {
    const container = document.getElementById('globo-test');
    const consoleEl = document.getElementById('debugConsole');
    const badgeGlobe = document.getElementById('badgeGlobe');
    const badgeMethod = document.getElementById('badgeGlobeMethod');
    const badgeTexture = document.getElementById('badgeTexture');

    function log(cls, msg) {
      const line = document.createElement('div');
      line.className = cls;
      line.textContent = '> ' + msg;
      consoleEl.appendChild(line);
      consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    function setBadge(el, cls, text) {
      el.className = 'badge ' + cls;
      el.textContent = text;
    }

    // ── Verificar que globe.gl se cargó ──
    if (typeof Globe === 'undefined') {
      log('err', 'Globe NO está disponible. globe.gl no se cargó correctamente.');
      setBadge(badgeGlobe, 'err', '[ERROR] globe.gl: NO DISPONIBLE');
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#94a3b8;font-size:1.1rem;">[ERROR] globe.gl no se cargó. Verifica la consola de red.</div>';
      return;
    }

    log('ok', 'Globe() está disponible en window.');
    setBadge(badgeGlobe, 'ok', '[OK] globe.gl: disponible');

    // ── Verificar versión (si es accesible) ──
    if (Globe.version) {
      log('info', 'Versión de globe.gl: ' + Globe.version);
    } else {
      log('info', 'Versión de globe.gl: desconocida (sin Globe.version)');
    }

    // ── Crear instancia del globo ──
    let world;
    try {
      world = Globe()(container);
      log('ok', 'Globe() instanciado correctamente.');
      setBadge(badgeMethod, 'ok', '[OK] Globe(): OK');
    } catch (err) {
      log('err', 'Error al instanciar Globe(): ' + err.message);
      log('err', 'Stack: ' + (err.stack || 'N/A'));
      setBadge(badgeMethod, 'err', '[ERROR] Globe(): ERROR');
      container.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#f87171;font-size:1.1rem;">[ERROR] ' + err.message + '</div>';
      return;
    }

    // ── Verificar propiedades del objeto world ──
    const methods = ['globeImageUrl', 'width', 'height', 'backgroundColor', 'controls', 'pointOfView'];
    for (const m of methods) {
      if (typeof world[m] === 'function') {
        log('ok', '  ✔ world.' + m + '() está disponible.');
      } else {
        log('warn', '  [!] world.' + m + '() NO es función. Tipo: ' + typeof world[m]);
      }
    }

    // ── Configurar el globo ──
    log('info', 'Configurando globo...');

    // Dimensiones
    world.width(container.clientWidth);
    world.height(container.clientHeight);
    log('ok', 'Dimensiones: ' + container.clientWidth + 'x' + container.clientHeight);

    // Fondo transparente (el div tiene su propio fondo oscuro)
    world.backgroundColor('rgba(0,0,0,0)');

    // Textura de la Tierra
    const TEXTURE_URL = 'https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg';
    log('info', 'Cargando textura: ' + TEXTURE_URL);

    world.globeImageUrl(TEXTURE_URL);

    // Verificar que se asignó
    const urlActual = world.globeImageUrl();
    log('ok', 'globeImageUrl() retorna: ' + urlActual);

    // ── Atmósfera ──
    world.showAtmosphere(true);
    world.atmosphereColor('#38bdf8');
    world.atmosphereAltitude(0.25);
    log('ok', 'Atmósfera configurada: color=#38bdf8, altitude=0.25');

    // ── [FIX] Color base del material del globo ──
    // Por defecto globe.gl crea un MeshPhongMaterial con color=#000000
    // que multiplica la textura por negro → todo invisible.
    // Forzamos color blanco #ffffff para que la textura se vea.
    try {
      if (typeof world.globeMaterial === 'function') {
        const mat = world.globeMaterial();
        if (mat && typeof mat.color !== 'undefined') {
          const hexAntes = mat.color.getHexString();
          mat.color.setHex(0xffffff);
          log('ok', 'globeMaterial().color corregido: #' + hexAntes + ' → #ffffff');
        } else {
          log('warn', '⚠ globeMaterial() no tiene propiedad color.');
        }
      }
    } catch(e) {
      log('warn', '[!] Error al corregir globeMaterial color: ' + e.message);
    }

    // ── Bump map ──
    world.bumpImageUrl('https://unpkg.com/three-globe/example/img/earth-topology.png');
    log('ok', 'Bump map asignado.');

    // ── Verificar material del globo ──
    try {
      if (typeof world.globeMaterial === 'function') {
        const mat = world.globeMaterial();
        if (mat) {
          log('info', 'globeMaterial: type=' + (mat.type || '?') + 
            ', opacity=' + (mat.opacity ?? '?') + 
            ', transparent=' + mat.transparent +
            ', color=' + (mat.color ? '#' + mat.color.getHexString() : '?'));
        } else {
          log('warn', 'globeMaterial() retornó null/undefined.');
        }
      } else {
        log('warn', 'world.globeMaterial() no está disponible como función.');
      }
    } catch(e) {
      log('warn', 'Error al leer globeMaterial: ' + e.message);
    }

    // ── Posición inicial ──
    world.pointOfView({ lat: 15, lng: -20, altitude: 2.5 });
    log('ok', 'pointOfView: { lat: 15, lng: -20, altitude: 2.5 }');

    // ── Controles ──
    const controls = world.controls();
    if (controls) {
      // [FIX] Radio del globo ≈ 100 unidades Three.js
      // minDistance debe ser > 100 para que la cámara no atraviese el globo.
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.8;
      controls.enableDamping = true;
      controls.dampingFactor = 0.08;
      controls.minDistance = 120;  // 1.2x radio — evita entrar al globo
      controls.maxDistance = 400;  // 4x radio — zoom máximo cómodo
      log('ok', 'Controles configurados: autoRotate=true, minDist=1.5, maxDist=6');
    } else {
      log('warn', 'world.controls() retornó null/undefined.');
    }

    // ── Verificar el Three.js interno ──
    if (world._destructor && world._destructor.three) {
      const THREE = world._destructor.three;
      log('info', 'Three.js interno (version: ' + (THREE.REVISION || '?') + ')');
    }
    
    // ── Acceder al scene/renderer de Three.js para debugging ──
    try {
      // globe.gl expone el scene y renderer internos
      if (world.scene) {
        log('ok', 'world.scene() disponible: ' + (world.scene() ? 'Scene creada' : 'null'));
      } else {
        log('warn', 'world.scene() no está disponible.');
      }
    } catch(e) {
      log('warn', 'Error al acceder a scene: ' + e.message);
    }

    log('ok', 'Configuración completa. El globo debería ser visible.');
    setBadge(badgeTexture, 'ok', '[OK] globo: visible');

    // ── Resize ──
    window.addEventListener('resize', () => {
      if (world) {
        world.width(container.clientWidth);
        world.height(container.clientHeight);
      }
    });

    // ── Test de cámara: reportar posición periódicamente ──
    setTimeout(() => {
      try {
        const pov = world.pointOfView();
        log('info', 'pointOfView actual: lat=' + (pov.lat || '?') + ', lng=' + (pov.lng || '?') + ', alt=' + (pov.altitude || '?'));

        // Verificar que la escena tiene objetos
        if (world.scene) {
          const scene = world.scene();
          if (scene && scene.children) {
            log('info', 'Children en escena: ' + scene.children.length);
            for (let i = 0; i < Math.min(scene.children.length, 8); i++) {
              const child = scene.children[i];
              const type = child.type || child.constructor?.name || '?';
              const visible = child.visible !== false ? 'visible' : 'INVISIBLE';
              log('info', '  [' + i + '] ' + type + ' (' + visible + ')');
            }
          }
        }
      } catch(e) {
        log('warn', 'Error en diagnóstico diferido: ' + e.message);
      }
    }, 2000);

    // ── Segundo diagnóstico a los 5 segundos ──
    setTimeout(() => {
      try {
        if (world.scene) {
          const scene = world.scene();
          if (scene && scene.children) {
            // Buscar el mesh del globo
            const globes = scene.children.filter(c => c.type === 'Mesh' || c.name?.includes('globe') || c.name?.includes('Globe'));
            log('info', 'Meshes encontrados: ' + globes.length);
            globes.forEach((g, i) => {
              const mat = g.material;
              log('info', '  Mesh[' + i + ']: name=' + (g.name || 'sin-nombre') + 
                ', visible=' + g.visible + 
                ', mat.type=' + (mat?.type || '?') +
                ', mat.color=' + (mat?.color ? '#' + mat.color.getHexString() : '?') +
                ', mat.opacity=' + (mat?.opacity ?? '?') +
                ', mat.transparent=' + mat?.transparent);
              // Forzar mesh visible si está oculto
              if (!g.visible) {
                g.visible = true;
                log('fix', 'Mesh[' + i + '] forzado a visible=true');
              }
            });

            // Buscar dentro de Groups también
            const groups = scene.children.filter(c => c.type === 'Group');
            for (const grp of groups) {
              log('info', '  Grupo: ' + (grp.name || 'sin-nombre') + ', children=' + grp.children.length);
              grp.children.forEach((child, j) => {
                if (child.type === 'Mesh') {
                  const m = child.material;
                  log('info', '    Mesh-en-grupo[' + j + ']: visible=' + child.visible + 
                    ', mat.type=' + (m?.type || '?') +
                    ', mat.color=' + (m?.color ? '#' + m.color.getHexString() : '?'));
                }
              });
            }
          }
        }
      } catch(e) {
        log('warn', 'Error en diagnóstico 5s: ' + e.message);
      }
    }, 5000);

    // ── Diagnóstico a los 8 segundos: verificar visibilidad real ──
    setTimeout(() => {
      try {
        const pov = world.pointOfView();
        log('info', 'pointOfView tras 8s: lat=' + (pov.lat?.toFixed(2) || '?') + 
          ', lng=' + (pov.lng?.toFixed(2) || '?') + 
          ', alt=' + (pov.altitude?.toFixed(2) || '?'));
        if (pov.altitude < 0.5) {
          log('warn', '[!] LA CÁMARA ESTÁ DENTRO DEL GLOBO (alt=' + pov.altitude.toFixed(2) + '). Re-aplicando pointOfView...');
          world.pointOfView({ lat: 15, lng: -20, altitude: 2.5 });
          log('fix', 'pointOfView re-aplicado: { lat: 15, lng: -20, altitude: 2.5 }');
        } else {
          log('ok', 'Cámara en posición correcta (alt=' + pov.altitude.toFixed(2) + ')');
        }
        
        // Re-verificar material color después del fix
        if (typeof world.globeMaterial === 'function') {
          const mat = world.globeMaterial();
          if (mat && mat.color) {
            log('ok', 'globeMaterial().color = #' + mat.color.getHexString() + ' (debe ser ffffff)');
          }
        }
      } catch(e) {
        log('warn', 'Error en diagnóstico 8s: ' + e.message);
      }
    }, 8000);

  })();
</script>
