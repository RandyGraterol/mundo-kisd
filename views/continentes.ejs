<!-- Globe.gl and dependencies -->
<script>window.exports = {};</script>
<script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/globe.gl@2.32.2/dist/globe.gl.min.js"></script>
<link rel="stylesheet" href="/css/mapa-estilos.css" />

<!-- Estilos personalizados para el mapa -->
<style>
  #mapa-mundo {
    height: 600px;
    border-radius: 2.5rem;
    cursor: grab;
    background: radial-gradient(circle at center, #f8fafc 0%, #e2e8f0 100%);
    overflow: hidden;
    position: relative;
  }
  
  #mapa-mundo:active {
    cursor: grabbing;
  }
  
  @media (max-width: 768px) {
    #mapa-mundo {
      height: 400px;
    }
  }

  /* Tooltip personalizado para el globo */
  .globe-tooltip {
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(8px);
    color: white;
    padding: 8px 16px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 14px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    pointer-events: none;
    z-index: 1000;
  }
</style>

<div class="min-h-screen p-6 py-12 animate-fade-in">
  
  <div class="max-w-7xl mx-auto">
    
    <!-- Título -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-3 bg-white/40 backdrop-blur-md px-6 py-2 rounded-full border border-white/50 soft-shadow mb-6">
        <span class="text-2xl">🌍</span>
        <h2 class="text-2xl font-bold text-slate-800">
          Explora los Continentes
        </h2>
      </div>
      <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight">El Mundo en tus Manos</h1>
      <p class="text-slate-500 text-xl font-medium mt-4">Haz clic en el mapa o en los botones para descubrir nuevas historias</p>
    </div>

    <!-- Contenedor principal con dos columnas -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-12">
      
      <!-- Mapa interactivo (3/4 del espacio en pantallas grandes) -->
      <div class="lg:col-span-3 glass-effect rounded-[2.5rem] soft-shadow p-8 border border-white/60 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/></svg>
        </div>
        
        <div class="flex items-center gap-3 mb-6">
          <div class="p-2 bg-sky-100 rounded-lg text-sky-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-navigation-2"><polygon points="12 2 19 21 12 17 5 21 12 2"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-800">Mapa Mundial Interactivo</h3>
        </div>

        <div id="mapa-mundo"></div>
        
        <div class="flex items-center justify-center gap-2 mt-6 text-slate-500 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-info"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <p>Haz clic en cualquier continente para ver su información</p>
        </div>
      </div>

      <!-- Grid de continentes (1/4 del espacio en pantallas grandes) -->
      <div class="glass-effect rounded-[2.5rem] soft-shadow p-8 border border-white/60">
        <div class="flex items-center gap-3 mb-8">
          <div class="p-2 bg-teal-100 rounded-lg text-teal-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-list-checks"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-800">Acceso Rápido</h3>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-1 gap-4">
          <% continentes.forEach(continente => { %>
            <a href="/continente/<%= continente.id %>" 
               class="group relative flex items-center gap-4 p-4 rounded-2xl bg-white/40 hover:bg-white hover:soft-shadow border border-white/40 hover:border-sky-100 transition-all">
              <div class="text-3xl transition-transform group-hover:scale-110"><%= continente.emoji %></div>
              <div class="text-slate-700 font-bold text-sm"><%= continente.nombre %></div>
              <div class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-sky-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
              </div>
            </a>
          <% }); %>
        </div>
      </div>

    </div>

    <!-- Botón Volver -->
    <div class="text-center">
      <a href="/menu" 
         class="inline-flex items-center gap-3 px-10 py-5 rounded-2xl bg-slate-900 hover:bg-slate-800 text-white font-bold text-xl soft-shadow transition-all hover:-translate-y-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>

</div>

<!-- Script del mapa de continentes -->
<script src="/js/mapa-continentes.js"></script>
