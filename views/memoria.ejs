<%- include('partials/confetti') %>

<div class="min-h-screen flex items-center justify-center p-responsive-main animate-fade-in">
  
  <div class="bg-white rounded-[3rem] shadow-xl p-responsive card-padding-md max-w-4xl w-full border border-slate-100 md:rounded-[3.5rem]">

    <!-- Encabezado -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-3 bg-purple-50 backdrop-blur-md px-6 py-2 rounded-full border border-purple-100 shadow-sm mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-600"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <h2 class="text-xl font-bold text-slate-800">Juego de Memoria</h2>
      </div>
      <h1 class="text-responsive-4xl font-extrabold text-slate-900 tracking-tight">Encuentra los pares de países</h1>
    </div>

    <% if (juego) { %>
      <!-- Juego activo -->
      <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-4 gap-responsive gap-responsive-desk-lg">
        <!-- Tablero de cartas -->
        <div class="md:col-span-3 lg:col-span-3">
          <!-- Info de nivel y tema -->
          <div class="flex items-center justify-between mb-4 px-1">
            <div class="flex items-center gap-2">
              <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Tema:</span>
              <span class="text-sm font-bold text-slate-800"><%= juego.tema.nombre %></span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Nivel:</span>
              <span class="text-sm font-bold text-slate-800"><%= juego.nivel.nombre %></span>
            </div>
          </div>
          <!-- Grid de cartas con columnas adaptables al nivel -->
          <div class="grid gap-3" id="tablero-memoria"
               style="grid-template-columns: repeat(<%= juego.nivel.columnas %>, minmax(0, 1fr));">
            <% juego.cartas.forEach((carta, index) => { %>
              <div class="carta-memoria aspect-[3/4] cursor-pointer perspective-1000" 
                   data-id="<%= carta.idUnico %>"
                   data-par="<%= carta.parId %>"
                   onclick="voltearCarta(this)">
                <div class="carta-interior relative w-full h-full transition-transform duration-500 transform-gpu" style="transform-style: preserve-3d;">
                  <!-- Reverso -->
                  <div class="carta-reverso absolute inset-0 rounded-2xl bg-gradient-to-br from-purple-400 to-purple-600 shadow-md flex items-center justify-center border-2 border-purple-300" style="backface-visibility: hidden;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                  </div>
                  <!-- Frente -->
                  <div class="carta-frente absolute inset-0 rounded-2xl overflow-hidden shadow-sm" style="backface-visibility: hidden; transform: rotateY(180deg);">
                    <% if (carta.esMonumento) { %>
                      <!-- 🌍 Vuelta al Mundo: emoji de monumento/lugar icónico como figura principal -->
                      <div class="w-full h-full bg-gradient-to-br from-sky-50 via-blue-50 to-indigo-50 flex flex-col items-center justify-center relative">
                        <span class="text-7xl leading-none drop-shadow-lg mb-1 animate-fade-in-fast"><%= carta.emoji %></span>
                        <p class="text-[11px] sm:text-xs font-bold text-slate-700 text-center px-2 leading-tight"><%= carta.contenido %></p>
                        <p class="text-[9px] text-slate-400 text-center px-2 leading-tight"><%= carta.descripcion %></p>
                      </div>
                    <% } else if (carta.esAnimal) { %>
                      <!-- 🐾 Animales del Mundo: emoji gigante como figura principal -->
                      <div class="w-full h-full bg-gradient-to-br from-amber-50 via-yellow-50 to-emerald-50 flex flex-col items-center justify-center relative">
                        <span class="text-7xl leading-none drop-shadow-lg mb-1 animate-fade-in-fast"><%= carta.emoji %></span>
                        <p class="text-[11px] sm:text-xs font-bold text-slate-700 text-center px-2 leading-tight"><%= carta.contenido %></p>
                      </div>
                    <% } else if (carta.usarBandera && carta.codigoPais) { %>
                      <!-- 🏴 Banderas del Mundo: imagen real de bandera -->
                      <img src="https://flagcdn.com/w160/<%= carta.codigoPais %>.png"
                           alt="<%= carta.contenido %>"
                           class="w-full h-full object-cover"
                           fetchpriority="high"
                           onerror="this.classList.add('hidden');this.parentNode.querySelector('.bandera-fallback').classList.remove('hidden')">
                      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent pointer-events-none"></div>
                      <div class="absolute bottom-0 left-0 right-0 px-2 pb-2 pt-6">
                        <p class="text-[11px] sm:text-xs font-bold text-white text-center leading-tight drop-shadow-sm"><%= carta.contenido %></p>
                      </div>
                      <!-- Fallback si la imagen no carga -->
                      <div class="bandera-fallback hidden w-full h-full bg-gradient-to-br from-white to-purple-50/30 flex flex-col items-center justify-center">
                        <span class="text-4xl leading-none drop-shadow-sm mb-0.5"><%= carta.emoji %></span>
                        <p class="text-[10px] font-bold text-slate-600 text-center leading-tight px-1 truncate max-w-full"><%= carta.contenido %></p>
                      </div>
                    <% } else { %>
                      <!-- Otras (Antártida): emoji mediano -->
                      <div class="flex items-center justify-center h-full w-full bg-gradient-to-br from-white to-sky-50/30">
                        <span class="text-5xl leading-none drop-shadow-sm"><%= carta.emoji %></span>
                      </div>
                      <p class="absolute bottom-0 left-0 right-0 text-[10px] font-bold text-slate-600 text-center pb-1.5 px-1 truncate"><%= carta.contenido %></p>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Panel lateral -->
        <div class="space-y-responsive">
          <!-- Temporizador (solo en modo contrarreloj) -->
          <div id="temporizador-panel" class="<%= juego.modo === 'contrarreloj' ? '' : 'hidden' %> bg-gradient-to-br from-rose-50 to-orange-50 rounded-2xl p-5 border border-rose-200 shadow-sm">
            <h3 class="font-bold text-slate-800 mb-3 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-600"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Tiempo restante
            </h3>
            <div class="text-center">
              <div id="display-tiempo" class="text-5xl font-black tabular-nums tracking-tight transition-colors duration-500" style="color: #0f172a;">
                <%= Math.floor(juego.tiempoLimite / 60) %>:<% if (juego.tiempoLimite % 60 < 10) { %>0<% } %><%= juego.tiempoLimite % 60 %>
              </div>
              <div class="w-full bg-white/60 rounded-full h-2.5 mt-3 overflow-hidden border border-rose-100">
                <div id="barra-tiempo" class="h-full rounded-full transition-all duration-1000" style="width: 100%; background: linear-gradient(90deg, #f43f5e, #f97316);"></div>
              </div>
              <p class="text-xs text-slate-400 mt-2 flex items-center justify-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                ¡Contrarreloj activo!
              </p>
            </div>
          </div>

          <!-- Estadísticas -->
          <div class="bg-purple-50 rounded-2xl p-5 border border-purple-100">
            <h3 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-600"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
              Estadísticas
            </h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center bg-white rounded-xl px-3 sm:px-4 py-2.5 sm:py-3 border border-purple-50">
                <span class="text-sm text-slate-500">Pares encontrados</span>
                <span class="text-xl font-black text-purple-600" id="pares-encontrados">0</span>
              </div>
              <div class="flex justify-between items-center bg-white rounded-xl px-responsive-main py-2.5 sm:py-3 border border-purple-50">
                <span class="text-sm text-slate-500">Intentos</span>
                <span class="text-xl font-black text-purple-600" id="intentos">0</span>
              </div>
              <div class="flex justify-between items-center bg-white rounded-xl px-responsive-main py-2.5 sm:py-3 border border-purple-50">
                <span class="text-sm text-slate-500">Total pares</span>
                <span class="text-xl font-black text-purple-600"><%= juego.totalPares %></span>
              </div>
            </div>
          </div>

          <!-- Nivel -->
          <div class="rounded-2xl p-4 sm:p-5 border shadow-sm" style="background: <% if (juego.nivel.id === 'facil') { %>#f0fdf4;border-color:#bbf7d0<% } else if (juego.nivel.id === 'medio') { %>#fefce8;border-color:#fde047<% } else if (juego.nivel.id === 'dificil') { %>#fef2f2;border-color:#fecaca<% } else { %>#faf5ff;border-color:#e9d5ff<% } %>;">
            <div class="flex items-center gap-3 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: <% if (juego.nivel.id === 'facil') { %>#22c55e<% } else if (juego.nivel.id === 'medio') { %>#eab308<% } else if (juego.nivel.id === 'dificil') { %>#ef4444<% } else { %>#a855f7<% } %>;"><circle cx="12" cy="12" r="10"/></svg>
              <div>
                <p class="text-sm font-black text-slate-800">Nivel <%= juego.nivel.nombre.split(' ')[0] %></p>
                <p class="text-xs text-slate-500"><%= juego.totalPares %> pares · <%= juego.totalPares * 2 %> cartas</p>
              </div>
            </div>
            <div class="w-full bg-white/60 rounded-full h-2 mt-2 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500"
                   id="barra-progreso-memoria"
                   style="width: 0%; background: <% if (juego.nivel.id === 'facil') { %>#22c55e<% } else if (juego.nivel.id === 'medio') { %>#eab308<% } else if (juego.nivel.id === 'dificil') { %>#ef4444<% } else { %>#a855f7<% } %>;">
              </div>
            </div>
          </div>

          <!-- Progreso del usuario -->
          <div class="bg-sky-50 rounded-2xl p-4 sm:p-5 border border-sky-100">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-slate-500 font-bold uppercase tracking-widest">Nivel</span>
              <span class="text-xl font-black text-sky-600 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
                <%= progreso.nivel %>
              </span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-500 font-bold uppercase tracking-widest">Puntos</span>
              <span class="text-xl font-black text-sky-600 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <%= progreso.puntosTotal %>
              </span>
            </div>
          </div>

          <!-- Acciones -->
          <a href="/memoria/jugar?tema=<%= juego.tema.id %>&nivel=<%= juego.nivel.id %>&modo=<%= juego.modo %>"
             class="block text-center w-full bg-purple-500 hover:bg-purple-600 text-white font-bold py-responsive-main px-responsive-md rounded-2xl transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9"/><path d="M21 3v6h-6"/></svg>
            Nueva Partida
          </a>

          <a href="/memoria"
             class="block text-center w-full bg-white hover:bg-slate-50 text-slate-600 font-bold py-responsive-main px-responsive-md rounded-2xl transition-all border border-slate-200 shadow-sm flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Cambiar Tema / Nivel
          </a>

          <!-- Mensaje de victoria -->
          <div id="mensaje-victoria" class="hidden bg-gradient-to-br from-amber-400 to-orange-500 rounded-2xl p-6 text-center text-white shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
            <h4 class="text-xl font-black mb-1">¡Completaste el juego!</h4>
            <p class="text-sm opacity-90">Encontraste todos los pares</p>
            <div class="mt-3 flex items-center justify-center gap-2 text-sm font-bold bg-white/20 rounded-xl px-4 py-2">
              <span>Intentos: <span id="intentos-finales">0</span></span>
            </div>
          </div>

          <!-- Mensaje de tiempo agotado (solo contrarreloj) -->
          <div id="mensaje-tiempo-agotado" class="hidden bg-gradient-to-br from-rose-500 to-red-600 rounded-2xl p-6 text-center text-white shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2"><path d="M12 12V7"/><path d="M12 22a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/><path d="M12 18h.01"/></svg>
            <h4 class="text-xl font-black mb-1">¡Se acabó el tiempo!</h4>
            <p class="text-sm opacity-90">No te rindas, ¡inténtalo de nuevo!</p>
            <div class="mt-3 flex items-center justify-center gap-2 text-sm font-bold bg-white/20 rounded-xl px-4 py-2">
              <span>Encontraste <span id="pares-tiempo-agotado">0</span> de <span id="total-tiempo-agotado"><%= juego.totalPares %></span> pares</span>
            </div>
          </div>
        </div>
      </div>

    <% } else { %>
      <!-- Selección de tema y dificultad -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-purple-100 text-purple-600 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
        </div>
        <h2 class="text-3xl font-black text-slate-900 mb-4">¡Elige un tema!</h2>
        <p class="text-slate-500 text-lg">Voltea las cartas y encuentra los pares de países y sus banderas.</p>
      </div>

      <!-- Selector de modo de juego -->
      <div class="max-w-lg mx-auto mb-8">
        <h3 class="text-lg font-bold text-slate-800 text-center mb-4 flex items-center justify-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="12" x="2" y="6" rx="2"/><path d="M6 12h4"/><path d="M14 12h4"/></svg>
          Selecciona el modo:
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div id="modo-normal-card"
               class="cursor-pointer flex flex-col items-center gap-2 p-5 bg-white rounded-2xl border-2 border-purple-400 shadow-md transition-all hover:-translate-y-1 hover:shadow-lg selected-modo"
               data-modo="normal"
               onclick="seleccionarModo('normal')">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-600"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            <p class="text-sm font-bold text-slate-700">Normal</p>
            <p class="text-xs text-slate-400 text-center">Sin límite de tiempo.<br>Juega a tu ritmo.</p>
          </div>
          <div id="modo-contrarreloj-card"
               class="cursor-pointer flex flex-col items-center gap-2 p-5 bg-white rounded-2xl border-2 border-slate-200 transition-all hover:-translate-y-1 hover:shadow-lg"
               data-modo="contrarreloj"
               onclick="seleccionarModo('contrarreloj')">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-600"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <p class="text-sm font-bold text-slate-700">Contrarreloj</p>
            <p class="text-xs text-slate-400 text-center">Cuenta regresiva.<br>¡Encuentra todos los pares a tiempo!</p>
          </div>
        </div>
        <p id="tiempos-ayuda" class="text-xs text-slate-400 text-center mt-2 hidden flex items-center justify-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Tiempos: Fácil 60s · Medio 90s · Difícil 120s · Experto 150s
        </p>
      </div>

      <!-- Selector de niveles -->
      <h3 class="text-lg font-bold text-slate-800 text-center mb-4 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Selecciona tu nivel:
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 max-w-2xl mx-auto">
        <% (typeof niveles !== 'undefined' ? niveles : []).forEach(n => { %>
          <% var colorNivel = n.id === 'facil' ? '#22c55e' : n.id === 'medio' ? '#eab308' : n.id === 'dificil' ? '#ef4444' : '#a855f7'; %>
          <div onclick="seleccionarNivel('<%= n.id %>')"
               class="nivel-link cursor-pointer flex flex-col items-center gap-2 p-5 bg-white rounded-2xl border-2 hover:shadow-lg transition-all hover:-translate-y-1"
               style="border-color: <%= colorNivel %>;"
               data-nivel="<%= n.id %>"
               tabindex="0" role="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: <%= colorNivel %>;"><circle cx="12" cy="12" r="10"/></svg>
            <p class="text-sm font-bold text-slate-700"><%= n.nombre %></p>
            <p class="text-xs text-slate-400 text-center"><%= n.descripcion %></p>
            <span class="text-[10px] font-bold text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full tiempito inline-flex items-center gap-1" style="display:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <%= n.tiempoSegundos %>s
            </span>
          </div>
        <% }); %>
      </div>

      <!-- Grid de temas -->
      <h3 class="text-lg font-bold text-slate-800 text-center mb-4 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Elige un tema:
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-responsive-main mb-8 md:mb-10">
        <% (typeof temas !== 'undefined' ? temas : []).forEach(tema => { %>
          <a href="/memoria/jugar?tema=<%= tema.id %>&nivel=medio&modo=normal"
             class="group flex flex-col items-center gap-3 p-responsive-card bg-white rounded-2xl border border-slate-200 hover:border-purple-300 hover:shadow-lg transition-all hover:-translate-y-1 tema-link"
             data-tema="<%= tema.id %>">
            <span class="icono-render" data-icono="<%= tema.icono %>" data-clases="w-12 h-12 text-purple-600" data-titulo="<%= tema.nombre %>"></span>
            <p class="text-sm font-bold text-slate-600 text-center"><%= tema.nombre %></p>
            <% if (tema.descripcion) { %>
              <p class="text-[10px] text-slate-400 text-center leading-tight"><%= tema.descripcion %></p>
            <% } %>
          </a>
        <% }); %>
      </div>

      <!-- Por continente -->
      <h3 class="text-lg font-bold text-slate-800 text-center mb-4 flex items-center justify-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        O elige por continente:
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-responsive-main">
        <% (typeof continentes !== 'undefined' ? continentes : []).forEach(c => { %>
          <a href="/memoria/jugar?tema=<%= c.id %>&nivel=medio&modo=normal"
             class="group flex flex-col items-center gap-3 p-3 sm:p-4 bg-white rounded-2xl border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1 continente-link"
             data-continente="<%= c.id %>">
            <span class="icono-render" data-icono="<%= c.svgIcon %>" data-clases="w-8 h-8" data-titulo="<%= c.nombre %>"></span>
            <p class="text-xs font-bold text-slate-600"><%= c.nombre %></p>
          </a>
        <% }); %>
      </div>
    <% } %>

    <!-- Volver -->
    <div class="text-center pt-6 border-t border-slate-100 mt-8">
      <a href="/menu" class="inline-flex items-center gap-2 text-slate-400 hover:text-slate-600 font-bold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>

</div>

<script src="/js/memoria.js"></script>
