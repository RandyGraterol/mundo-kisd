<div class="min-h-screen flex items-center justify-center p-6 py-12 animate-fade-in">
  
  <div class="glass-effect rounded-[3rem] soft-shadow p-10 max-w-2xl w-full border border-white/60 relative overflow-hidden">
    
    <!-- Resultado -->
    <div class="text-center mb-10">
      <% if (esCorrecta) { %>
        <!-- Respuesta Correcta -->
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-green-100 text-green-600 mb-6 animate-bounce">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle-2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h2 class="text-5xl font-black text-slate-900 mb-4">
          ¡Muy bien!
        </h2>
        <div class="p-6 bg-green-50 rounded-2xl border border-green-100 mb-4">
          <p class="text-slate-500 font-bold mb-2 uppercase tracking-widest text-xs">Es la bandera de:</p>
          <p class="text-2xl font-black text-green-600"><%= paisCorrecto %></p>
        </div>
        <div class="inline-block px-6 py-2 rounded-full bg-white text-green-700 font-bold text-xl soft-shadow border border-slate-100 mb-4">
          +<%= puntosGanados %> puntos ⭐
        </div>
      <% } else { %>
        <!-- Respuesta Incorrecta -->
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-red-100 text-red-600 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-circle"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
        </div>
        <h2 class="text-5xl font-black text-slate-900 mb-4">
          ¡Casi!
        </h2>
        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 mb-4">
          <p class="text-slate-500 font-bold mb-2 uppercase tracking-widest text-xs">La bandera correcta era:</p>
          <p class="text-2xl font-black text-orange-600"><%= paisCorrecto %></p>
        </div>
      <% } %>
    </div>

    <!-- Progreso actualizado -->
    <div class="grid grid-cols-2 gap-4 mb-10">
      <div class="bg-white/50 backdrop-blur-sm rounded-2xl p-6 border border-white/40 text-center soft-shadow">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Nivel Actual</p>
        <p class="text-3xl font-black text-orange-600">🏆 <%= progreso.nivel %></p>
      </div>
      <div class="bg-white/50 backdrop-blur-sm rounded-2xl p-6 border border-white/40 text-center soft-shadow">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Puntos Totales</p>
        <p class="text-3xl font-black text-orange-600">⭐ <%= progreso.puntosTotal %></p>
      </div>
    </div>

    <!-- Mensaje de nivel -->
    <% if (subisteNivel) { %>
      <div class="bg-gradient-to-br from-amber-400 to-orange-500 rounded-[2rem] p-8 mb-8 text-center text-white soft-shadow animate-pulse">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h4 class="text-3xl font-black mb-1">¡NUEVO NIVEL!</h4>
        <p class="text-xl font-bold opacity-90">
          Has alcanzado el Nivel <%= progreso.nivel %>
        </p>
      </div>
    <% } %>

    <!-- Botones de navegación -->
    <div class="grid gap-4">
      <% if (hayMasPreguntas) { %>
        <!-- Siguiente pregunta -->
        <a href="/trivia-banderas" 
           class="flex items-center justify-center gap-3 bg-slate-900 hover:bg-slate-800 text-white font-bold text-xl py-5 rounded-2xl shadow-xl transition-all transform hover:-translate-y-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right-circle"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="m12 16 4-4-4-4"/></svg>
          Siguiente Bandera
        </a>
      <% } else { %>
        <!-- Trivia completada -->
        <div class="bg-green-50 border border-green-100 rounded-2xl p-6 text-center">
          <p class="text-xl font-bold text-green-700">
            ✨ ¡Has completado todas las banderas disponibles!
          </p>
        </div>
      <% } %>

      <!-- Volver al menú -->
      <a href="/menu" 
         class="flex items-center justify-center gap-3 bg-white/40 hover:bg-white text-slate-600 hover:text-slate-900 font-bold py-4 rounded-2xl transition-all border border-white/60 soft-shadow">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Volver al Menú Principal
      </a>
    </div>

  </div>

</div>
