<div class="min-h-screen flex items-center justify-center p-4 py-12">
  
  <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-2xl w-full border-4 border-orange-400">
    
    <!-- Resultado -->
    <div class="text-center mb-8">
      <% if (esCorrecta) { %>
        <!-- Respuesta Correcta -->
        <div class="text-8xl mb-4">🎉</div>
        <h2 class="text-4xl font-bold text-green-500 mb-3">
          ¡Correcto!
        </h2>
        <p class="text-2xl text-gray-700 mb-2">
          Es la bandera de <span class="font-bold text-orange-600"><%= paisCorrecto %></span> 🚩
        </p>
        <p class="text-xl text-gray-600 mb-4">
          Ganaste <span class="font-bold text-green-600">+<%= puntosGanados %> puntos</span> ⭐
        </p>
      <% } else { %>
        <!-- Respuesta Incorrecta -->
        <div class="text-8xl mb-4">😢</div>
        <h2 class="text-4xl font-bold text-red-500 mb-3">
          ¡Ups! Incorrecto
        </h2>
        <p class="text-xl text-gray-700 mb-4">
          La respuesta correcta era: <span class="font-bold text-orange-600"><%= paisCorrecto %></span> 🚩
        </p>
      <% } %>
    </div>

    <!-- Progreso actualizado -->
    <div class="bg-gradient-to-r from-orange-100 to-yellow-100 rounded-2xl p-6 mb-8">
      <h3 class="text-xl font-bold text-center text-gray-800 mb-4">
        📊 Tu Progreso
      </h3>
      <div class="grid grid-cols-2 gap-4">
        <div class="text-center bg-white rounded-xl p-4">
          <p class="text-sm text-gray-600 mb-1">Nivel</p>
          <p class="text-3xl font-bold text-orange-600">🏆 <%= progreso.nivel %></p>
        </div>
        <div class="text-center bg-white rounded-xl p-4">
          <p class="text-sm text-gray-600 mb-1">Puntos Totales</p>
          <p class="text-3xl font-bold text-orange-600">⭐ <%= progreso.puntosTotal %></p>
        </div>
      </div>
    </div>

    <!-- Mensaje de nivel -->
    <% if (subisteNivel) { %>
      <div class="bg-yellow-100 border-4 border-yellow-400 rounded-2xl p-6 mb-6 text-center animate-pulse">
        <p class="text-3xl mb-2">🎊</p>
        <p class="text-2xl font-bold text-yellow-800">
          ¡Subiste al Nivel <%= progreso.nivel %>!
        </p>
      </div>
    <% } %>

    <!-- Botones de navegación -->
    <div class="space-y-3">
      <% if (hayMasPreguntas) { %>
        <!-- Siguiente pregunta -->
        <a href="/trivia-banderas" 
           class="block bg-orange-500 hover:bg-orange-600 text-white font-bold text-xl py-4 px-8 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105 text-center">
          ➡️ Siguiente Bandera
        </a>
      <% } else { %>
        <!-- Trivia completada -->
        <div class="bg-green-100 border-4 border-green-400 rounded-2xl p-4 mb-4 text-center">
          <p class="text-xl font-bold text-green-800">
            ✅ ¡Completaste todas las banderas!
          </p>
        </div>
      <% } %>

      <!-- Volver al menú -->
      <a href="/menu" 
         class="block bg-purple-500 hover:bg-purple-600 text-white font-bold text-xl py-4 px-8 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105 text-center">
        🏠 Volver al Menú
      </a>
    </div>

  </div>

</div>
