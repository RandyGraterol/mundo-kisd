<% 
  var tiempoLimite = 30;
  if (typeof pregunta !== 'undefined' && pregunta.tiempo_limite) {
    tiempoLimite = parseInt(pregunta.tiempo_limite);
  }
%>

<%- include('partials/modal-atencion') %>
<%- include('partials/cronometro') %>

<div class="min-h-screen flex items-center justify-center p-responsive-main animate-fade-in">
  
  <div class="bg-white rounded-[3rem] shadow-xl p-responsive card-padding-md max-w-3xl w-full border border-slate-100 relative overflow-hidden md:rounded-[3.5rem]">
    
    <!-- Encabezado -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center gap-3 bg-orange-50 backdrop-blur-md px-6 py-2 rounded-full border border-orange-100 shadow-sm mb-6">
        <svg class="w-7 h-7 text-orange-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
        <h2 class="text-xl font-bold text-slate-800">
          Trivia de Banderas
        </h2>
      </div>
      <h1 class="text-responsive-4xl font-extrabold text-slate-900 tracking-tight">¿Reconoces estas banderas?</h1>
    </div>

    <!-- Información de progreso -->
    <div class="grid grid-cols-3 gap-responsive gap-responsive-desk mb-8 md:mb-12">
      <div class="bg-orange-50/60 rounded-2xl p-4 border border-orange-100/60 text-center shadow-sm">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Nivel</p>
        <p class="text-xl font-black text-orange-600 flex items-center justify-center gap-1">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          <%= progreso.nivel %>
        </p>
      </div>
      <div class="bg-orange-50/60 rounded-2xl p-4 border border-orange-100/60 text-center shadow-sm">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Puntos</p>
        <p class="text-xl font-black text-orange-600 flex items-center justify-center gap-1">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <%= progreso.puntosTotal %>
        </p>
      </div>
      <div class="bg-orange-50/60 rounded-2xl p-4 border border-orange-100/60 text-center shadow-sm">
        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Respondidas</p>
        <p class="text-xl font-black text-orange-600 flex items-center justify-center gap-1">
          <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
          <%= preguntasRespondidas %> / 12
        </p>
      </div>
    </div>

    <% if (pregunta) { %>
      <!-- Contenido de la actividad (oculto hasta que se confirme el modal) -->
      <div id="contenido-actividad" style="display: none;">

        <!-- Pregunta actual -->
        <div class="mb-10">
          <div class="bg-slate-900 rounded-[2rem] p-6 sm:p-8 md:p-10 mb-6 md:mb-10 shadow-xl relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10">
              <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flag"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
            </div>
            <h3 class="text-xl font-bold text-orange-400 mb-3 relative z-10 uppercase tracking-widest">Descripción de la Bandera</h3>
            <p class="text-2xl font-bold text-white text-center leading-tight relative z-10">
              <%= pregunta.descripcion %>
            </p>
          </div>

          <!-- Opciones de respuesta -->
          <form method="POST" action="/trivia-banderas/responder" id="form-actividad" onsubmit="detenerCronometro()">
            <input type="hidden" name="preguntaId" value="<%= pregunta.id %>">
            
            <div class="grid gap-responsive-desk">
              <% pregunta.opciones.forEach((opcion, index) => { %>
                <label class="group cursor-pointer">
                  <input type="radio" name="respuesta" value="<%= index %>" class="hidden peer" required>
                  <div class="flex items-center gap-4 p-responsive-card rounded-2xl bg-white border border-slate-200 peer-checked:border-orange-400 peer-checked:shadow-md peer-checked:bg-orange-50 transition-all group-hover:border-orange-200 group-hover:bg-orange-50/50">
                    <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-500 font-bold peer-checked:bg-orange-500 peer-checked:text-white group-hover:bg-orange-100 group-hover:text-orange-600 transition-colors">
                      <%= String.fromCharCode(65 + index) %>
                    </div>
                    <p class="text-lg font-bold text-slate-700 peer-checked:text-slate-900">
                      <%= opcion %>
                    </p>
                    <div class="ml-auto opacity-0 peer-checked:opacity-100 text-orange-500 transition-opacity">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-circle-2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    </div>
                  </div>
                </label>
              <% }); %>
            </div>

            <!-- Botón enviar -->
            <div class="text-center mt-12">
              <button type="submit" 
                      class="inline-flex items-center gap-3 bg-slate-900 hover:bg-slate-800 text-white font-bold text-responsive-subtitle py-4 sm:py-5 md:py-6 px-8 sm:px-12 md:px-16 rounded-2xl shadow-xl hover:shadow-orange-100 transition-all transform hover:-translate-y-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-send"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Enviar Respuesta
              </button>
            </div>
          </form>
        </div>

      </div>
    <% } else { %>
      <!-- Trivia completada -->
      <div class="text-center mb-10 py-10">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-green-100 text-green-600 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
        </div>
        <h3 class="text-4xl font-black text-slate-900 mb-4">
          ¡Trivia Completada!
        </h3>
        <p class="text-xl text-slate-500 mb-8 max-w-md mx-auto">
          Has demostrado ser un experto en las banderas del mundo. ¡Excelente trabajo!
        </p>
        <div class="inline-block bg-white soft-shadow rounded-2xl px-8 py-4 border border-slate-100">
          <p class="text-2xl font-black text-slate-800">
          <svg class="w-6 h-6 inline-block align-text-bottom" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          Nivel <%= progreso.nivel %> ·
          <svg class="w-6 h-6 inline-block align-text-bottom" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <%= progreso.puntosTotal %> puntos
        </p>
        </div>
      </div>
    <% } %>

    <!-- Botón volver -->
    <div class="text-center pt-6 border-t border-slate-100">          <a href="/menu" 
         class="inline-flex items-center gap-3 px-6 sm:px-8 py-responsive-main rounded-xl bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>

</div>

<script>
  // Limpiar flag de sesión al cargar página nueva de trivia (para que el modal aparezca)
  sessionStorage.removeItem('actividad_iniciada');
</script>
