<div class="min-h-screen flex items-center justify-center p-4 py-12">
  
  <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-3xl w-full border-4 border-orange-400">
    
    <!-- Encabezado -->
    <div class="text-center mb-6">
      <div class="text-6xl mb-3">🎮🚩</div>
      <h2 class="text-3xl font-bold text-orange-500 mb-2">
        Trivia de Banderas
      </h2>
      <p class="text-gray-600 text-lg">¡Adivina de qué país es cada bandera!</p>
    </div>

    <!-- Información de progreso -->
    <div class="bg-orange-100 rounded-xl p-4 mb-6 flex justify-between items-center">
      <div class="text-center">
        <p class="text-sm text-gray-600">Nivel</p>
        <p class="text-2xl font-bold text-orange-600">🏆 <%= progreso.nivel %></p>
      </div>
      <div class="text-center">
        <p class="text-sm text-gray-600">Puntos Totales</p>
        <p class="text-2xl font-bold text-orange-600">⭐ <%= progreso.puntosTotal %></p>
      </div>
      <div class="text-center">
        <p class="text-sm text-gray-600">Respondidas</p>
        <p class="text-2xl font-bold text-orange-600">🚩 <%= preguntasRespondidas %>/12</p>
      </div>
    </div>

    <% if (pregunta) { %>
      <!-- Pregunta actual -->
      <div class="mb-8">
        <div class="bg-gradient-to-r from-orange-100 to-yellow-100 rounded-2xl p-6 mb-6">
          <h3 class="text-2xl font-bold text-gray-800 text-center mb-4">
            🚩 Descripción de la Bandera:
          </h3>
          <p class="text-xl text-gray-700 text-center leading-relaxed">
            <%= pregunta.descripcion %>
          </p>
        </div>

        <!-- Opciones de respuesta -->
        <form method="POST" action="/trivia-banderas/responder">
          <input type="hidden" name="preguntaId" value="<%= pregunta.id %>">
          
          <div class="space-y-3">
            <% pregunta.opciones.forEach((opcion, index) => { %>
              <label class="block">
                <input type="radio" name="respuesta" value="<%= index %>" class="hidden peer" required>
                <div class="bg-white border-4 border-gray-300 rounded-xl p-4 cursor-pointer hover:border-orange-400 hover:bg-orange-50 transition-all peer-checked:border-orange-500 peer-checked:bg-orange-100 peer-checked:shadow-lg">
                  <p class="text-lg font-semibold text-gray-700">
                    <span class="inline-block w-8 h-8 bg-orange-400 text-white rounded-full text-center leading-8 mr-3">
                      <%= String.fromCharCode(65 + index) %>
                    </span>
                    <%= opcion %>
                  </p>
                </div>
              </label>
            <% }); %>
          </div>

          <!-- Botón enviar -->
          <div class="text-center mt-8">
            <button type="submit" 
                    class="bg-green-500 hover:bg-green-600 text-white font-bold text-xl py-4 px-12 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105">
              ✅ Responder
            </button>
          </div>
        </form>
      </div>
    <% } else { %>
      <!-- Trivia completada -->
      <div class="text-center mb-8">
        <div class="text-8xl mb-4">🎊</div>
        <h3 class="text-3xl font-bold text-green-500 mb-4">
          ¡Completaste la Trivia!
        </h3>
        <p class="text-xl text-gray-700 mb-6">
          Respondiste todas las preguntas de banderas. ¡Excelente trabajo!
        </p>
        <div class="bg-green-100 border-4 border-green-400 rounded-2xl p-6 mb-6">
          <p class="text-2xl font-bold text-green-800">
            🏆 Nivel <%= progreso.nivel %> | ⭐ <%= progreso.puntosTotal %> puntos
          </p>
        </div>
      </div>
    <% } %>

    <!-- Botón volver -->
    <div class="text-center mt-6">
      <a href="/menu" 
         class="inline-block bg-purple-500 hover:bg-purple-600 text-white font-bold text-xl py-4 px-8 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105">
        🏠 Volver al Menú
      </a>
    </div>

  </div>

</div>
