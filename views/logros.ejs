<style>
  [data-theme="dark"] .log-main { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .log-badge { background: rgba(30,41,59,0.8) !important; border-color: #334155 !important; }
  [data-theme="dark"] .log-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .log-badge h1 { color: #e2e8f0 !important; }
  [data-theme="dark"] .log-sub { color: #64748b !important; }
  [data-theme="dark"] .log-stat { background-color: #0f172a !important; border-color: #1e293b !important; }
  [data-theme="dark"] .log-stat-value { color: #94a3b8 !important; }
  [data-theme="dark"] .log-stat-label { color: #64748b !important; }
  [data-theme="dark"] .log-bar-bg { background-color: #334155 !important; }
  [data-theme="dark"] .log-bar-fill { background: #475569 !important; }
  [data-theme="dark"] .log-category-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .log-category-title svg { color: #64748b !important; }
  [data-theme="dark"] .log-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .log-card:hover { border-color: #475569 !important; }
  [data-theme="dark"] .log-card-locked { background-color: #0f172a !important; border-color: #1e293b !important; }
  [data-theme="dark"] .log-name { color: #e2e8f0 !important; }
  [data-theme="dark"] .log-name-locked { color: #475569 !important; }
  [data-theme="dark"] .log-desc { color: #94a3b8 !important; }
  [data-theme="dark"] .log-desc-locked { color: #475569 !important; }
  [data-theme="dark"] .log-badge-unlocked { background-color: #0f172a !important; color: #94a3b8 !important; }
  [data-theme="dark"] .log-badge-locked { background-color: #0f172a !important; color: #475569 !important; }
  [data-theme="dark"] .log-badge-locked svg { color: #334155 !important; }
  [data-theme="dark"] .log-date { color: #64748b !important; }
  [data-theme="dark"] .log-reward { color: #94a3b8 !important; }
  [data-theme="dark"] .log-empty { color: #64748b !important; }
  [data-theme="dark"] .log-empty svg { color: #334155 !important; }
  [data-theme="dark"] .log-back { background-color: #0f172a !important; border-color: #334155 !important; color: #94a3b8 !important; }
  .log-card-locked svg { filter: grayscale(1); opacity: 0.35; }
  [data-theme="dark"] .log-back:hover { background-color: #1e293b !important; color: #e2e8f0 !important; }
</style>

<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-4xl mx-auto">

    <!-- Encabezado -->
    <div class="flex items-center gap-3 mb-4">
      <div class="log-badge inline-flex items-center gap-2 bg-amber-50 px-3 py-1 rounded-full border border-amber-200 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-600 shrink-0"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        <h1 class="text-sm font-bold text-amber-800">Logros e Insignias</h1>
      </div>
      <p class="log-sub text-xs text-slate-500">Tus medallas</p>
    </div>

    <!-- Progreso general -->
    <div class="flex items-center gap-3 mb-4">
      <div class="log-stat bg-slate-50 rounded-lg px-2.5 py-1 border border-slate-200 text-center shadow-sm min-w-[60px]">
        <p class="log-stat-label text-[8px] text-slate-400 font-bold uppercase tracking-wider">Logros</p>
        <p class="log-stat-value text-[11px] font-black text-slate-600"><%= logrosDesbloqueados %>/<%= logrosTotales %></p>
      </div>
      <div class="flex-1">
        <div class="log-bar-bg w-full bg-slate-100 rounded-full h-2 overflow-hidden">
          <div class="log-bar-fill h-2 rounded-full transition-all duration-700" 
               style="width: <%= logrosTotales > 0 ? Math.round((logrosDesbloqueados / logrosTotales) * 100) : 0 %>%"></div>
        </div>
      </div>
    </div>

    <% if (!logros || logros.length === 0) { %>
      <div class="log-empty text-center py-12 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-slate-300"><path d="M22 12h-6l-2 3H10l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
        <p class="text-sm font-medium">Aún no hay logros disponibles</p>
        <p class="text-[10px] mt-0.5">Vuelve pronto para ver las insignias</p>
      </div>
    <% } else { %>
      <% 
      const categorias = {};
      logros.forEach(l => {
        if (!categorias[l.categoria]) categorias[l.categoria] = [];
        categorias[l.categoria].push(l);
      });
      const nombresCategoria = { 
        progreso: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg> Progreso', 
        actividades: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><rect width="20" height="12" x="2" y="6" rx="2"/><path d="M6 12h4"/><path d="M14 12h4"/></svg> Actividades', 
        habilidad: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/></svg> Habilidad', 
        social: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> Social', 
        especial: '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline -mt-0.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> Especial' 
      };
      %>

      <% Object.entries(categorias).forEach(([categoria, logrosCategoria]) => { %>
      <div class="mb-4">
        <h2 class="log-category-title text-xs font-bold text-slate-700 mb-2"><%- nombresCategoria[categoria] || categoria %></h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-1.5">
          <% logrosCategoria.forEach(logro => { %>
            <% var unlocked = logro.desbloqueado; %>
            <div class="<%= unlocked ? 'log-card bg-white border-slate-200 hover:border-slate-400' : 'log-card-locked bg-slate-50 border-slate-200 opacity-60' %> rounded-xl p-2 border shadow-sm transition-all hover:-translate-y-0.5 text-center">
              <span class="icono-render" data-icono="<%= logro.icono %>" data-clases="w-5 h-5 mx-auto block"></span>
              <h3 class="font-bold text-[10px] <%= unlocked ? 'log-name text-slate-800' : 'log-name-locked text-slate-400' %> mt-1"><%= logro.nombre %></h3>
              <p class="text-[9px] <%= unlocked ? 'log-desc text-slate-500' : 'log-desc-locked text-slate-400' %> leading-tight"><%= logro.descripcion %></p>
              
              <% if (unlocked) { %>
                <div class="log-badge-unlocked mt-1 inline-flex items-center gap-0.5 bg-green-100 text-green-700 text-[8px] font-medium px-1 py-0.5 rounded-full">
                  <svg xmlns="http://www.w3.org/2000/svg" width="7" height="7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Hecho
                </div>
                <% if (logro.fecha_desbloqueado) { %>
                  <p class="log-date text-[8px] text-slate-400">
                    <%= new Date(logro.fecha_desbloqueado).toLocaleDateString('es-ES', { day: 'numeric', month: 'short' }) %>
                  </p>
                <% } %>
              <% } else { %>
                <div class="log-badge-locked mt-1 inline-flex items-center gap-0.5 bg-slate-200 text-slate-500 text-[8px] font-medium px-1 py-0.5 rounded-full">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  Bloqueado
                </div>
                <% if (logro.puntos_recompensa > 0) { %>
                  <p class="log-reward text-[8px]">+<%= logro.puntos_recompensa %> pts</p>
                <% } %>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
      <% }); %>
    <% } %>

    <!-- Volver -->
    <div class="text-center pt-3 mt-4">
      <a href="/menu" 
         class="log-back inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 text-slate-500 text-xs font-bold transition-all border border-slate-200 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>
</div>
