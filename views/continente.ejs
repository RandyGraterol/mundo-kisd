<div class="min-h-screen flex items-center justify-center p-6 py-12 animate-fade-in">
  
  <div class="glass-effect rounded-[3rem] soft-shadow p-12 max-w-4xl w-full border border-white/60 relative overflow-hidden">
    <!-- Decoración de fondo -->
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-sky-100 rounded-full blur-3xl opacity-50"></div>
    <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-teal-50 rounded-full blur-3xl opacity-50"></div>

    <!-- Título con emoji del continente -->
    <div class="text-center mb-10 relative">
      <div class="inline-flex items-center justify-center w-32 h-32 rounded-[2.5rem] bg-white soft-shadow text-7xl mb-6 transform hover:rotate-6 transition-transform">
        <%= continente.emoji %>
      </div>
      <h2 class="text-5xl font-extrabold text-slate-900 tracking-tight mb-4">
        <%= continente.nombre %>
      </h2>
      <div class="h-1.5 w-24 bg-sky-400 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 mb-12 relative">
      <!-- Columna Izquierda: Información -->
      <div class="space-y-8">
        <div class="space-y-4">
          <div class="flex items-center gap-3 text-sky-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open-check"><path d="M8 3H2v15h7c1.7 0 3 1.3 3 3V7c0-2.2-1.8-4-4-4Z"/><path d="m16 12 2 2 4-4"/><path d="M22 6V3h-6c-2.2 0-4 1.8-4 4v14c0-1.7 1.3-3 3-3h7v-3"/></svg>
            <h3 class="text-xl font-bold text-slate-800">Sobre este continente</h3>
          </div>
          <p class="text-slate-600 text-lg leading-relaxed font-medium">
            <%= continente.descripcion %>
          </p>
        </div>

        <div class="bg-amber-50/50 backdrop-blur-sm border border-amber-100 p-6 rounded-[2rem] soft-shadow">
          <div class="flex items-center gap-3 text-amber-600 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3 1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
            <h3 class="text-lg font-bold">¿Sabías qué?</h3>
          </div>
          <p class="text-slate-700 leading-relaxed italic">
            "<%= continente.datosCuriosos %>"
          </p>
        </div>
      </div>

      <!-- Columna Derecha: Países -->
      <div class="space-y-8">
        <div class="space-y-6">
          <div class="flex items-center gap-3 text-teal-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <h3 class="text-xl font-bold text-slate-800">Países Principales</h3>
          </div>
          
          <div class="flex flex-wrap gap-3">
            <% if (continente.paisesPrincipales.length > 0) { %>
              <% continente.paisesPrincipales.forEach(pais => { %>
                <div class="px-5 py-2.5 rounded-xl bg-white border border-slate-100 text-slate-700 font-bold soft-shadow hover:border-teal-200 transition-colors">
                  <%= pais %>
                </div>
              <% }); %>
            <% } else { %>
              <div class="p-6 bg-slate-50 rounded-2xl border border-dashed border-slate-200 text-slate-500 italic w-full">
                Este territorio es un espacio internacional dedicado a la ciencia.
              </div>
            <% } %>
          </div>
        </div>

        <!-- Botón de Reto -->
        <% if (continente.preguntas && continente.preguntas.length > 0) { %>
          <a href="/reto/<%= continente.id %>" 
             class="group block p-1 rounded-2xl bg-gradient-to-br from-sky-400 to-teal-500 hover:from-sky-500 hover:to-teal-600 transition-all soft-shadow hover:-translate-y-1">
            <div class="bg-white/10 group-hover:bg-transparent px-8 py-6 rounded-xl flex items-center justify-between text-white">
              <div class="flex items-center gap-4">
                <div class="p-3 bg-white/20 rounded-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                </div>
                <div>
                  <h4 class="text-2xl font-black">¡ACEPTA EL RETO!</h4>
                  <p class="text-sky-50 opacity-90 font-medium"><%= continente.preguntas.length %> preguntas de geografía</p>
                </div>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          </a>
        <% } %>
      </div>
    </div>

    <!-- Botón Volver -->
    <div class="text-center pt-6 border-t border-slate-100">
      <a href="/continentes" 
         class="inline-flex items-center gap-3 px-8 py-4 rounded-xl text-slate-500 hover:text-slate-800 font-bold text-lg transition-all hover:bg-slate-50">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Volver al Mapa
      </a>
    </div>

  </div>

</div>
