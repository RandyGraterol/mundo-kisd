<%- include('partials/confetti') %>

<style>
  [data-theme="dark"] .rtres-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .rtres-icon-correct { background-color: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .rtres-icon-wrong { background-color: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .rtres-h2 { color: #f1f5f9 !important; }
  [data-theme="dark"] .rtres-puntos { background-color: #0f172a !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .rtres-answer-box { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .rtres-answer-label { color: #64748b !important; }
  [data-theme="dark"] .rtres-answer-text { color: #94a3b8 !important; }
  [data-theme="dark"] .rtres-stat { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .rtres-stat-label { color: #64748b !important; }
  [data-theme="dark"] .rtres-stat-value { color: #94a3b8 !important; }
  [data-theme="dark"] .rtres-nivelup { background: #1e293b !important; }
  [data-theme="dark"] .rtres-nivelup-icon { background-color: #0f172a !important; }
  [data-theme="dark"] .rtres-nivelup-text { color: #e2e8f0 !important; }
  [data-theme="dark"] .rtres-complete { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .rtres-complete-text { color: #94a3b8 !important; }
  [data-theme="dark"] .rtres-btn-primary { background-color: #475569 !important; }
  [data-theme="dark"] .rtres-btn-primary:hover { background-color: #64748b !important; }
  [data-theme="dark"] .rtres-btn-secondary { background-color: #0f172a !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .rtres-btn-secondary:hover { background-color: #1e293b !important; color: #e2e8f0 !important; }
</style>

<div class="min-h-screen flex items-center justify-center p-4 sm:p-6 animate-fade-in">

  <div class="rtres-card bg-white rounded-[2.5rem] shadow-xl p-6 sm:p-8 max-w-lg w-full border border-slate-100">

    <!-- Resultado + Stats en fila -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-5">
      <div class="flex items-center gap-3 flex-1">
        <% if (esCorrecta) { %>
          <div class="rtres-icon-correct inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-green-100 text-green-600 animate-bounce shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <div>
            <h2 class="rtres-h2 text-lg font-black text-slate-900">¡Excelente!</h2>
            <div class="rtres-puntos inline-flex items-center gap-1 px-3 py-0.5 rounded-full bg-white text-green-700 font-bold text-xs shadow-sm border border-slate-100 mt-0.5">
              +<%= puntosGanados %> pts
              <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
          </div>
        <% } else { %>
          <div class="rtres-icon-wrong inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-red-100 text-red-600 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
          </div>
          <div>
            <h2 class="rtres-h2 text-lg font-black text-slate-900">¡Casi lo logras!</h2>
          </div>
        <% } %>
      </div>

      <!-- Stats compactas -->
      <div class="flex gap-3 shrink-0">
        <div class="rtres-stat bg-slate-50 rounded-xl px-3 py-2 border border-slate-100 text-center min-w-[70px]">
          <p class="rtres-stat-label text-[10px] text-slate-400 font-bold uppercase tracking-wider">Nivel</p>
          <p class="rtres-stat-value text-sm font-black text-slate-700"><%= progreso.nivel %></p>
        </div>
        <div class="rtres-stat bg-slate-50 rounded-xl px-3 py-2 border border-slate-100 text-center min-w-[70px]">
          <p class="rtres-stat-label text-[10px] text-slate-400 font-bold uppercase tracking-wider">Puntos</p>
          <p class="rtres-stat-value text-sm font-black text-slate-700"><%= progreso.puntosTotal %></p>
        </div>
      </div>
    </div>

    <!-- Respuesta correcta (si falló) -->
    <% if (!esCorrecta) { %>
      <div class="rtres-answer-box bg-slate-50 rounded-xl p-4 border border-slate-100 mb-5">
        <p class="rtres-answer-label text-slate-400 font-bold uppercase tracking-widest text-[10px] mb-1">La respuesta correcta era:</p>
        <p class="rtres-answer-text text-base font-black text-slate-600"><%= respuestaCorrecta %></p>
      </div>
    <% } %>

    <!-- NUEVO NIVEL -->
    <% if (subisteNivel) { %>
      <div class="rtres-nivelup rounded-2xl p-5 mb-5 text-center shadow-md bg-gradient-to-br from-amber-400 to-orange-500">
        <div class="rtres-nivelup-icon inline-flex items-center justify-center w-12 h-12 bg-white/20 rounded-xl mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <h4 class="rtres-nivelup-text text-xl font-black text-white">¡NUEVO NIVEL!</h4>
        <p class="text-sm font-bold text-white/90">Has alcanzado el Nivel <%= progreso.nivel %></p>
      </div>
    <% } %>

    <!-- Botones -->
    <div class="flex flex-col gap-3">
      <% if (hayMasPreguntas) { %>
        <a href="/reto/<%= continente.id %>?pregunta=<%= siguientePregunta %>"
           class="rtres-btn-primary flex items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-white font-bold text-sm py-3 rounded-xl shadow-md transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="m12 16 4-4-4-4"/></svg>
          Siguiente Pregunta
        </a>
      <% } else { %>
        <div class="rtres-complete bg-green-50 border border-green-100 rounded-xl p-4 text-center">
          <p class="rtres-complete-text text-sm font-bold text-green-700">
            <svg class="w-4 h-4 inline-block align-text-bottom mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ¡Has completado todas las preguntas de <%= continente.nombre %>!
          </p>
        </div>
      <% } %>

      <div class="grid grid-cols-2 gap-3">
        <a href="/continente/<%= continente.id %>"
           class="rtres-btn-secondary flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-500 hover:text-slate-700 font-semibold text-xs py-3 rounded-xl transition-all border border-slate-200 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>
          Información
        </a>
        <a href="/continentes"
           class="rtres-btn-secondary flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-slate-500 hover:text-slate-700 font-semibold text-xs py-3 rounded-xl transition-all border border-slate-200 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.381V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z"/><path d="M15 5.764v15"/><path d="M9 3.236v15"/></svg>
          Mapa Mundial
        </a>
      </div>
    </div>

  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  <% if (esCorrecta) { %>
    if (typeof SonidosMundoKids !== 'undefined') SonidosMundoKids.correcto();
    if (typeof lanzarConfetti === 'function') {
      lanzarConfetti(100, true);
      setTimeout(function() { if (typeof lanzarFuegosArtificiales === 'function') lanzarFuegosArtificiales(2); }, 800);
    }
  <% } else { %>
    if (typeof SonidosMundoKids !== 'undefined') SonidosMundoKids.incorrecto();
  <% } %>
  <% if (subisteNivel) { %>
    setTimeout(function() {
      if (typeof SonidosMundoKids !== 'undefined') SonidosMundoKids.nivel();
      if (typeof lanzarConfetti === 'function') lanzarConfetti(120, true);
    }, 1500);
    setTimeout(function() { if (typeof lanzarFuegosArtificiales === 'function') lanzarFuegosArtificiales(3); }, 2500);
  <% } %>
});
</script>
