<div class="min-h-screen p-responsive-main lg:p-10 animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 sm:mb-8 md:mb-10 gap-4">
      <div>
        <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
          Gestor de Contenido
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">Banco de Preguntas</h1>
        <p class="text-slate-500 mt-1 text-sm sm:text-base">Crea y administra las preguntas personalizadas para tus actividades.</p>
      </div>
      <a href="/admin/contenido/nueva"
         class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl transition-all soft-shadow flex items-center gap-2 w-full sm:w-auto justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nueva Pregunta
      </a>
    </div>

    <!-- Filtros -->
    <div class="bg-white rounded-2xl p-3 sm:p-4 md:p-5 soft-shadow border border-slate-100 mb-responsive flex flex-wrap items-center gap-responsive-main">
      <span class="text-xs sm:text-sm font-semibold text-slate-600">Filtrar:</span>
      <button onclick="filtrar('todas')" class="filtro-btn px-responsive-main py-1.5 rounded-lg text-xs sm:text-sm font-medium bg-indigo-100 text-indigo-700 hover:bg-indigo-200 transition-all" data-filtro="todas">Todas</button>
      <button onclick="filtrar('continente')" class="filtro-btn px-responsive-main py-1.5 rounded-lg text-xs sm:text-sm font-medium text-slate-600 hover:bg-slate-100 transition-all" data-filtro="continente">Continentes</button>
      <button onclick="filtrar('banderas')" class="filtro-btn px-responsive-main py-1.5 rounded-lg text-xs sm:text-sm font-medium text-slate-600 hover:bg-slate-100 transition-all" data-filtro="banderas">Banderas</button>
      <button onclick="filtrar('activas')" class="filtro-btn px-responsive-main py-1.5 rounded-lg text-xs sm:text-sm font-medium text-slate-600 hover:bg-slate-100 transition-all" data-filtro="activas">Activas</button>
      <button onclick="filtrar('inactivas')" class="filtro-btn px-responsive-main py-1.5 rounded-lg text-xs sm:text-sm font-medium text-slate-600 hover:bg-slate-100 transition-all" data-filtro="inactivas">Inactivas</button>
    </div>

    <!-- Lista de Preguntas -->
    <% if (preguntas.length === 0) { %>
      <div class="bg-white rounded-2xl p-6 sm:p-12 md:p-16 soft-shadow border border-slate-100 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-indigo-100 text-indigo-600 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-700 mb-2">No hay preguntas aún</h3>
        <p class="text-slate-400 mb-6">Crea tu primera pregunta personalizada para tus alumnos.</p>
        <a href="/admin/contenido/nueva"
           class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl transition-all inline-block">
          Crear Primera Pregunta
        </a>
      </div>
    <% } else { %>
      <div class="space-y-3 sm:space-y-4">
        <% preguntas.forEach(function(p, index) { %>
          <div class="pregunta-item bg-white rounded-2xl p-4 sm:p-5 soft-shadow border <%= p.activa ? 'border-slate-100' : 'border-red-100 bg-red-50/30' %> hover:border-indigo-200 transition-all"
               data-tipo="<%= p.tipo %>"
               data-activa="<%= p.activa %>">
            <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-1.5 sm:gap-2 mb-2">
                  <span class="px-2.5 py-0.5 rounded-full text-xs font-bold inline-flex items-center gap-1 <%= p.tipo === 'continente' ? 'bg-sky-100 text-sky-700' : 'bg-orange-100 text-orange-700' %>">
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    <%= p.tipo === 'continente' ? 'Continente' : 'Banderas' %>
                  </span>
                  <% if (p.continente_id) { %>
                    <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-600">
                      <%= continentes.find(c => c.id === p.continente_id)?.nombre || p.continente_id %>
                    </span>
                  <% } %>
                  <% if (!p.activa) { %>
                    <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-red-100 text-red-600">Inactiva</span>
                  <% } %>
                  <span class="text-xs text-slate-400 ml-auto">#<%= p.id %></span>
                </div>
                <h3 class="text-base sm:text-lg font-bold text-slate-800"><%= p.pregunta %></h3>
                <div class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-1.5 sm:gap-2">
                  <% p.opciones.forEach(function(opcion, oIndex) { %>
                    <div class="flex items-center gap-2 <%= oIndex === p.respuesta_correcta ? 'text-emerald-600 font-semibold' : 'text-slate-500' %>">
                      <span class="w-2 h-2 rounded-full <%= oIndex === p.respuesta_correcta ? 'bg-emerald-500' : 'bg-slate-300' %> flex-shrink-0"></span>
                      <span class="text-sm truncate"><%= opcion %></span>
                      <% if (oIndex === p.respuesta_correcta) { %>
                        <svg class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      <% } %>
                    </div>
                  <% }); %>
                </div>
                <div class="flex flex-wrap items-center gap-2 sm:gap-4 mt-3 text-xs text-slate-400">
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <%= p.puntos %> pts
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <%= p.tiempo_limite %>s
                  </span>
                  <span class="truncate">Creada por: <%= p.creado_por %></span>
                  <span class="hidden sm:inline"><%= new Date(p.fecha_creacion).toLocaleDateString() %></span>
                </div>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0 self-end sm:self-start">
                <a href="/admin/contenido/editar/<%= p.id %>"
                   class="p-2.5 bg-slate-100 hover:bg-sky-100 rounded-xl text-slate-500 hover:text-sky-600 transition-all"
                   title="Editar">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
                </a>
                <form action="/admin/contenido/eliminar/<%= p.id %>" method="POST" onsubmit="return confirm('¿Desactivar esta pregunta? No se eliminará permanentemente.');">
                  <button type="submit"
                     class="p-2.5 bg-slate-100 hover:bg-red-100 rounded-xl text-slate-500 hover:text-red-600 transition-all"
                     title="Desactivar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<script>
function filtrar(filtro) {
  document.querySelectorAll('.filtro-btn').forEach(function(btn) {
    btn.classList.remove('bg-indigo-100', 'text-indigo-700');
    btn.classList.add('text-slate-600', 'hover:bg-slate-100');
  });
  var activo = document.querySelector('.filtro-btn[data-filtro="' + filtro + '"]');
  if (activo) {
    activo.classList.add('bg-indigo-100', 'text-indigo-700');
    activo.classList.remove('text-slate-600', 'hover:bg-slate-100');
  }

  document.querySelectorAll('.pregunta-item').forEach(function(item) {
    if (filtro === 'todas') {
      item.style.display = 'block';
    } else if (filtro === 'activas') {
      item.style.display = item.dataset.activa === '1' ? 'block' : 'none';
    } else if (filtro === 'inactivas') {
      item.style.display = item.dataset.activa === '0' ? 'block' : 'none';
    } else {
      item.style.display = item.dataset.tipo === filtro ? 'block' : 'none';
    }
  });
}
</script>