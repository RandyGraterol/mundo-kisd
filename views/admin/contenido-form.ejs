<style>
  [data-theme="dark"] .cf-badge { background: rgba(99,102,241,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .cf-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .cf-title { color: #f1f5f9 !important; }
  [data-theme="dark"] .cf-subtitle { color: #64748b !important; }
  [data-theme="dark"] .cf-msg-error { background: rgba(239,68,68,0.1) !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .cf-msg-error svg { color: #94a3b8 !important; }
  [data-theme="dark"] .cf-form { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .cf-label { color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-select { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-select:focus { border-color: #64748b !important; }
  [data-theme="dark"] .cf-textarea { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-textarea:focus { border-color: #64748b !important; }
  [data-theme="dark"] .cf-textarea::placeholder { color: #475569 !important; }
  [data-theme="dark"] .cf-option-card { border-color: #334155 !important; }
  [data-theme="dark"] .cf-option-card-selected { border-color: #64748b !important; background-color: rgba(16,185,129,0.1) !important; }
  [data-theme="dark"] .cf-option-input { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-option-input:focus { border-color: #64748b !important; }
  [data-theme="dark"] .cf-option-hint { color: #64748b !important; }
  [data-theme="dark"] .cf-option-hint svg { color: #475569 !important; }
  [data-theme="dark"] .cf-divider { border-color: #334155 !important; }
  [data-theme="dark"] .cf-section-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-input { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-input:focus { border-color: #64748b !important; }
  [data-theme="dark"] .cf-checkbox { accent-color: #64748b !important; }
  [data-theme="dark"] .cf-checkbox-label { color: #94a3b8 !important; }
  [data-theme="dark"] .cf-btn-cancel { background-color: #1e293b !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .cf-btn-cancel:hover { background-color: #0f172a !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .cf-btn-submit { background-color: #475569 !important; }
  [data-theme="dark"] .cf-btn-submit:hover { background-color: #64748b !important; }
</style>

<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <div class="cf-badge inline-flex items-center gap-1.5 bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-xs font-bold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
        Gestor de Contenido
      </div>
      <h1 class="cf-title text-2xl font-extrabold text-slate-900">
        <%= pregunta ? 'Editar Pregunta' : 'Nueva Pregunta' %>
      </h1>
      <p class="cf-subtitle text-slate-500 text-xs mt-0.5">
        <%= pregunta ? 'Modifica los datos de la pregunta personalizada.' : 'Crea una nueva pregunta para tus actividades.' %>
      </p>
    </div>

    <!-- Error -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="cf-msg-error bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="text-sm font-medium"><%= error %></span>
      </div>
    <% } %>

    <!-- Formulario -->
    <form action="<%= pregunta ? '/admin/contenido/editar/' + pregunta.id : '/admin/contenido/nueva' %>" method="POST"
          class="cf-form bg-white rounded-xl p-5 border border-slate-100 space-y-5">

      <!-- Tipo -->
      <div>
        <label class="cf-label block text-sm font-bold text-slate-700 mb-1.5">Tipo de Pregunta</label>
        <select name="tipo" id="tipoSelect" required
                class="cf-select w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm"
                onchange="toggleContinente()">
          <% tipos.forEach(function(t) { %>
            <option value="<%= t.valor %>" <%= pregunta && pregunta.tipo === t.valor ? 'selected' : '' %>>
              <%= t.etiqueta %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Continente -->
      <div id="continenteGroup" class="<%= pregunta && pregunta.tipo === 'reto' ? '' : 'hidden' %>">
        <label class="cf-label block text-sm font-bold text-slate-700 mb-1.5">Continente</label>
        <select name="continenteId"
                class="cf-select w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm">
          <option value="">Seleccionar continente...</option>
          <% continentes.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= pregunta && pregunta.continente_id === c.id ? 'selected' : '' %>>
              <%= c.nombre %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Pregunta -->
      <div>
        <label class="cf-label block text-sm font-bold text-slate-700 mb-1.5">Pregunta</label>
        <textarea name="pregunta" rows="2" required
                  class="cf-textarea w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm resize-none"
                  placeholder="Escribe la pregunta aquí..."><%= pregunta ? pregunta.pregunta : '' %></textarea>
      </div>

      <!-- Opciones -->
      <div>
        <label class="cf-label block text-sm font-bold text-slate-700 mb-2">Opciones de Respuesta</label>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <% for (var i = 0; i < 4; i++) { %>
            <div class="flex items-center gap-2.5 p-2.5 rounded-lg border <%= pregunta && pregunta.respuesta_correcta === i ? 'cf-option-card-selected border-emerald-300 bg-emerald-50/50' : 'cf-option-card border-slate-200' %>">
              <input type="radio" name="respuestaCorrecta" value="<%= i %>" required
                     <%= pregunta && pregunta.respuesta_correcta === i ? 'checked' : i === 0 && !pregunta ? 'checked' : '' %>
                     class="w-4 h-4 text-emerald-500 focus:ring-emerald-400 shrink-0">
              <input type="text" name="opcion<%= i+1 %>" required
                     value="<%= pregunta ? pregunta.opciones[i] : '' %>"
                     placeholder="Opción <%= i+1 %>"
                     class="cf-option-input flex-1 p-2 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm">
            </div>
          <% } %>
        </div>
        <p class="cf-option-hint text-[11px] text-slate-400 mt-1.5 flex items-center gap-1">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
          Selecciona el círculo de la opción correcta.
        </p>
      </div>

      <!-- Configuración Avanzada -->
      <div class="cf-divider border-t border-slate-100 pt-5">
        <h3 class="cf-section-title text-sm font-bold text-slate-700 mb-3">Configuración Avanzada</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="cf-label block text-xs font-bold text-slate-700 mb-1.5">Puntos</label>
            <input type="number" name="puntos" value="<%= pregunta ? pregunta.puntos : 10 %>" min="1" max="100"
                   class="cf-input w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm">
          </div>
          <div>
            <label class="cf-label block text-xs font-bold text-slate-700 mb-1.5">Tiempo Límite (seg)</label>
            <input type="number" name="tiempoLimite" value="<%= pregunta ? pregunta.tiempo_limite : 30 %>" min="5" max="300"
                   class="cf-input w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all text-sm">
          </div>
          <% if (pregunta) { %>
            <div class="flex items-center gap-2 pt-5">
              <input type="checkbox" name="activa" id="activa" <%= pregunta.activa == 1 ? 'checked' : '' %>
                     class="cf-checkbox w-4 h-4 text-indigo-500 focus:ring-indigo-400 rounded">
              <label for="activa" class="cf-checkbox-label text-sm font-medium text-slate-700">Pregunta Activa</label>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Botones -->
      <div class="cf-divider flex flex-col sm:flex-row items-stretch sm:items-center justify-between pt-4 border-t border-slate-100 gap-2">
        <a href="/admin/contenido"
           class="cf-btn-cancel bg-white hover:bg-slate-50 text-slate-600 font-bold py-2.5 px-5 rounded-lg border border-slate-200 transition-all text-center text-xs">
          ← Cancelar
        </a>
        <button type="submit"
                class="cf-btn-submit bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-lg transition-all flex items-center justify-center gap-2 text-xs">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <%= pregunta ? 'Guardar Cambios' : 'Crear Pregunta' %>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function toggleContinente() {
  var tipo = document.getElementById('tipoSelect').value;
  document.getElementById('continenteGroup').classList.toggle('hidden', tipo !== 'reto');
}
toggleContinente();
</script>
