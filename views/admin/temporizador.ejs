<style>
  [data-theme="dark"] .tmp-badge { background: rgba(251,191,36,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-title { color: #f1f5f9 !important; }
  [data-theme="dark"] .tmp-subtitle { color: #64748b !important; }
  [data-theme="dark"] .tmp-msg-success { background: rgba(16,185,129,0.1) !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-msg-success svg { color: #64748b !important; }
  [data-theme="dark"] .tmp-msg-error { background: rgba(239,68,68,0.1) !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-msg-error svg { color: #64748b !important; }
  [data-theme="dark"] .tmp-form { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .tmp-section-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .tmp-empty { color: #64748b !important; }
  [data-theme="dark"] .tmp-config-card { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .tmp-config-card-inactive { border-color: #334155 !important; background-color: rgba(30,41,59,0.5) !important; }
  [data-theme="dark"] .tmp-label { color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-input { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .tmp-input:focus { border-color: #64748b !important; }
  [data-theme="dark"] .tmp-checkbox { accent-color: #64748b !important; }
  [data-theme="dark"] .tmp-checkbox-label { color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-divider { border-color: #334155 !important; }
  [data-theme="dark"] .tmp-new-card { border-color: #475569 !important; background-color: rgba(15,23,42,0.5) !important; }
  [data-theme="dark"] .tmp-btn-back { background-color: #1e293b !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .tmp-btn-back:hover { background-color: #0f172a !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .tmp-btn-save { background-color: #475569 !important; }
  [data-theme="dark"] .tmp-btn-save:hover { background-color: #64748b !important; }
  [data-theme="dark"] .tmp-preview { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .tmp-preview-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .tmp-preview-card { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .tmp-preview-card-matched { background-color: rgba(15,23,42,0.8) !important; border-color: #475569 !important; }
  [data-theme="dark"] .tmp-preview-label { color: #64748b !important; }
  [data-theme="dark"] .tmp-preview-empty { color: #475569 !important; }
  [data-theme="dark"] .tmp-preview-value { color: #94a3b8 !important; }
</style>

<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <div class="tmp-badge inline-flex items-center gap-1.5 bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Configuración
      </div>
      <h1 class="tmp-title text-2xl font-extrabold text-slate-900">Temporizador</h1>
      <p class="tmp-subtitle text-slate-500 text-xs mt-0.5">Define los tiempos de respuesta para cada rango de niveles.</p>
    </div>

    <!-- Mensajes -->
    <% if (typeof exito !== 'undefined' && exito) { %>
      <div class="tmp-msg-success bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl p-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-emerald-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="text-sm font-medium"><%= exito %></span>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="tmp-msg-error bg-red-50 border border-red-200 text-red-700 rounded-xl p-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="text-sm font-medium"><%= error %></span>
      </div>
    <% } %>

    <!-- Formulario -->
    <form action="/admin/temporizador" method="POST"
          class="tmp-form bg-white rounded-xl p-5 border border-slate-100 space-y-5">

      <!-- Configuraciones Existentes -->
      <div class="space-y-4">
        <h2 class="tmp-section-title text-base font-bold text-slate-700">Configuraciones Actuales</h2>

        <% if (configs.length === 0) { %>
          <div class="tmp-empty text-center py-6 text-slate-400">
            <p class="text-sm">No hay configuraciones de temporizador.</p>
            <p class="text-xs">Agrega una nueva configuración abajo.</p>
          </div>
        <% } else { %>
          <% configs.forEach(function(config, index) { %>
            <div class="flex flex-wrap items-end gap-3 p-4 rounded-xl border <%= config.activo ? 'tmp-config-card border-slate-200' : 'tmp-config-card-inactive border-red-200 bg-red-50/30' %>">
              <input type="hidden" name="configs[<%= index %>][id]" value="<%= config.id %>">

              <div class="flex-1 min-w-[90px]">
                <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Desde Nivel</label>
                <input type="number" name="configs[<%= index %>][nivel_desde]" value="<%= config.nivel_desde %>" min="1"
                       class="tmp-input w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
              </div>
              <div class="flex-1 min-w-[90px]">
                <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Hasta Nivel</label>
                <input type="number" name="configs[<%= index %>][nivel_hasta]" value="<%= config.nivel_hasta %>" min="1"
                       class="tmp-input w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
              </div>
              <div class="flex-1 min-w-[90px]">
                <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Tiempo (seg)</label>
                <input type="number" name="configs[<%= index %>][tiempo_segundos]" value="<%= config.tiempo_segundos %>" min="5" max="300"
                       class="tmp-input w-full p-2.5 rounded-lg border border-slate-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
              </div>
              <div class="flex items-center gap-1.5 pb-2">
                <input type="checkbox" name="configs[<%= index %>][activo]" id="activo_<%= index %>"
                       <%= config.activo ? 'checked' : '' %>
                       class="tmp-checkbox w-4 h-4 text-amber-500 focus:ring-amber-400 rounded">
                <label for="activo_<%= index %>" class="tmp-checkbox-label text-xs font-medium text-slate-600 cursor-pointer">Activo</label>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- Nueva Configuración -->
      <div class="tmp-divider border-t border-slate-100 pt-5">
        <h2 class="tmp-section-title text-base font-bold text-slate-700 mb-3">Agregar Nueva Configuración</h2>
        <div class="tmp-new-card flex flex-wrap items-end gap-3 p-4 rounded-xl border border-dashed border-amber-300 bg-amber-50/30">
          <div class="flex-1 min-w-[90px]">
            <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Desde Nivel</label>
            <input type="number" name="nueva_nivel_desde" min="1" placeholder="1"
                   class="tmp-input w-full p-2.5 rounded-lg border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
          </div>
          <div class="flex-1 min-w-[90px]">
            <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Hasta Nivel</label>
            <input type="number" name="nueva_nivel_hasta" min="1" placeholder="99"
                   class="tmp-input w-full p-2.5 rounded-lg border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
          </div>
          <div class="flex-1 min-w-[90px]">
            <label class="tmp-label block text-[11px] font-bold text-slate-600 mb-1">Tiempo (seg)</label>
            <input type="number" name="nueva_tiempo_segundos" min="5" max="300" placeholder="30"
                   class="tmp-input w-full p-2.5 rounded-lg border border-amber-200 bg-white text-slate-800 focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-all text-sm">
          </div>
        </div>
      </div>

      <!-- Botones -->
      <div class="tmp-divider flex flex-col sm:flex-row items-stretch sm:items-center justify-between pt-4 border-t border-slate-100 gap-2">
        <a href="/admin"
           class="tmp-btn-back bg-white hover:bg-slate-50 text-slate-600 font-bold py-2.5 px-5 rounded-lg border border-slate-200 transition-all text-center text-xs">
          ← Volver al Dashboard
        </a>
        <button type="submit"
                class="tmp-btn-save bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 px-6 rounded-lg transition-all flex items-center justify-center gap-2 text-xs">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar
        </button>
      </div>
    </form>

    <!-- Vista previa -->
    <div class="tmp-preview mt-6 bg-white rounded-xl p-5 border border-slate-100">
      <h3 class="tmp-preview-title text-sm font-bold text-slate-700 mb-4">Vista previa por nivel</h3>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2">
        <% if (configs.length > 0) { %>
          <% for (var nivel = 1; nivel <= 12; nivel++) { %>
            <% 
              var configMatch = null;
              for (var ci = 0; ci < configs.length; ci++) {
                if (configs[ci].activo && nivel >= configs[ci].nivel_desde && nivel <= configs[ci].nivel_hasta) {
                  configMatch = configs[ci];
                  break;
                }
              }
            %>
            <div class="p-3 rounded-lg text-center <%= configMatch ? 'tmp-preview-card-matched bg-indigo-50 border border-indigo-200' : 'tmp-preview-card bg-slate-50 border border-slate-200' %>">
              <p class="tmp-preview-label text-[10px] font-medium text-slate-500">Nivel <%= nivel %></p>
              <p class="tmp-preview-value text-base font-bold <%= configMatch ? 'text-indigo-600' : 'text-slate-300' %>">
                <%= configMatch ? configMatch.tiempo_segundos + 's' : '—' %>
              </p>
            </div>
          <% } %>
        <% } else { %>
          <p class="tmp-preview-empty text-slate-400 col-span-full text-center py-4 text-xs">No hay configuraciones para mostrar.</p>
        <% } %>
      </div>
    </div>

  </div>
</div>
