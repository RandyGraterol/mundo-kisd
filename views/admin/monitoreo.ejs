<style>
  [data-theme="dark"] .mon-badge { background: rgba(16,185,129,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-title { color: #f1f5f9 !important; }
  [data-theme="dark"] .mon-subtitle { color: #64748b !important; }
  [data-theme="dark"] .mon-stat-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .mon-stat-label { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-stat-value { color: #f1f5f9 !important; }
  [data-theme="dark"] .mon-stat-value-green { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-stat-value-amber { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-search { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .mon-search svg { color: #475569 !important; }
  [data-theme="dark"] .mon-search input { color: #e2e8f0 !important; }
  [data-theme="dark"] .mon-search input::placeholder { color: #64748b !important; }
  [data-theme="dark"] .mon-search select { background-color: #0f172a !important; border-color: #334155 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .mon-search select:focus { border-color: #64748b !important; }
  [data-theme="dark"] .mon-empty { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .mon-empty-icon { background: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .mon-empty-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .mon-empty-text { color: #64748b !important; }
  [data-theme="dark"] .mon-table { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .mon-thead { background-color: #0f172a !important; border-color: #334155 !important; }
  [data-theme="dark"] .mon-th { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-tr { border-color: #1e293b !important; }
  [data-theme="dark"] .mon-tr:hover { background-color: #0f172a !important; }
  [data-theme="dark"] .mon-avatar-m { background-color: rgba(59,130,246,0.2) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-avatar-f { background-color: rgba(236,72,153,0.2) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-name { color: #e2e8f0 !important; }
  [data-theme="dark"] .mon-username { color: #64748b !important; }
  [data-theme="dark"] .mon-level-badge { background: rgba(56,189,248,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-level-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-points { color: #e2e8f0 !important; }
  [data-theme="dark"] .mon-points svg { color: #64748b !important; }
  [data-theme="dark"] .mon-retos { color: #94a3b8 !important; }
  [data-theme="dark"] .mon-status-active { background: rgba(16,185,129,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-status-active .dot { background-color: #94a3b8 !important; }
  [data-theme="dark"] .mon-status-inactive { background: rgba(100,116,139,0.2) !important; color: #64748b !important; }
  [data-theme="dark"] .mon-status-inactive .dot { background-color: #475569 !important; }
  [data-theme="dark"] .mon-last-access { color: #64748b !important; }
  [data-theme="dark"] .mon-action-btn { background: rgba(99,102,241,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .mon-action-btn:hover { background: rgba(99,102,241,0.25) !important; color: #e2e8f0 !important; }
</style>

<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-6">
      <div class="mon-badge inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-xs font-bold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Monitoreo
      </div>
      <h1 class="mon-title text-2xl font-extrabold text-slate-900">Mis Estudiantes</h1>
      <p class="mon-subtitle text-slate-500 text-xs mt-0.5">Supervisa el progreso de todos tus estudiantes.</p>
    </div>

    <!-- Resumen -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="mon-stat-card bg-white rounded-xl p-4 border border-slate-100">
        <p class="mon-stat-label text-[11px] text-slate-500 font-medium">Total Estudiantes</p>
        <p class="mon-stat-value text-xl font-bold text-slate-900"><%= alumnos.length %></p>
      </div>
      <div class="mon-stat-card bg-white rounded-xl p-4 border border-slate-100">
        <p class="mon-stat-label text-[11px] text-slate-500 font-medium">Activos</p>
        <p class="mon-stat-value-green text-xl font-bold text-emerald-600"><%= alumnos.filter(a => a.esActivo).length %></p>
      </div>
      <div class="mon-stat-card bg-white rounded-xl p-4 border border-slate-100">
        <p class="mon-stat-label text-[11px] text-slate-500 font-medium">Inactivos (>7 días)</p>
        <p class="mon-stat-value text-xl font-bold text-slate-400"><%= alumnos.filter(a => !a.esActivo).length %></p>
      </div>
      <div class="mon-stat-card bg-white rounded-xl p-4 border border-slate-100">
        <p class="mon-stat-label text-[11px] text-slate-500 font-medium">Mejor Puntaje</p>
        <p class="mon-stat-value-amber text-xl font-bold text-amber-600">
          <%= alumnos.length > 0 ? Math.max(...alumnos.map(a => a.puntos_total)) : 0 %>
        </p>
      </div>
    </div>

    <!-- Filtros avanzados -->
    <div class="mon-search bg-white rounded-xl p-3 border border-slate-100 mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="flex items-center gap-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="buscador" onkeyup="filtrar()" placeholder="Buscar estudiante..."
                 class="flex-1 bg-transparent border-none text-slate-800 placeholder-slate-400 focus:outline-none text-sm">
        </div>
        <select id="filtro-nivel" onchange="filtrar()"
                class="w-full p-2 rounded-lg border border-slate-200 bg-white text-slate-800 text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
          <option value="">Todos los niveles</option>
          <% var niveles = [...new Set(alumnos.map(a => a.nivel))].sort(); %>
          <% niveles.forEach(function(n) { %>
            <option value="<%= n %>">Nivel <%= n %></option>
          <% }); %>
        </select>
        <select id="filtro-estado" onchange="filtrar()"
                class="w-full p-2 rounded-lg border border-slate-200 bg-white text-slate-800 text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
          <option value="">Todos los estados</option>
          <option value="activo">Activo</option>
          <option value="inactivo">Inactivo</option>
        </select>
        <select id="filtro-genero" onchange="filtrar()"
                class="w-full p-2 rounded-lg border border-slate-200 bg-white text-slate-800 text-sm focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
          <option value="">Todos los géneros</option>
          <option value="masculino">Niño</option>
          <option value="femenino">Niña</option>
        </select>
      </div>
    </div>

    <% if (alumnos.length === 0) { %>
      <div class="mon-empty bg-white rounded-xl p-8 border border-slate-100 text-center">
        <div class="mon-empty-icon inline-flex items-center justify-center w-12 h-12 rounded-xl bg-emerald-100 text-emerald-600 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="mon-empty-title text-lg font-bold text-slate-700 mb-1">No hay estudiantes registrados</h3>
        <p class="mon-empty-text text-slate-400 text-sm">Los estudiantes aparecerán aquí cuando se registren.</p>
      </div>
    <% } else { %>
      <!-- Tabla -->
      <div class="mon-table bg-white rounded-xl overflow-hidden border border-slate-100">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="mon-thead bg-slate-50 border-b border-slate-200">
                <th class="mon-th text-left px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider">Estudiante</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider hidden sm:table-cell">Nivel</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider">Puntos</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider hidden sm:table-cell">Retos</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider">Estado</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider hidden md:table-cell">Último Acceso</th>
                <th class="mon-th text-center px-4 py-3 text-[11px] font-bold text-slate-600 uppercase tracking-wider"></th>
              </tr>
            </thead>
            <tbody>
              <% alumnos.forEach(function(alumno) { %>
                <tr class="mon-tr alumno-row border-b border-slate-100 hover:bg-slate-50 transition-all"
                    data-nombre="<%= alumno.nombre_completo.toLowerCase() %>"
                    data-nivel="<%= alumno.nivel %>"
                    data-estado="<%= alumno.esActivo ? 'activo' : 'inactivo' %>"
                    data-genero="<%= alumno.genero %>">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <div class="<%= alumno.genero === 'femenino' ? 'mon-avatar-f bg-pink-100 text-pink-600' : 'mon-avatar-m bg-blue-100 text-blue-600' %> w-9 h-9 rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                        <%= alumno.nombre_completo.charAt(0).toUpperCase() %>
                      </div>
                      <div class="min-w-0">
                        <p class="mon-name font-bold text-slate-800 text-sm truncate"><%= alumno.nombre_completo %></p>
                        <p class="mon-username text-[11px] text-slate-400 truncate">@<%= alumno.nombre_usuario %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-center hidden sm:table-cell">
                    <span class="mon-level-badge inline-flex items-center gap-1 bg-sky-100 text-sky-700 px-2.5 py-1 rounded-full text-[11px] font-bold">
                      <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                      <%= alumno.nivel %>
                    </span>
                  </td>
                  <td class="mon-points px-4 py-3 text-center font-bold text-sm text-slate-800">
                    <svg class="w-3.5 h-3.5 inline -mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <%= alumno.puntos_total %>
                  </td>
                  <td class="mon-retos px-4 py-3 text-center text-sm text-slate-600 font-medium hidden sm:table-cell"><%= alumno.totalRetos %></td>
                  <td class="px-4 py-3 text-center">
                    <% if (alumno.esActivo) { %>
                      <span class="mon-status-active inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-700 px-2.5 py-1 rounded-full text-[10px] font-bold">
                        <span class="dot w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                        <span class="hidden sm:inline">Activo</span>
                      </span>
                    <% } else { %>
                      <span class="mon-status-inactive inline-flex items-center gap-1.5 bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full text-[10px] font-bold">
                        <span class="dot w-1.5 h-1.5 bg-slate-400 rounded-full"></span>
                        <span class="hidden sm:inline">Inactivo</span>
                      </span>
                    <% } %>
                  </td>
                  <td class="mon-last-access px-4 py-3 text-center text-xs text-slate-500 hidden md:table-cell">
                    <%= new Date(alumno.ultimo_acceso).toLocaleDateString() %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <a href="/admin/monitoreo/<%= alumno.id %>"
                       class="mon-action-btn inline-flex items-center gap-1.5 bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-3 py-1.5 rounded-lg text-[11px] font-bold transition-all">
                      <span class="hidden sm:inline">Detalle</span>
                      <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>
</div>

<script>
function filtrar() {
  var query = document.getElementById('buscador').value.toLowerCase();
  var nivel = document.getElementById('filtro-nivel').value;
  var estado = document.getElementById('filtro-estado').value;
  var genero = document.getElementById('filtro-genero').value;
  document.querySelectorAll('.alumno-row').forEach(function(row) {
    var nombre = row.dataset.nombre;
    var cumpleNombre = nombre.includes(query);
    var cumpleNivel = !nivel || row.dataset.nivel === nivel;
    var cumpleEstado = !estado || row.dataset.estado === estado;
    var cumpleGenero = !genero || row.dataset.genero === genero;
    row.style.display = (cumpleNombre && cumpleNivel && cumpleEstado && cumpleGenero) ? '' : 'none';
  });
}
</script>
