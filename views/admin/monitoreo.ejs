<div class="min-h-screen p-responsive-main animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-6 sm:mb-8 md:mb-10">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Monitoreo
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">Mis Alumnos</h1>
      <p class="text-slate-500 mt-1 text-sm sm:text-base">Supervisa el progreso y rendimiento de todos tus alumnos.</p>
    </div>

    <!-- Resumen rápido -->
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-responsive-desk mb-responsive">
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Total Alumnos</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-900"><%= alumnos.length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Activos</p>
        <p class="text-xl sm:text-2xl font-bold text-emerald-600"><%= alumnos.filter(a => a.esActivo).length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Inactivos (>7 días)</p>
        <p class="text-xl sm:text-2xl font-bold text-slate-400"><%= alumnos.filter(a => !a.esActivo).length %></p>
      </div>
      <div class="bg-white rounded-xl p-3 sm:p-4 soft-shadow border border-slate-100">
        <p class="text-xs text-slate-500 font-medium">Mejor Puntaje</p>
        <p class="text-xl sm:text-2xl font-bold text-amber-600">
          <%= alumnos.length > 0 ? Math.max(...alumnos.map(a => a.puntos_total)) : 0 %>
        </p>
      </div>
    </div>

    <!-- Buscador -->
    <div class="bg-white rounded-2xl p-4 sm:p-5 soft-shadow border border-slate-100 mb-responsive">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="buscador" onkeyup="buscarAlumno()" placeholder="Buscar alumno..."
               class="flex-1 p-2 bg-transparent border-none text-slate-800 placeholder-slate-400 focus:outline-none text-base sm:text-lg">
      </div>
    </div>

    <% if (alumnos.length === 0) { %>
      <div class="bg-white rounded-2xl p-6 sm:p-12 soft-shadow border border-slate-100 text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-emerald-100 text-emerald-600 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-700 mb-2">No hay alumnos registrados</h3>
        <p class="text-slate-400">Los alumnos aparecerán aquí cuando se registren en la plataforma.</p>
      </div>
    <% } else { %>
      <!-- Tabla de Alumnos -->
      <div class="bg-white rounded-2xl overflow-hidden soft-shadow border border-slate-100">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left p-3 sm:p-4 text-sm font-bold text-slate-600">Alumno</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden sm:table-cell">Nivel</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600">Puntos</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden sm:table-cell">Retos</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600">Estado</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600 hidden md:table-cell">Último Acceso</th>
                <th class="text-center p-3 sm:p-4 text-sm font-bold text-slate-600"></th>
              </tr>
            </thead>
            <tbody>
              <% alumnos.forEach(function(alumno) { %>
                <tr class="alumno-row border-b border-slate-100 hover:bg-slate-50 transition-all"
                    data-nombre="<%= alumno.nombre_completo.toLowerCase() %>">
                  <td class="p-3 sm:p-4">
                    <div class="flex items-center gap-responsive-sm">
                      <div class="w-9 h-9 sm:w-10 sm:h-10 <%= alumno.genero === 'femenino' ? 'bg-pink-100 text-pink-600' : 'bg-blue-100 text-blue-600' %> rounded-full flex items-center justify-center font-bold text-base sm:text-lg flex-shrink-0">
                        <%= alumno.nombre_completo.charAt(0).toUpperCase() %>
                      </div>
                      <div class="min-w-0">
                        <p class="font-bold text-slate-800 text-sm sm:text-base truncate"><%= alumno.nombre_completo %></p>
                        <p class="text-xs text-slate-400 truncate">@<%= alumno.nombre_usuario %></p>
                      </div>
                    </div>
                  </td>
                  <td class="p-3 sm:p-4 text-center hidden sm:table-cell">
                    <span class="inline-flex items-center gap-1 bg-sky-100 text-sky-700 px-2.5 sm:px-3 py-1 rounded-full text-xs sm:text-sm font-bold">
                      <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                      <%= alumno.nivel %>
                    </span>
                  </td>
                  <td class="p-3 sm:p-4 text-center font-bold text-base sm:text-lg text-slate-800 items-center justify-center gap-1">
                    <svg class="w-4 h-4 sm:w-5 sm:h-5 inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <%= alumno.puntos_total %>
                  </td>
                  <td class="p-3 sm:p-4 text-center hidden sm:table-cell">
                    <span class="text-slate-600 font-medium text-sm"><%= alumno.totalRetos %></span>
                  </td>
                  <td class="p-3 sm:p-4 text-center">
                    <% if (alumno.esActivo) { %>
                      <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-2 sm:px-3 py-1 rounded-full text-xs font-bold">
                        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-emerald-500 rounded-full"></span>
                        <span class="hidden sm:inline">Activo</span>
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 px-2 sm:px-3 py-1 rounded-full text-xs font-bold">
                        <span class="w-1.5 h-1.5 sm:w-2 sm:h-2 bg-slate-400 rounded-full"></span>
                        <span class="hidden sm:inline">Inactivo</span>
                      </span>
                    <% } %>
                  </td>
                  <td class="p-3 sm:p-4 text-center text-sm text-slate-500 hidden md:table-cell">
                    <%= new Date(alumno.ultimo_acceso).toLocaleDateString() %>
                  </td>
                  <td class="p-3 sm:p-4 text-center">
                    <a href="/admin/monitoreo/<%= alumno.id %>"
                       class="inline-flex items-center gap-1 bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-responsive-main py-2 rounded-xl text-xs sm:text-sm font-bold transition-all">
                      <span class="hidden sm:inline">Ver Detalle</span>
                      <svg class="sm:hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      <svg class="hidden sm:block" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>
</div>

<script>
function buscarAlumno() {
  var query = document.getElementById('buscador').value.toLowerCase();
  document.querySelectorAll('.alumno-row').forEach(function(row) {
    var nombre = row.dataset.nombre;
    row.style.display = nombre.includes(query) ? '' : 'none';
  });
}
</script>
