<div class="min-h-screen bg-white p-responsive-main animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- ═══ HEADER MEJORADO ═══ -->
    <div class="bg-gradient-to-r from-sky-50 to-indigo-50 rounded-[1.75rem] p-6 sm:p-8 mb-8 border border-sky-100 shadow-xl animate-slide-in">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-responsive-main py-1.5 rounded-full text-xs sm:text-sm font-semibold mb-2">
            <%- icono('dashboard', 'w-4 h-4') %>
            Panel del Profesor
          </div>
          <h1 class="text-responsive-4xl sm:text-4xl font-extrabold text-slate-900">¡Bienvenido, <%= nombreUsuario %>!</h1>
          <p class="text-slate-500 mt-1 text-sm">Gestiona tu aula y supervisa el progreso de tus alumnos.</p>
        </div>
        <div class="flex items-center gap-3 w-full sm:w-auto">
          <a href="/admin/exportar/csv"
             class="flex-1 sm:flex-initial bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2.5 px-5 rounded-xl transition-all shadow-md hover:shadow-lg flex items-center justify-center gap-2 transform hover:scale-[1.02] active:scale-[0.98] text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportar CSV
          </a>
          <a href="/menu"
             class="flex-1 sm:flex-initial bg-white hover:bg-slate-50 text-slate-600 font-semibold py-2.5 px-5 rounded-xl transition-all border border-gray-200 shadow-md hover:shadow-lg text-center transform hover:scale-[1.02] active:scale-[0.98] text-sm">
            ← Volver
          </a>
        </div>
      </div>
    </div>

    <!-- ═══ TARJETAS DE ESTADÍSTICAS ═══ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-responsive-fluid mb-8">

      <div class="bg-white rounded-[1.75rem] p-5 sm:p-6 border border-gray-100 shadow-xl animate-fade-in hover:border-indigo-200 transition-all" style="animation-delay: 0.1s">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 shrink-0">
            <%- icono('usuarios', 'w-6 h-6') %>
          </div>
          <div class="min-w-0">
            <p class="text-xs sm:text-sm text-slate-500 font-medium">Total Alumnos</p>
            <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= totalAlumnos %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-[1.75rem] p-5 sm:p-6 border border-gray-100 shadow-xl animate-fade-in hover:border-emerald-200 transition-all" style="animation-delay: 0.15s">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center text-emerald-600 shrink-0">
            <%- icono('lapiz', 'w-6 h-6') %>
          </div>
          <div class="min-w-0">
            <p class="text-xs sm:text-sm text-slate-500 font-medium">Preguntas Activas</p>
            <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= totalPreguntasActivas %></p>
            <p class="text-xs text-slate-400"><%= totalPreguntas %> totales</p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-[1.75rem] p-5 sm:p-6 border border-gray-100 shadow-xl animate-fade-in hover:border-amber-200 transition-all" style="animation-delay: 0.2s">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600 shrink-0">
            <%- icono('trofeo', 'w-6 h-6') %>
          </div>
          <div class="min-w-0">
            <p class="text-xs sm:text-sm text-slate-500 font-medium">Puntos Promedio</p>
            <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= puntosPromedio %></p>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-[1.75rem] p-5 sm:p-6 border border-gray-100 shadow-xl animate-fade-in hover:border-sky-200 transition-all" style="animation-delay: 0.25s">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-sky-100 rounded-xl flex items-center justify-center text-sky-600 shrink-0">
            <%- icono('reloj', 'w-6 h-6') %>
          </div>
          <div class="min-w-0">
            <p class="text-xs sm:text-sm text-slate-500 font-medium">Activos (7 días)</p>
            <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= alumnosActivos %></p>
          </div>
        </div>
      </div>

    </div>

    <!-- ═══ GRID: ACCESO RÁPIDO + ALUMNOS RECIENTES ═══ -->
    <div class="grid lg:grid-cols-2 gap-4 sm:gap-responsive-desk-lg">

      <!-- ─── ACCESO RÁPIDO ─── -->
      <div class="space-y-3 animate-fade-in" style="animation-delay: 0.3s">
        <h2 class="text-lg sm:text-xl font-bold text-slate-800 flex items-center gap-2">
          <div class="p-1.5 bg-indigo-100 rounded-lg text-indigo-600">
            <%- icono('dashboard', 'w-5 h-5') %>
          </div>
          Acceso Rápido
        </h2>

        <a href="/admin/contenido"
           class="group flex items-center gap-responsive-md bg-white rounded-[1.75rem] p-4 sm:p-5 border border-gray-100 shadow-md hover:border-indigo-200 hover:-translate-y-0.5 transition-all">
          <div class="w-12 h-12 sm:w-14 sm:h-14 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 group-hover:bg-indigo-500 group-hover:text-white transition-all shrink-0">
            <%- icono('lapiz', 'w-6 h-6 sm:w-7 sm:h-7') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base sm:text-lg font-bold text-slate-800">Gestor de Contenido</h3>
            <p class="text-xs sm:text-sm text-slate-500">Crea, edita y administra preguntas personalizadas.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-indigo-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a href="/admin/temporizador"
           class="group flex items-center gap-responsive-md bg-white rounded-[1.75rem] p-4 sm:p-5 border border-gray-100 shadow-md hover:border-amber-200 hover:-translate-y-0.5 transition-all">
          <div class="w-12 h-12 sm:w-14 sm:h-14 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-all shrink-0">
            <%- icono('reloj', 'w-6 h-6 sm:w-7 sm:h-7') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base sm:text-lg font-bold text-slate-800">Temporizador</h3>
            <p class="text-xs sm:text-sm text-slate-500">Configura los tiempos de respuesta por nivel.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-amber-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a href="/admin/monitoreo"
           class="group flex items-center gap-responsive-md bg-white rounded-[1.75rem] p-4 sm:p-5 border border-gray-100 shadow-md hover:border-emerald-200 hover:-translate-y-0.5 transition-all">
          <div class="w-12 h-12 sm:w-14 sm:h-14 bg-emerald-100 rounded-xl flex items-center justify-center text-emerald-600 group-hover:bg-emerald-500 group-hover:text-white transition-all shrink-0">
            <%- icono('profesor', 'w-6 h-6 sm:w-7 sm:h-7') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base sm:text-lg font-bold text-slate-800">Monitoreo de Alumnos</h3>
            <p class="text-xs sm:text-sm text-slate-500">Supervisa el rendimiento y progreso de cada alumno.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-emerald-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- ─── ALUMNOS RECIENTES ─── -->
      <div class="animate-fade-in" style="animation-delay: 0.35s">
        <h2 class="text-lg sm:text-xl font-bold text-slate-800 flex items-center gap-2 mb-3">
          <div class="p-1.5 bg-sky-100 rounded-lg text-sky-600">
            <%- icono('usuarios', 'w-5 h-5') %>
          </div>
          Alumnos Recientes
        </h2>

        <% if (alumnosRecientes.length === 0) { %>
          <div class="bg-white rounded-[1.75rem] p-8 border border-gray-100 shadow-xl text-center">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-sky-100 text-sky-600 mb-4">
              <%- icono('usuario', 'w-7 h-7') %>
            </div>
            <p class="text-slate-500 font-medium">No hay alumnos registrados aún.</p>
            <p class="text-slate-400 text-sm mt-1">¡Invita a tus alumnos a registrarse!</p>
          </div>
        <% } else { %>
          <div class="space-y-2">
            <% alumnosRecientes.forEach(function(alumno) { %>
              <a href="/admin/monitoreo/<%= alumno.id %>"
                 class="flex items-center justify-between bg-white rounded-[1.25rem] p-3 sm:p-4 border border-gray-100 shadow-md hover:border-sky-200 hover:-translate-y-0.5 transition-all">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-10 h-10 sm:w-11 sm:h-11 rounded-full overflow-hidden bg-white shadow-sm border-2 border-white ring-1 ring-sky-100 shrink-0">
                    <% if (alumno.genero === 'masculino') { %>
                      <img src="/images/avatar-nino.svg" alt="Avatar" class="w-full h-full object-contain">
                    <% } else { %>
                      <img src="/images/avatar-nina.svg" alt="Avatar" class="w-full h-full object-contain">
                    <% } %>
                  </div>
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-800 text-sm sm:text-base truncate"><%= alumno.nombre_completo %></p>
                    <p class="text-xs text-slate-400 flex items-center gap-1">
                      <%- icono('trofeo', 'w-3 h-3 text-amber-400') %>
                      Nivel <%= alumno.nivel %> · <%= alumno.puntos_total %> pts
                    </p>
                  </div>
                </div>
                <div class="text-right shrink-0 ml-2">
                  <p class="text-xs text-slate-400 whitespace-nowrap">
                    <%= new Date(alumno.ultimo_acceso).toLocaleDateString() %>
                  </p>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>

    </div>

    <!-- ═══ CONFIGURACIÓN DE TIEMPOS ═══ -->
    <div class="mt-6 sm:mt-8 md:mt-10 animate-fade-in" style="animation-delay: 0.4s">
      <h2 class="text-lg sm:text-xl font-bold text-slate-800 flex items-center gap-2 mb-3 sm:mb-4">
        <div class="p-1.5 bg-amber-100 rounded-lg text-amber-600">
          <%- icono('cronometro', 'w-5 h-5') %>
        </div>
        Configuración de Tiempos Actual
      </h2>

      <div class="bg-white rounded-[1.75rem] p-5 sm:p-6 border border-gray-100 shadow-xl">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-responsive-main md:gap-5">
          <% configs.forEach(function(config) { %>
            <div class="<%= config.activo ? 'bg-indigo-50 border-indigo-200' : 'bg-slate-50 border-slate-200' %> rounded-[1.25rem] p-4 border text-center hover:scale-[1.03] transition-all duration-200">
              <p class="text-xs sm:text-sm font-medium text-slate-500">Niveles</p>
              <p class="text-base sm:text-lg font-bold text-slate-600"><%= config.nivel_desde %>-<%= config.nivel_hasta %></p>
              <p class="text-2xl sm:text-3xl font-bold <%= config.activo ? 'text-indigo-600' : 'text-slate-400' %> mt-1"><%= config.tiempo_segundos %>s</p>
              <% if (!config.activo) { %>
                <span class="inline-block text-xs text-slate-400 bg-white px-2 py-0.5 rounded-full mt-1">Inactivo</span>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div>
</div>
