<style>
  [data-theme="dark"] .dash-header { background: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-header h1 { color: #f1f5f9 !important; }
  [data-theme="dark"] .dash-header p { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-badge { background: rgba(99,102,241,0.15) !important; color: #94a3b8 !important; }
  [data-theme="dark"] .dash-badge svg { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-btn-export { background-color: #475569 !important; }
  [data-theme="dark"] .dash-btn-export:hover { background-color: #64748b !important; }
  [data-theme="dark"] .dash-btn-back { background-color: #1e293b !important; border-color: #334155 !important; color: #94a3b8 !important; }
  [data-theme="dark"] .dash-btn-back:hover { background-color: #0f172a !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-stat-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-stat-card:hover { border-color: #475569 !important; }
  [data-theme="dark"] .dash-stat-icon { background-color: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .dash-stat-label { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-stat-value { color: #f1f5f9 !important; }
  [data-theme="dark"] .dash-stat-sub { color: #64748b !important; }
  [data-theme="dark"] .dash-section-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-section-icon { background: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .dash-quick-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-quick-card:hover { border-color: #475569 !important; }
  [data-theme="dark"] .dash-quick-icon { background-color: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .dash-quick-icon:hover { background-color: #475569 !important; color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-quick-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-quick-desc { color: #64748b !important; }
  [data-theme="dark"] .dash-quick-arrow { color: #475569 !important; }
  [data-theme="dark"] .dash-quick-arrow:hover { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-empty-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-empty-icon { background: #0f172a !important; color: #64748b !important; }
  [data-theme="dark"] .dash-empty-title { color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-empty-text { color: #64748b !important; }
  [data-theme="dark"] .dash-student-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-student-card:hover { border-color: #475569 !important; }
  [data-theme="dark"] .dash-student-name { color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-student-meta { color: #64748b !important; }
  [data-theme="dark"] .dash-student-date { color: #64748b !important; }
  [data-theme="dark"] .dash-config-card { background-color: #1e293b !important; border-color: #334155 !important; }
  [data-theme="dark"] .dash-config-card-matched { background: #0f172a !important; border-color: #475569 !important; }
  [data-theme="dark"] .dash-config-label { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-config-range { color: #e2e8f0 !important; }
  [data-theme="dark"] .dash-config-time { color: #94a3b8 !important; }
  [data-theme="dark"] .dash-config-inactive { color: #64748b !important; }
  [data-theme="dark"] .dash-config-inactive-badge { background: #0f172a !important; color: #64748b !important; }
</style>

<div class="min-h-screen p-4 sm:p-6 animate-fade-in">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="dash-header bg-gradient-to-r from-sky-50 to-indigo-50 rounded-xl p-5 mb-6 border border-sky-100 animate-slide-in">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
        <div>
          <div class="dash-badge inline-flex items-center gap-1.5 bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-[11px] font-bold mb-2">
            <%- icono('dashboard', 'w-3.5 h-3.5') %>
            Panel del Profesor
          </div>
          <h1 class="text-xl font-extrabold text-slate-900">¡Bienvenido, <%= nombreUsuario %>!</h1>
          <p class="text-slate-500 text-xs mt-0.5">Gestiona tu aula y supervisa el progreso.</p>
        </div>
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <a href="/admin/exportar/csv"
             class="dash-btn-export flex-1 sm:flex-initial bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded-lg transition-all flex items-center justify-center gap-1.5 text-xs">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Exportar CSV
          </a>
          <a href="/menu"
             class="dash-btn-back flex-1 sm:flex-initial bg-white hover:bg-slate-50 text-slate-600 font-semibold py-2 px-4 rounded-lg transition-all border border-gray-200 text-center text-xs">
            ← Volver
          </a>
        </div>
      </div>
    </div>

    <!-- Estadísticas -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
      <div class="dash-stat-card bg-white rounded-xl p-4 border border-gray-100 hover:border-indigo-200 transition-all">
        <div class="flex items-center gap-3">
          <div class="dash-stat-icon w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600 shrink-0">
            <%- icono('usuarios', 'w-5 h-5') %>
          </div>
          <div class="min-w-0">
            <p class="dash-stat-label text-[11px] text-slate-500 font-medium">Total Estudiantes</p>
            <p class="dash-stat-value text-xl font-bold text-slate-900"><%= totalAlumnos %></p>
          </div>
        </div>
      </div>

      <div class="dash-stat-card bg-white rounded-xl p-4 border border-gray-100 hover:border-emerald-200 transition-all">
        <div class="flex items-center gap-3">
          <div class="dash-stat-icon w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600 shrink-0">
            <%- icono('lapiz', 'w-5 h-5') %>
          </div>
          <div class="min-w-0">
            <p class="dash-stat-label text-[11px] text-slate-500 font-medium">Preguntas Activas</p>
            <p class="dash-stat-value text-xl font-bold text-slate-900"><%= totalPreguntasActivas %></p>
            <p class="dash-stat-sub text-[10px] text-slate-400"><%= totalPreguntas %> totales</p>
          </div>
        </div>
      </div>

      <div class="dash-stat-card bg-white rounded-xl p-4 border border-gray-100 hover:border-amber-200 transition-all">
        <div class="flex items-center gap-3">
          <div class="dash-stat-icon w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600 shrink-0">
            <%- icono('trofeo', 'w-5 h-5') %>
          </div>
          <div class="min-w-0">
            <p class="dash-stat-label text-[11px] text-slate-500 font-medium">Puntos Promedio</p>
            <p class="dash-stat-value text-xl font-bold text-slate-900"><%= puntosPromedio %></p>
          </div>
        </div>
      </div>

      <div class="dash-stat-card bg-white rounded-xl p-4 border border-gray-100 hover:border-sky-200 transition-all">
        <div class="flex items-center gap-3">
          <div class="dash-stat-icon w-10 h-10 bg-sky-100 rounded-lg flex items-center justify-center text-sky-600 shrink-0">
            <%- icono('reloj', 'w-5 h-5') %>
          </div>
          <div class="min-w-0">
            <p class="dash-stat-label text-[11px] text-slate-500 font-medium">Activos (7 días)</p>
            <p class="dash-stat-value text-xl font-bold text-slate-900"><%= alumnosActivos %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Grid: Acceso Rápido + Alumnos Recientes -->
    <div class="grid lg:grid-cols-2 gap-4 mb-6">
      <!-- Acceso Rápido -->
      <div class="space-y-2">
        <h2 class="dash-section-title text-sm font-bold text-slate-800 flex items-center gap-2 mb-3">
          <div class="dash-section-icon p-1.5 bg-indigo-100 rounded-lg text-indigo-600">
            <%- icono('dashboard', 'w-4 h-4') %>
          </div>
          Acceso Rápido
        </h2>

        <a href="/admin/contenido"
           class="dash-quick-card group flex items-center gap-3 bg-white rounded-xl p-4 border border-gray-100 hover:border-indigo-200 hover:-translate-y-0.5 transition-all">
          <div class="dash-quick-icon w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center text-indigo-600 group-hover:bg-indigo-500 group-hover:text-white transition-all shrink-0">
            <%- icono('lapiz', 'w-5 h-5') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="dash-quick-title text-sm font-bold text-slate-800">Gestor de Contenido</h3>
            <p class="dash-quick-desc text-xs text-slate-500">Crea, edita y administra preguntas.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="dash-quick-arrow text-slate-300 group-hover:text-indigo-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a href="/admin/temporizador"
           class="dash-quick-card group flex items-center gap-3 bg-white rounded-xl p-4 border border-gray-100 hover:border-amber-200 hover:-translate-y-0.5 transition-all">
          <div class="dash-quick-icon w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600 group-hover:bg-amber-500 group-hover:text-white transition-all shrink-0">
            <%- icono('reloj', 'w-5 h-5') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="dash-quick-title text-sm font-bold text-slate-800">Temporizador</h3>
            <p class="dash-quick-desc text-xs text-slate-500">Configura tiempos por nivel.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="dash-quick-arrow text-slate-300 group-hover:text-amber-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        <a href="/admin/monitoreo"
           class="dash-quick-card group flex items-center gap-3 bg-white rounded-xl p-4 border border-gray-100 hover:border-emerald-200 hover:-translate-y-0.5 transition-all">
          <div class="dash-quick-icon w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600 group-hover:bg-emerald-500 group-hover:text-white transition-all shrink-0">
            <%- icono('profesor', 'w-5 h-5') %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="dash-quick-title text-sm font-bold text-slate-800">Monitoreo</h3>
            <p class="dash-quick-desc text-xs text-slate-500">Rendimiento de cada estudiante.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="dash-quick-arrow text-slate-300 group-hover:text-emerald-500 transition-all shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Estudiantes Recientes -->
      <div>
        <h2 class="dash-section-title text-sm font-bold text-slate-800 flex items-center gap-2 mb-3">
          <div class="dash-section-icon p-1.5 bg-sky-100 rounded-lg text-sky-600">
            <%- icono('usuarios', 'w-4 h-4') %>
          </div>
          Estudiantes Recientes
        </h2>

        <% if (alumnosRecientes.length === 0) { %>
          <div class="dash-empty-card bg-white rounded-xl p-6 border border-gray-100 text-center">
            <div class="dash-empty-icon inline-flex items-center justify-center w-12 h-12 rounded-lg bg-sky-100 text-sky-600 mb-3">
              <%- icono('usuario', 'w-6 h-6') %>
            </div>
            <p class="dash-empty-title text-slate-500 font-medium text-sm">No hay estudiantes registrados aún.</p>
            <p class="dash-empty-text text-slate-400 text-xs mt-1">Invítalos a registrarse.</p>
          </div>
        <% } else { %>
          <div class="space-y-2">
            <% alumnosRecientes.forEach(function(alumno) { %>
              <a href="/admin/monitoreo/<%= alumno.id %>"
                 class="dash-student-card flex items-center justify-between bg-white rounded-xl p-3 border border-gray-100 hover:border-sky-200 hover:-translate-y-0.5 transition-all">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-9 h-9 rounded-full overflow-hidden bg-white border-2 border-white ring-1 ring-sky-100 shrink-0">
                    <% if (alumno.genero === 'masculino') { %>
                      <img src="/images/avatar-nino.svg" alt="Avatar" class="w-full h-full object-contain">
                    <% } else { %>
                      <img src="/images/avatar-nina.svg" alt="Avatar" class="w-full h-full object-contain">
                    <% } %>
                  </div>
                  <div class="min-w-0">
                    <p class="dash-student-name font-semibold text-slate-800 text-sm truncate"><%= alumno.nombre_completo %></p>
                    <p class="dash-student-meta text-xs text-slate-400 flex items-center gap-1">
                      <%- icono('trofeo', 'w-3 h-3 text-amber-400') %>
                      Nivel <%= alumno.nivel %> · <%= alumno.puntos_total %> pts
                    </p>
                  </div>
                </div>
                <div class="dash-student-date text-right shrink-0 ml-2">
                  <p class="text-[11px] text-slate-400 whitespace-nowrap"><%= new Date(alumno.ultimo_acceso).toLocaleDateString() %></p>
                </div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Configuración de Tiempos -->
    <div class="animate-fade-in">
      <h2 class="dash-section-title text-sm font-bold text-slate-800 flex items-center gap-2 mb-3">
        <div class="dash-section-icon p-1.5 bg-amber-100 rounded-lg text-amber-600">
          <%- icono('cronometro', 'w-4 h-4') %>
        </div>
        Configuración de Tiempos
      </h2>

      <div class="dash-config-card bg-white rounded-xl p-5 border border-gray-100">
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          <% configs.forEach(function(config) { %>
            <div class="<%= config.activo ? 'dash-config-card-matched bg-indigo-50 border-indigo-200' : 'dash-config-card bg-slate-50 border-slate-200' %> rounded-lg p-3 border text-center">
              <p class="dash-config-label text-[10px] font-medium text-slate-500">Niveles</p>
              <p class="dash-config-range text-sm font-bold text-slate-600"><%= config.nivel_desde %>-<%= config.nivel_hasta %></p>
              <p class="dash-config-time text-lg font-bold <%= config.activo ? 'text-indigo-600' : 'text-slate-400' %> mt-0.5"><%= config.tiempo_segundos %>s</p>
              <% if (!config.activo) { %>
                <span class="dash-config-inactive-badge inline-block text-[10px] text-slate-400 bg-white px-2 py-0.5 rounded-full mt-1">Inactivo</span>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div>
</div>
