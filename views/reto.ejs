<div class="min-h-screen flex items-center justify-center p-4 py-12">
  
  <div class="bg-white rounded-3xl shadow-2xl p-8 max-w-3xl w-full border-4 border-cyan-400">
    
    <!-- Encabezado con emoji del continente -->
    <div class="text-center mb-6">
      <div class="text-6xl mb-3"><%= continente.emoji %></div>
      <h2 class="text-3xl font-bold mb-2" style="color: <%= continente.color %>;">
        🎯 Reto: <%= continente.nombre %>
      </h2>
      <p class="text-gray-600 text-lg">¡Responde correctamente para ganar puntos!</p>
    </div>

    <!-- Información de progreso -->
    <div class="bg-cyan-100 rounded-xl p-4 mb-6 flex justify-between items-center">
      <div class="text-center">
        <p class="text-sm text-gray-600">Nivel</p>
        <p class="text-2xl font-bold text-cyan-600">🏆 <%= progreso.nivel %></p>
      </div>
      <div class="text-center">
        <p class="text-sm text-gray-600">Puntos Totales</p>
        <p class="text-2xl font-bold text-cyan-600">⭐ <%= progreso.puntosTotal %></p>
      </div>
      <div class="text-center">
        <p class="text-sm text-gray-600">Pregunta</p>
        <p class="text-2xl font-bold text-cyan-600"><%= preguntaActual + 1 %>/<%= totalPreguntas %></p>
      </div>
    </div>

    <!-- Pregunta actual -->
    <div class="mb-8">
      <div class="bg-gradient-to-r from-purple-100 to-pink-100 rounded-2xl p-6 mb-6">
        <h3 class="text-2xl font-bold text-gray-800 text-center">
          <%= pregunta.pregunta %>
        </h3>
      </div>

      <!-- Opciones de respuesta -->
      <form method="POST" action="/reto/<%= continente.id %>/responder">
        <input type="hidden" name="preguntaIndex" value="<%= preguntaActual %>">
        <input type="hidden" name="preguntaId" value="<%= pregunta.id %>">
        
        <div class="space-y-3">
          <% pregunta.opciones.forEach((opcion, index) => { %>
            <label class="block">
              <input type="radio" name="respuesta" value="<%= index %>" class="hidden peer" required>
              <div class="bg-white border-4 border-gray-300 rounded-xl p-4 cursor-pointer hover:border-cyan-400 hover:bg-cyan-50 transition-all peer-checked:border-cyan-500 peer-checked:bg-cyan-100 peer-checked:shadow-lg">
                <p class="text-lg font-semibold text-gray-700">
                  <span class="inline-block w-8 h-8 bg-cyan-400 text-white rounded-full text-center leading-8 mr-3">
                    <%= String.fromCharCode(65 + index) %>
                  </span>
                  <%= opcion %>
                </p>
              </div>
            </label>
          <% }); %>
        </div>

        <!-- Botón enviar -->
        <div class="text-center mt-8">
          <button type="submit" 
                  class="bg-green-500 hover:bg-green-600 text-white font-bold text-xl py-4 px-12 rounded-full shadow-lg hover:shadow-2xl transition-all transform hover:scale-105">
            ✅ Responder
          </button>
        </div>
      </form>
    </div>

    <!-- Botón volver -->
    <div class="text-center mt-6">
      <a href="/continente/<%= continente.id %>" 
         class="inline-block text-gray-600 hover:text-gray-800 font-semibold underline">
        ← Volver a la información del continente
      </a>
    </div>

  </div>

</div>
