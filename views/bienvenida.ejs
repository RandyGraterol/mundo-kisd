<div class="min-h-screen bg-white flex items-center justify-center px-4 py-8 animate-fade-in">
  <div class="w-full max-w-lg">
    
    <!-- Logo y título mejorado -->
    <div class="text-center mb-8 animate-slide-in">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-sky-100 rounded-3xl text-sky-500 shadow-inner mb-4">
        <%- icono('continentes', 'w-10 h-10') %>
      </div>
      <h1 class="text-responsive-4xl font-extrabold text-gray-900 tracking-tight mb-1">Mundo <span class="text-sky-500">Kids</span></h1>
      <p class="text-gray-400 text-sm sm:text-base font-medium">Explora el mundo con diversión</p>
    </div>

    <!-- Card principal -->
    <div class="bg-white rounded-[1.75rem] shadow-xl p-6 sm:p-8 border border-gray-100 animate-fade-in" style="animation-delay: 0.1s">
      
      <!-- Opciones de acceso -->
      <div class="space-y-3 mb-8 animate-fade-in" style="animation-delay: 0.15s">
        <p class="text-gray-600 font-semibold text-base text-center">Elige cómo quieres entrar</p>
        
        <div class="grid grid-cols-2 gap-3">
          <a href="/auth/login" 
            class="flex items-center justify-center gap-2 py-3.5 px-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold text-sm sm:text-base rounded-xl hover:from-blue-600 hover:to-blue-700 transform hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 shadow-md hover:shadow-lg">
            <%- icono('inicio_sesion', 'w-4 h-4 sm:w-5 sm:h-5') %> <span class="hidden sm:inline">Iniciar Sesión</span><span class="sm:hidden">Entrar</span>
          </a>
          
          <a href="/auth/registro" 
            class="flex items-center justify-center gap-2 py-3.5 px-4 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-bold text-sm sm:text-base rounded-xl hover:from-green-600 hover:to-emerald-700 transform hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 shadow-md hover:shadow-lg">
            <%- icono('registro', 'w-4 h-4 sm:w-5 sm:h-5') %> <span class="hidden sm:inline">Crear Cuenta</span><span class="sm:hidden">Registro</span>
          </a>
        </div>
      </div>

      <!-- Divisor -->
      <div class="flex items-center gap-4 mb-6 animate-fade-in" style="animation-delay: 0.2s">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
        <span class="text-gray-400 text-xs font-medium px-2">O entra rápido</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
      </div>

      <!-- Formulario rápido (sin registro) -->
      <form action="/menu" method="POST" class="space-y-6" id="registroForm" novalidate>
        
        <!-- Selección de Avatar -->
        <div class="space-y-3 animate-fade-in" style="animation-delay: 0.25s">
          <p class="text-gray-600 font-semibold text-center text-sm sm:text-base">Elige tu avatar</p>
          
          <div class="flex justify-center gap-5 sm:gap-8">
            
            <!-- Niño avatar -->
            <label class="avatar-option group cursor-pointer" id="avatar-nino">
              <input type="radio" name="genero" value="masculino" required class="sr-only">
              <div class="flex flex-col items-center gap-2 transition-all duration-200">
                <div class="w-22 h-22 sm:w-24 sm:h-24 rounded-2xl bg-gray-50 shadow-sm flex items-center justify-center border-2 border-transparent transition-all duration-200 group-hover:border-sky-300 group-hover:bg-sky-50 group-[.selected]:border-sky-500 group-[.selected]:bg-sky-50 group-[.selected]:shadow-md p-2">
                  <img src="/images/avatar-nino.svg" alt="Avatar niño" class="w-full h-full object-contain drop-shadow-sm group-[.selected]:scale-105 transition-transform duration-200">
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-sky-400 opacity-0 group-[.selected]:opacity-100 transition-opacity duration-200"></span>
                  <p class="text-sm font-bold text-gray-500 group-[.selected]:text-sky-600 transition-colors duration-200">Explorador</p>
                </div>
              </div>
            </label>

            <!-- Niña avatar -->
            <label class="avatar-option group cursor-pointer" id="avatar-nina">
              <input type="radio" name="genero" value="femenino" required class="sr-only">
              <div class="flex flex-col items-center gap-2 transition-all duration-200">
                <div class="w-22 h-22 sm:w-24 sm:h-24 rounded-2xl bg-gray-50 shadow-sm flex items-center justify-center border-2 border-transparent transition-all duration-200 group-hover:border-pink-300 group-hover:bg-pink-50 group-[.selected]:border-pink-400 group-[.selected]:bg-pink-50 group-[.selected]:shadow-md p-2">
                  <img src="/images/avatar-nina.svg" alt="Avatar niña" class="w-full h-full object-contain drop-shadow-sm group-[.selected]:scale-105 transition-transform duration-200">
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full bg-pink-400 opacity-0 group-[.selected]:opacity-100 transition-opacity duration-200"></span>
                  <p class="text-sm font-bold text-gray-500 group-[.selected]:text-pink-500 transition-colors duration-200">Exploradora</p>
                </div>
              </div>
            </label>

          </div>
          
          <!-- Error de avatar -->
          <p class="text-red-500 text-xs text-center hidden" id="avatar-error">Por favor selecciona tu avatar</p>
        </div>

        <!-- Campo de Nombre con icono -->
        <div class="animate-fade-in" style="animation-delay: 0.3s">
          <label for="nombreInput" class="block text-sm font-semibold text-gray-700 mb-1.5">
            ¿Cómo te llamas?
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
            </div>
            <input 
              type="text" 
              name="nombre" 
              id="nombreInput"
              placeholder="Escribe tu nombre..." 
              required
              minlength="2"
              maxlength="30"
              autocomplete="name"
              class="w-full pl-11 pr-4 py-3.5 rounded-xl bg-gray-50 border border-gray-200 focus:border-sky-400 focus:bg-white focus:ring-2 focus:ring-sky-100 outline-none transition-all text-gray-700 placeholder:text-gray-400 text-base text-center"
            >
          </div>
          <p class="text-red-500 text-xs mt-1 hidden" id="nombre-error">Por favor ingresa tu nombre (mínimo 2 caracteres)</p>
        </div>
        
        <!-- Botón de Entrada -->
        <div class="animate-fade-in" style="animation-delay: 0.35s">
          <button 
            type="submit"
            class="w-full py-3.5 px-6 bg-gradient-to-r from-gray-800 to-gray-700 hover:from-gray-700 hover:to-gray-600 text-white font-bold text-base rounded-xl shadow-md hover:shadow-lg transition-all duration-200 transform hover:scale-[1.02] active:scale-[0.98] flex items-center justify-center gap-2.5"
            id="btnEntrar"
          >
            <%- icono('jugar', 'w-5 h-5') %>
            ¡JUGAR AHORA!
          </button>
        </div>
      </form>
    </div>

    <!-- Volver al inicio (decorativo) -->
    <div class="text-center mt-6 animate-fade-in" style="animation-delay: 0.4s">
      <a href="/" class="inline-flex items-center gap-1.5 text-gray-400 hover:text-gray-600 text-xs sm:text-sm transition-colors group">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Mundo Kids
      </a>
    </div>
  </div>

  <style>
    .avatar-option {
      cursor: pointer;
    }
    .w-22 {
      width: 5.5rem;
    }
    .h-22 {
      height: 5.5rem;
    }
    @media (min-width: 640px) {
      .w-22 {
        width: 6rem;
      }
      .h-22 {
        height: 6rem;
      }
    }
  </style>

  <script>
    (function() {
      // ── Selección de avatar ──
      const avatarNino = document.getElementById('avatar-nino');
      const avatarNina = document.getElementById('avatar-nina');
      const radioNino = avatarNino.querySelector('input[type="radio"]');
      const radioNina = avatarNina.querySelector('input[type="radio"]');
      const avatarError = document.getElementById('avatar-error');

      function seleccionarAvatar(el, radio) {
        avatarNino.classList.remove('selected');
        avatarNina.classList.remove('selected');
        el.classList.add('selected');
        radio.checked = true;
        avatarError.classList.add('hidden');
      }

      avatarNino.addEventListener('click', function() {
        seleccionarAvatar(this, radioNino);
      });
      avatarNina.addEventListener('click', function() {
        seleccionarAvatar(this, radioNina);
      });

      // ── Validación inline del formulario ──
      const form = document.getElementById('registroForm');
      const nombreInput = document.getElementById('nombreInput');
      const nombreError = document.getElementById('nombre-error');

      function limpiarError(input, errorEl) {
        input.classList.remove('border-red-300', 'bg-red-50');
        input.classList.add('border-gray-200', 'bg-gray-50');
        errorEl.classList.add('hidden');
      }

      function mostrarError(input, errorEl) {
        input.classList.remove('border-gray-200', 'bg-gray-50');
        input.classList.add('border-red-300', 'bg-red-50');
        errorEl.classList.remove('hidden');
      }

      // Limpiar errores al escribir
      if (nombreInput) {
        nombreInput.addEventListener('input', function() {
          if (this.value.trim().length >= 2) limpiarError(this, nombreError);
        });
        nombreInput.addEventListener('focus', function() {
          if (this.value.trim()) limpiarError(this, nombreError);
        });
      }

      form.addEventListener('submit', function(e) {
        let valido = true;

        // Validar nombre
        const nombre = nombreInput.value.trim();
        if (!nombre || nombre.length < 2) {
          mostrarError(nombreInput, nombreError);
          valido = false;
        } else {
          limpiarError(nombreInput, nombreError);
        }

        // Validar género
        if (!radioNino.checked && !radioNina.checked) {
          avatarError.classList.remove('hidden');
          valido = false;
        } else {
          avatarError.classList.add('hidden');
        }

        if (!valido) {
          e.preventDefault();
          // Enfocar el primer campo con error
          if (!radioNino.checked && !radioNina.checked) {
            avatarNino.focus();
          } else {
            nombreInput.focus();
          }
        }
      });
    })();
  </script>
</div>
