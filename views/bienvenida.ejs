<div class="min-h-screen flex items-center justify-center p-6 animate-fade-in">
  
  <div class="glass-effect rounded-[2rem] soft-shadow p-10 max-w-lg w-full text-center">
    
    <!-- Logo y Título -->
    <div class="mb-10">
      <div class="flex flex-col items-center justify-center gap-4 mb-4">
        <div class="bg-sky-100 p-5 rounded-3xl text-sky-600 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe-2"><path d="M4 12a8 8 0 0 1 16 0"/><path d="M12 2v20"/><path d="m20 15-8 5-8-5"/><path d="m4 9 8 5 8-5"/></svg>
        </div>
        <div>
          <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight">Mundo <span class="text-sky-500">Kids</span></h1>
          <p class="text-slate-500 text-xl font-medium mt-2">Explora el mundo con elegancia y diversión</p>
        </div>
      </div>
    </div>

    <!-- Formulario -->
    <form action="/menu" method="POST" class="space-y-8" id="registroForm">
      
      <!-- Selección de Género -->
      <div class="space-y-4">
        <p class="text-slate-700 font-semibold text-lg">Elige tu avatar para comenzar</p>
        <div class="flex justify-center gap-8">
          <label class="avatar-option group" id="avatar-nino">
            <input type="radio" name="genero" value="masculino" required>
            <div class="flex flex-col items-center transition-all">
              <div class="w-24 h-24 rounded-2xl bg-white soft-shadow flex items-center justify-center group-hover:bg-sky-50 transition-colors border-2 border-transparent group-[.selected]:border-sky-500 group-[.selected]:bg-sky-50">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-round text-sky-500"><path d="M18 20a6 6 0 0 0-12 0"/><circle cx="12" cy="10" r="4"/></svg>
              </div>
              <p class="mt-3 text-slate-600 font-bold group-[.selected]:text-sky-600">Explorador</p>
            </div>
          </label>
          
          <label class="avatar-option group" id="avatar-nina">
            <input type="radio" name="genero" value="femenino" required>
            <div class="flex flex-col items-center transition-all">
              <div class="w-24 h-24 rounded-2xl bg-white soft-shadow flex items-center justify-center group-hover:bg-pink-50 transition-colors border-2 border-transparent group-[.selected]:border-pink-400 group-[.selected]:bg-pink-50">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-round text-pink-400"><path d="M18 20a6 6 0 0 0-12 0"/><circle cx="12" cy="10" r="4"/></svg>
              </div>
              <p class="mt-3 text-slate-600 font-bold group-[.selected]:text-pink-500">Exploradora</p>
            </div>
          </label>
        </div>
      </div>

      <!-- Campo de Nombre -->
      <div class="relative">
        <input 
          type="text" 
          name="nombre" 
          id="nombreInput"
          placeholder="Escribe tu nombre..." 
          required
          minlength="2"
          maxlength="30"
          class="w-full px-6 py-4 rounded-2xl bg-white/50 border border-slate-200 focus:border-sky-400 focus:bg-white focus:outline-none text-center text-xl font-semibold text-slate-800 transition-all soft-shadow"
        >
      </div>
      
      <!-- Botón de Entrada -->
      <button 
        type="submit"
        class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold text-xl py-5 rounded-2xl shadow-xl hover:shadow-sky-200 transition-all transform hover:-translate-y-1 active:translate-y-0"
        id="btnEntrar"
      >
        COMENZAR AVENTURA
      </button>
    </form>

  </div>

  <style>
    .avatar-option {
      cursor: pointer;
    }
    .avatar-option.selected .w-24 {
      transform: scale(1.05);
    }
  </style>

  <script>
    // Manejo de selección de avatar
    const avatarNino = document.getElementById('avatar-nino');
    const avatarNina = document.getElementById('avatar-nina');
    const radioNino = avatarNino.querySelector('input[type="radio"]');
    const radioNina = avatarNina.querySelector('input[type="radio"]');

    avatarNino.addEventListener('click', function() {
      radioNino.checked = true;
      avatarNino.classList.add('selected');
      avatarNina.classList.remove('selected');
    });

    avatarNina.addEventListener('click', function() {
      radioNina.checked = true;
      avatarNina.classList.add('selected');
      avatarNino.classList.remove('selected');
    });

    // Validación del formulario
    const form = document.getElementById('registroForm');
    const nombreInput = document.getElementById('nombreInput');

    form.addEventListener('submit', function(e) {
      const nombre = nombreInput.value.trim();
      const generoSeleccionado = document.querySelector('input[name="genero"]:checked');

      if (!nombre || nombre.length < 2) {
        e.preventDefault();
        alert('Por favor, ingresa tu nombre (mínimo 2 caracteres)');
        return false;
      }

      if (!generoSeleccionado) {
        e.preventDefault();
        alert('Por favor, selecciona tu avatar');
        return false;
      }
    });
  </script>
</div>
