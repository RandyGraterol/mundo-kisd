<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Mundo Kids - Plataforma educativa para aprender geografía jugando">
  <title>Mundo Kids - Aprende Geografía Jugando</title>
  
  <!-- Tailwind CSS (local / offline) -->
  <script src="/js/tailwind-cdn.min.js"></script>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Estilos globales -->
  <link rel="stylesheet" href="/css/estilos-globales.css">
  
  <!-- Estilos personalizados -->
  <style>
    body {
      font-family: 'Quicksand', sans-serif;
    }
    
    /* Animaciones suaves */
    .hover-scale {
      transition: transform 0.2s ease-in-out;
    }
    
    .hover-scale:hover {
      transform: scale(1.05);
    }
    
    /* Sombras personalizadas suaves */
    .soft-shadow {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    /* Fondo blanco estricto */
    .bg-main-gradient {
      background: #ffffff;
      background-attachment: fixed;
    }

    /* Glassmorphism sutil para unificación */
    .glass-effect {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }

    /* Ocultar scrollbar visualmente, mantener scroll funcional */
    .scroll-container::-webkit-scrollbar {
      display: none;
    }
    .scroll-container {
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
  </style>
</head>
<body class="bg-white">
  <div class="<% if (typeof esPaginaAuth !== 'undefined' && esPaginaAuth) { %>h-screen flex flex-col<% } else { %>min-h-screen<% } %>">
  <!-- ═══ GLOBAL NAVIGATION ═══ -->
  <nav id="global-nav" class="<% if (typeof esPaginaAuth !== 'undefined' && esPaginaAuth) { %>shrink-0<% } %>">
    <div class="nav-container">
      <a href="<%= (typeof nombreUsuario !== 'undefined' && nombreUsuario) ? '/menu' : '/' %>" class="nav-brand">
        <%- icono('continentes', 'nav-brand-icon') %>
        <span class="nav-brand-text">Mundo Kids</span>
      </a>

      <% if (typeof esPaginaAuth === 'undefined' || !esPaginaAuth) { %>
      <div class="nav-collapse" id="navCollapse">
        <div class="nav-links">
          <% if (typeof nombreUsuario !== 'undefined' && nombreUsuario) { %>
            <% if (typeof usuario !== 'undefined' && usuario && usuario.rol === 'profesor') { %>
              <a href="/menu" class="nav-link">Inicio</a>
              <a href="/continentes" class="nav-link">Continentes</a>
              <a href="/admin" class="nav-link">Dashboard</a>
              <a href="/admin/contenido" class="nav-link">Contenido</a>
              <a href="/admin/monitoreo" class="nav-link">Monitoreo</a>
              <a href="/admin/temporizador" class="nav-link">Temporizador</a>
            <% } else { %>
              <a href="/menu" class="nav-link">Inicio</a>
              <a href="/continentes" class="nav-link">Continentes</a>
              <a href="/trivia-banderas" class="nav-link">Trivia</a>
              <a href="/clasificacion" class="nav-link">Ranking</a>
            <% } %>
          <% } %>
        </div>

        <div class="nav-actions">
          <button id="theme-toggle-btn" class="nav-theme-switch" aria-label="Cambiar modo oscuro/claro" title="Cambiar modo oscuro/claro">
            <span class="theme-switch-track">
              <svg class="theme-switch-icon theme-switch-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"/>
                <path d="M12 2v2"/>
                <path d="M12 20v2"/>
                <path d="m4.93 4.93 1.41 1.41"/>
                <path d="m17.66 17.66 1.41 1.41"/>
                <path d="M2 12h2"/>
                <path d="M20 12h2"/>
                <path d="m6.34 17.66-1.41 1.41"/>
                <path d="m19.07 4.93-1.41 1.41"/>
              </svg>
              <span class="theme-switch-dot"></span>
              <svg class="theme-switch-icon theme-switch-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
          <% if (typeof nombreUsuario !== 'undefined' && nombreUsuario) { %>
            <a href="/perfil" class="nav-user">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
              <span class="nav-user-name"><%= nombreUsuario %></span>
            </a>
            <a href="/salir" class="nav-logout">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              <span>Salir</span>
            </a>
          <% } %>
        </div>
      </div>

      <button class="nav-hamburger" id="navHamburger" aria-label="Menú de navegación">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
      </button>
      <% } else { %>
      <div class="nav-actions">
        <button id="theme-toggle-btn" class="nav-theme-switch" aria-label="Cambiar modo oscuro/claro" title="Cambiar modo oscuro/claro">
          <span class="theme-switch-track">
            <svg class="theme-switch-icon theme-switch-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2"/>
              <path d="M12 20v2"/>
              <path d="m4.93 4.93 1.41 1.41"/>
              <path d="m17.66 17.66 1.41 1.41"/>
              <path d="M2 12h2"/>
              <path d="M20 12h2"/>
              <path d="m6.34 17.66-1.41 1.41"/>
              <path d="m19.07 4.93-1.41 1.41"/>
            </svg>
            <span class="theme-switch-dot"></span>
            <svg class="theme-switch-icon theme-switch-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </span>
        </button>
      </div>
      <% } %>
    </div>
  </nav>

  <!-- Mensajes Flash Globales -->
  <% if (typeof flashMessage !== 'undefined' && flashMessage) { %>
    <div id="flash-message" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 animate-slide-in" style="max-width: 90vw;">
      <div class="<%= flashMessage.tipo === 'exito' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : flashMessage.tipo === 'error' ? 'bg-red-50 border-red-200 text-red-800' : 'bg-sky-50 border-sky-200 text-sky-800' %> px-5 py-3 rounded-2xl border shadow-xl flex items-center gap-3 text-sm font-medium">
        <% if (flashMessage.tipo === 'exito') { %>
          <svg class="w-5 h-5 text-emerald-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else if (flashMessage.tipo === 'error') { %>
          <svg class="w-5 h-5 text-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <% } else { %>
          <svg class="w-5 h-5 text-sky-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <% } %>
        <span><%= flashMessage.texto %></span>
        <button onclick="this.parentElement.parentElement.remove()" class="ml-2 hover:opacity-70 transition-opacity">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <script>
      setTimeout(function() {
        var el = document.getElementById('flash-message');
        if (el) {
          el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          el.style.opacity = '0';
          el.style.transform = 'translateX(-50%) translateY(-20px)';
          setTimeout(function() { el.remove(); }, 500);
        }
      }, 4000);
    </script>
  <% } %>

  <!-- Contenido dinámico -->
  <main class="<% if (typeof esPaginaAuth !== 'undefined' && esPaginaAuth) { %>flex-1 overflow-y-auto scroll-container<% } %>">
    <%- body %>
  </main>

  <!-- Footer global -->
  <%- include('partials/footer') %>
</div>

  <!-- Sistema de Sonidos -->
  <%- include('partials/sonidos') %>
  <!-- Sistema de Iconos SVG -->
  <%- include('partials/iconos') %>

  <script>
    (function() {
      var temaGuardado = localStorage.getItem('mundo-kids-theme');
      var tema = temaGuardado || 'light';
      var html = document.documentElement;
      var switchTrack = document.querySelector('.theme-switch-track');

      function aplicarTema(t) {
        html.setAttribute('data-theme', t);
        if (switchTrack) {
          if (t === 'dark') {
            switchTrack.classList.add('theme-dark');
          } else {
            switchTrack.classList.remove('theme-dark');
          }
        }
        localStorage.setItem('mundo-kids-theme', t);
      }

      aplicarTema(tema);

      var btn = document.getElementById('theme-toggle-btn');
      if (btn) {
        btn.addEventListener('click', function() {
          var actual = html.getAttribute('data-theme');
          aplicarTema(actual === 'dark' ? 'light' : 'dark');
          if (typeof SonidosMundoKids !== 'undefined') {
            SonidosMundoKids.click();
          }
        });
      }

      // Hamburger menu toggle
      var hamburger = document.getElementById('navHamburger');
      var collapse = document.getElementById('navCollapse');
      if (hamburger && collapse) {
        hamburger.addEventListener('click', function() {
          collapse.classList.toggle('nav-open');
          hamburger.classList.toggle('nav-hamburger-active');
        });
      }
    })();
  </script>
</body>
</html>