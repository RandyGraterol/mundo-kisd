<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Mundo Kids - Plataforma educativa para aprender geografía jugando">
  <title>Mundo Kids - Aprende Geografía Jugando</title>
  
  <!-- Tailwind CSS (local / offline) -->
  <script src="/js/tailwind-cdn.min.js"></script>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Estilos globales -->
  <link rel="stylesheet" href="/css/estilos-globales.css">
  
  <!-- Estilos personalizados -->
  <style>
    body {
      font-family: 'Quicksand', sans-serif;
    }
    
    /* Animaciones suaves */
    .hover-scale {
      transition: transform 0.2s ease-in-out;
    }
    
    .hover-scale:hover {
      transform: scale(1.05);
    }
    
    /* Sombras personalizadas suaves */
    .soft-shadow {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    /* Fondo blanco estricto */
    .bg-main-gradient {
      background: #ffffff;
      background-attachment: fixed;
    }

    /* Glassmorphism sutil para unificación */
    .glass-effect {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
  </style>
</head>
<body class="bg-white min-h-screen">
  <!-- Mensajes Flash Globales -->
  <% if (typeof flashMessage !== 'undefined' && flashMessage) { %>
    <div id="flash-message" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 animate-slide-in" style="max-width: 90vw;">
      <div class="<%= flashMessage.tipo === 'exito' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : flashMessage.tipo === 'error' ? 'bg-red-50 border-red-200 text-red-800' : 'bg-sky-50 border-sky-200 text-sky-800' %> px-5 py-3 rounded-2xl border shadow-xl flex items-center gap-3 text-sm font-medium">
        <% if (flashMessage.tipo === 'exito') { %>
          <svg class="w-5 h-5 text-emerald-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <% } else if (flashMessage.tipo === 'error') { %>
          <svg class="w-5 h-5 text-red-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <% } else { %>
          <svg class="w-5 h-5 text-sky-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <% } %>
        <span><%= flashMessage.texto %></span>
        <button onclick="this.parentElement.parentElement.remove()" class="ml-2 hover:opacity-70 transition-opacity">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <script>
      // Auto-cerrar flash message después de 4 segundos
      setTimeout(function() {
        var el = document.getElementById('flash-message');
        if (el) {
          el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          el.style.opacity = '0';
          el.style.transform = 'translateX(-50%) translateY(-20px)';
          setTimeout(function() { el.remove(); }, 500);
        }
      }, 4000);
    </script>
  <% } %>

  <!-- Contenido dinámico -->
  <%- body %>
  <!-- Sistema de Sonidos -->
  <%- include('partials/sonidos') %>
  <!-- Sistema de Iconos SVG -->
  <%- include('partials/iconos') %>
</body>
</html>
