<div class="min-h-screen bg-white p-6 animate-fade-in">
  <div class="max-w-4xl mx-auto">
    
    <!-- Encabezado -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-3 bg-gradient-to-r from-amber-50 to-orange-50 px-6 py-3 rounded-full border border-amber-200 soft-shadow mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-600"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
        <h1 class="text-3xl font-bold text-amber-800">Tabla de Clasificación</h1>
      </div>
      <p class="text-lg text-slate-500">Los mejores exploradores de Mundo Kids</p>
    </div>

    <!-- Top 3 Destacados (si hay suficientes alumnos) -->
    <% if (ranking.length >= 3) { %>
    <div class="grid grid-cols-3 gap-responsive gap-4 mb-10 max-w-2xl mx-auto">
      <!-- #2 - Segundo lugar -->
      <div class="text-center pt-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-slate-400"><path d="M9 5H2v7l6.29 6.29a1 1 0 0 0 1.42 0l5.58-5.58a1 1 0 0 0 0-1.42L9 5Z"/><path d="M6 9.01V9"/><path d="m15 5 6.3 6.3a1 1 0 0 1 0 1.4L15 19"/></svg>
        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-2 border-2 border-slate-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h3 class="font-bold text-slate-800 text-sm"><%= ranking[1].nombre_completo.split(' ')[0] %></h3>
        <p class="text-xs text-slate-400">Nivel <%= ranking[1].nivel %></p>
        <p class="text-sm font-bold text-amber-600"><%= ranking[1].puntos_total %> pts</p>
      </div>

      <!-- #1 - Primer lugar (destacado) -->
      <div class="text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-amber-500"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-2 border-4 border-amber-400 shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-600"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h3 class="font-bold text-slate-800 text-lg"><%= ranking[0].nombre_completo.split(' ')[0] %></h3>
        <p class="text-sm text-amber-500">Nivel <%= ranking[0].nivel %></p>
        <p class="text-lg font-bold text-amber-600"><%= ranking[0].puntos_total %> pts</p>
      </div>

      <!-- #3 - Tercer lugar -->
      <div class="text-center pt-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-amber-700"><path d="M9.813 15.904 9 18.75"/><path d="M14.5 15.904 15 18.75"/><path d="M7.626 12.75 6 18.75"/><path d="M11.25 12.75 12 18.75"/><path d="M15.75 12.75 16.5 18.75"/><path d="M18 8.25c0 1.5-.75 3-2.25 3H7.5C6.75 11.25 6 9.75 6 8.25c0-2.25 1.5-4.5 3.75-4.5h4.5c2.25 0 3.75 2.25 3.75 4.5Z"/></svg>
        <div class="w-16 h-16 bg-amber-50 rounded-full flex items-center justify-center mx-auto mb-2 border-2 border-amber-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h3 class="font-bold text-slate-800 text-sm"><%= ranking[2].nombre_completo.split(' ')[0] %></h3>
        <p class="text-xs text-slate-400">Nivel <%= ranking[2].nivel %></p>
        <p class="text-sm font-bold text-amber-600"><%= ranking[2].puntos_total %> pts</p>
      </div>
    </div>
    <% } %>

    <!-- Tu posición -->
    <% if (posicionUsuario) { %>
    <div class="bg-gradient-to-r from-sky-50 to-indigo-50 rounded-2xl p-4 mb-6 border border-sky-200 soft-shadow">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-2xl font-bold text-sky-600">#<%= posicionUsuario %></span>
          <span class="text-slate-500">—</span>
          <span class="font-semibold text-slate-700">Tu posición</span>
        </div>
        <span class="text-sm text-slate-400">de <%= totalAlumnos %> alumnos</span>
      </div>
      <div class="mt-2 w-full bg-sky-200 rounded-full h-1.5">
        <div class="bg-sky-500 h-1.5 rounded-full" style="width: <%= Math.round((totalAlumnos - posicionUsuario + 1) / totalAlumnos * 100) %>%"></div>
      </div>
    </div>
    <% } %>

    <!-- Lista completa del ranking -->
    <div class="bg-white rounded-2xl soft-shadow border border-slate-200 overflow-hidden">
      <div class="grid-cols-12 gap-2 px-responsive py-3 bg-slate-50 border-b border-slate-200 text-sm font-semibold text-slate-500 hidden sm:grid">
        <div class="col-span-1">#</div>
        <div class="col-span-5">Nombre</div>
        <div class="col-span-2 text-center">Nivel</div>
        <div class="col-span-2 text-center">Puntos</div>
        <div class="col-span-2 text-center">Logros</div>
      </div>

      <% if (ranking.length === 0) { %>
        <div class="text-center py-12 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 text-slate-300"><path d="M22 12h-6l-2 3H10l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          <p class="text-lg">Aún no hay alumnos registrados</p>
          <p class="text-sm">¡Regístrate para aparecer en la clasificación!</p>
        </div>
      <% } else { %>
        <% ranking.forEach((alumno, index) => { %>
        <div class="sm:grid grid-cols-12 gap-2 px-responsive py-4 items-center border-b border-slate-100 hover:bg-slate-50 transition-colors <%= alumno.id === (usuario && usuario.id) ? 'bg-sky-50/50' : '' %>">
          <div class="col-span-1 hidden sm:block">
            <% if (index === 0) { %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 17 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
            <% } else if (index === 1) { %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M9 5H2v7l6.29 6.29a1 1 0 0 0 1.42 0l5.58-5.58a1 1 0 0 0 0-1.42L9 5Z"/><path d="M6 9.01V9"/><path d="m15 5 6.3 6.3a1 1 0 0 1 0 1.4L15 19"/></svg>
            <% } else if (index === 2) { %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-700"><path d="M9.813 15.904 9 18.75"/><path d="M14.5 15.904 15 18.75"/><path d="M7.626 12.75 6 18.75"/><path d="M11.25 12.75 12 18.75"/><path d="M15.75 12.75 16.5 18.75"/><path d="M18 8.25c0 1.5-.75 3-2.25 3H7.5C6.75 11.25 6 9.75 6 8.25c0-2.25 1.5-4.5 3.75-4.5h4.5c2.25 0 3.75 2.25 3.75 4.5Z"/></svg>
            <% } else { %><span class="text-slate-400 font-mono font-bold"><%= index + 1 %></span><% } %>
          </div>
          <div class="sm:col-span-5 col-span-7 flex items-center gap-3">
            <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="min-w-0 flex-1">
              <p class="font-semibold text-slate-800 truncate"><%= alumno.nombre_completo %></p>
              <p class="text-xs text-slate-400">@<%= alumno.nombre_usuario %></p>
            </div>
          </div>
          <div class="col-span-2 text-center hidden sm:block">
            <span class="inline-flex items-center gap-1 bg-amber-100 text-amber-700 font-bold px-3 py-1 rounded-full text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 5 8.6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C18 4 18 7 19 8.6"/><path d="M4 14h16"/><path d="M10 12v4"/><path d="M12 12v4"/><path d="M14 12v4"/><path d="M8 18h8"/></svg>
              <%= alumno.nivel %>
            </span>
          </div>
          <div class="sm:col-span-2 col-span-3 text-right sm:text-center font-bold text-sky-600 text-lg">
            <%= alumno.puntos_total %>
          </div>
          <div class="col-span-2 text-center text-slate-400 hidden sm:block">
            -
          </div>
        </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Botón volver -->
    <div class="text-center mt-8">
      <a href="/menu" 
         class="inline-flex items-center gap-2 bg-white hover:bg-slate-50 text-slate-700 font-bold px-8 py-3 rounded-2xl transition-all border border-slate-200 soft-shadow">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
        Volver al Menú
      </a>
    </div>

  </div>
</div>
